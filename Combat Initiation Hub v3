-- ★★★ AUTO ATTACK (НЕ взаимодействует с GUI) ★★★
-- ============================================
local lastAttack = 0

local function IsMouseOverGUI()
    -- Проверяем, не наведён ли курсор на наш GUI
    local mousePos = UserInputService:GetMouseLocation()
    
    if MainFrame.Visible then
        local absPos = MainFrame.AbsolutePosition
        local absSize = MainFrame.AbsoluteSize
        if mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X
           and mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y then
            return true
        end
    end
    
    return false
end

local function SafeClick()
    -- Кликает только если курсор НЕ на GUI
    if IsMouseOverGUI() then return end
    
    pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        local vp = Camera.ViewportSize
        -- Кликаем по центру экрана (игровой процесс)
        VIM:SendMouseButtonEvent(vp.X / 2, vp.Y / 2, 0, true, game, 0)
        task.wait(0.02)
        VIM:SendMouseButtonEvent(vp.X / 2, vp.Y / 2, 0, false, game, 0)
    end)
end

local function CombatLoop()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local myRoot = LocalPlayer.Character.HumanoidRootPart
    
    -- Kill Aura (inf range)
    if Settings.KillAura then
        local npcs = GetAllNPCs()
        local closestNPC = nil
        local closestDist = math.huge
        
        for _, npc in pairs(npcs) do
            local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
            if root then
                local d = (root.Position - myRoot.Position).Magnitude
                if d < closestDist then
                    closestDist = d
                    closestNPC = npc
                end
            end
        end
        
        -- Также атакуем игроков
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local theirRoot = player.Character:FindFirstChild("HumanoidRootPart")
                local theirHum = player.Character:FindFirstChildOfClass("Humanoid")
                if theirRoot and theirHum and theirHum.Health > 0 then
                    local d = (theirRoot.Position - myRoot.Position).Magnitude
                    if d < closestDist then
                        closestDist = d
                    end
                end
            end
        end
        
        if tick() - lastAttack > Settings.AttackSpeed then
            lastAttack = tick()
            SafeClick()
        end
    end
    
    -- Auto Attack (inf range, безопасный клик)
    if Settings.AutoAttack and not Settings.KillAura then
        if tick() - lastAttack > Settings.AttackSpeed then
            lastAttack = tick()
            SafeClick()
        end
    end
end

-- Auto Farm (inf range)
local function AutoFarm()
    if not Settings.AutoFarm_Enabled then return end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local myRoot = LocalPlayer.Character.HumanoidRootPart
    local npcs = GetAllNPCs()
    
    local closestNPC = nil
    local closestDist = math.huge -- inf range
    
    for _, npc in pairs(npcs) do
        local root = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if root then
            local d = (root.Position - myRoot.Position).Magnitude
            if d < closestDist then
                closestDist = d
                closestNPC = npc
            end
        end
    end
    
    if closestNPC then
        local root = closestNPC:FindFirstChild("HumanoidRootPart") or closestNPC:FindFirstChild("Head")
        if root then
            myRoot.CFrame = root.CFrame * CFrame.new(0, 0, 3)
            SafeClick()
        end
    end
end

