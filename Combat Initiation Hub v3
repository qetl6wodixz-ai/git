local function CreateSlider(parent, text, min, max, default, step, callback)
    if type(step) == "function" then
        callback = step
        step = 1
    end
    step = step or 1
    
    local SliderFrame = Instance.new("Frame")
    SliderFrame.Parent = parent
    SliderFrame.BackgroundColor3 = Theme.Card
    SliderFrame.BorderSizePixel = 0
    SliderFrame.Size = UDim2.new(1, 0, 0, 48)
    
    local SliderCorner = Instance.new("UICorner")
    SliderCorner.CornerRadius = UDim.new(0, 8)
    SliderCorner.Parent = SliderFrame
    
    local Label = Instance.new("TextLabel")
    Label.Parent = SliderFrame
    Label.BackgroundTransparency = 1
    Label.Position = UDim2.new(0, 12, 0, 4)
    Label.Size = UDim2.new(0.7, 0, 0, 18)
    Label.Font = Enum.Font.GothamSemibold
    Label.Text = text
    Label.TextColor3 = Theme.Text
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local ValueLabel = Instance.new("TextLabel")
    ValueLabel.Parent = SliderFrame
    ValueLabel.BackgroundTransparency = 1
    ValueLabel.Position = UDim2.new(0.7, 0, 0, 4)
    ValueLabel.Size = UDim2.new(0.3, -12, 0, 18)
    ValueLabel.Font = Enum.Font.GothamBold
    ValueLabel.Text = tostring(default)
    ValueLabel.TextColor3 = Theme.PrimaryGlow
    ValueLabel.TextSize = 12
    ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
    
    local SliderBar = Instance.new("Frame")
    SliderBar.Parent = SliderFrame
    SliderBar.BackgroundColor3 = Theme.SliderBg
    SliderBar.Position = UDim2.new(0, 12, 0, 28)
    SliderBar.Size = UDim2.new(1, -24, 0, 8)
    
    local SliderBarCorner = Instance.new("UICorner")
    SliderBarCorner.CornerRadius = UDim.new(0, 4)
    SliderBarCorner.Parent = SliderBar
    
    local Fill = Instance.new("Frame")
    Fill.Parent = SliderBar
    Fill.BackgroundColor3 = Theme.SliderFill
    Fill.Size = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), 0, 1, 0)
    
    local FillCorner = Instance.new("UICorner")
    FillCorner.CornerRadius = UDim.new(0, 4)
    FillCorner.Parent = Fill
    
    -- Кнопка-ползунок
    local Knob = Instance.new("Frame")
    Knob.Parent = SliderBar
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Knob.Position = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), -7, 0.5, -7)
    Knob.Size = UDim2.new(0, 14, 0, 14)
    Knob.ZIndex = 5
    
    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(1, 0)
    KnobCorner.Parent = Knob
    
    local KnobStroke = Instance.new("UIStroke")
    KnobStroke.Parent = Knob
    KnobStroke.Color = Theme.Primary
    KnobStroke.Thickness = 2
    
    local SliderBtn = Instance.new("TextButton")
    SliderBtn.Parent = SliderBar
    SliderBtn.BackgroundTransparency = 1
    SliderBtn.Size = UDim2.new(1, 0, 3, 0)
    SliderBtn.Position = UDim2.new(0, 0, -1, 0)
    SliderBtn.Text = ""
    SliderBtn.ZIndex = 6
    
    local dragging = false
    local lastSoundTick = 0
    
    SliderBtn.MouseButton1Down:Connect(function()
        dragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
            local rawValue = min + (max - min) * rel
            local value
            if step < 1 then
                value = math.floor(rawValue / step + 0.5) * step
                value = tonumber(string.format("%.2f", value))
            else
                value = math.floor(rawValue + 0.5)
            end
            value = math.clamp(value, min, max)
            local normalizedRel = (value - min) / (max - min)
            
            Fill.Size = UDim2.new(normalizedRel, 0, 1, 0)
            Knob.Position = UDim2.new(normalizedRel, -7, 0.5, -7)
            ValueLabel.Text = tostring(value)
            
            -- Тихий тик при перетаскивании
            if tick() - lastSoundTick > 0.15 then
                lastSoundTick = tick()
                PlaySound(Sounds.SliderTick)
            end
            
            if callback then callback(value) end
        end
    end)
    
    SliderFrame.MouseEnter:Connect(function()
        TweenService:Create(SliderFrame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.CardHover}):Play()
    end)
    SliderFrame.MouseLeave:Connect(function()
        TweenService:Create(SliderFrame, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Card}):Play()
    end)
    
    return SliderFrame
end

