function resetToolCooldown(tool)
    if not tool or not tool:IsA("Tool") then return end
    local cd = Settings.SwordCooldown_Value
    
    pcall(function()
        local names = {
            "Cooldown","cooldown","CD","cd","AttackCooldown","attackCooldown",
            "SwingCooldown","swingCooldown","HitCooldown","hitCooldown",
            "Debounce","debounce","CooldownTime","cooldownTime",
            "AttackSpeed","attackSpeed","SwingRate","swingRate",
            "Delay","delay","AttackDelay","attackDelay","SlashCooldown",
        }
        for _, n in pairs(names) do
            local val = tool:GetAttribute(n)
            if val ~= nil then
                if type(val) == "number" then tool:SetAttribute(n, cd) end
                if type(val) == "boolean" then tool:SetAttribute(n, true) end
            end
        end
    end)
    
    pcall(function()
        for _, desc in pairs(tool:GetDescendants()) do
            if desc:IsA("NumberValue") or desc:IsA("IntValue") then
                local n = desc.Name:lower()
                if n:find("cool") or n:find("delay") or n:find("debounce") or n:find("rate") or n:find("cd") or n:find("wait") or n:find("timer") then
                    desc.Value = cd
                end
            elseif desc:IsA("BoolValue") then
                local n = desc.Name:lower()
                if n:find("can") or n:find("ready") or n:find("enabled") or n:find("debounce") then
                    desc.Value = true
                end
            end
        end
    end)
    
    pcall(function()
        for _, desc in pairs(tool:GetDescendants()) do
            if desc:IsA("ModuleScript") then
                local ok, mod = pcall(require, desc)
                if ok and type(mod) == "table" then
                    local function patch(tbl, depth)
                        if depth > 3 then return end
                        for k, v in pairs(tbl) do
                            local ks = tostring(k):lower()
                            if type(v) == "number" and (ks:find("cool") or ks:find("delay") or ks:find("cd") or ks:find("debounce") or ks:find("rate") or ks:find("swing")) then
                                tbl[k] = cd
                            elseif type(v) == "table" then
                                patch(v, depth + 1)
                            end
                        end
                    end
                    patch(mod, 0)
                end
            end
        end
    end)
end

function deepInjectCooldownBypass()
    local cd = Settings.SwordCooldown_Value
    PlaySound(Sounds.PowerUp)
    
    pcall(function()
        for _, desc in pairs(ReplicatedStorage:GetDescendants()) do
            if desc:IsA("ModuleScript") then
                local n = desc.Name:lower()
                if n:find("combat") or n:find("weapon") or n:find("sword") or n:find("tool") or n:find("attack") or n:find("config") or n:find("data") then
                    pcall(function()
                        local mod = require(desc)
                        if type(mod) == "table" then
                            local function dp(tbl, depth)
                                if depth > 5 then return end
                                for k, v in pairs(tbl) do
                                    local ks = tostring(k):lower()
                                    if type(v) == "number" and (ks:find("cool") or ks:find("delay") or ks:find("cd") or ks:find("debounce") or ks:find("swing") or ks:find("rate")) then
                                        tbl[k] = cd
                                    elseif type(v) == "table" then
                                        dp(v, depth + 1)
                                    end
                                end
                            end
                            dp(mod, 0)
                        end
                    end)
                end
            end
        end
    end)
    
    pcall(function()
        if getconnections and getupvalue and setupvalue then
            local char = LocalPlayer.Character
            if char then
                for _, tool in pairs(char:GetChildren()) do
                    if tool:IsA("Tool") then
                        pcall(function()
                            for _, conn in pairs(getconnections(tool.Activated)) do
                                for i = 1, 20 do
                                    pcall(function()
                                        local uv = getupvalue(conn.Function, i)
                                        if type(uv) == "number" and uv > 0.1 and uv <= 5 then
                                            setupvalue(conn.Function, i, cd)
                                        elseif type(uv) == "table" then
                                            for k2, v2 in pairs(uv) do
                                                if type(v2) == "number" and tostring(k2):lower():find("cool") then
                                                    uv[k2] = cd
                                                end
                                            end
                                        end
                                    end)
                                end
                            end
                        end)
                    end
                end
            end
        end
    end)
end

