local function CreateTab(name, icon, description)
    local index = #TabButtons
    
    local TabBtn = Instance.new("TextButton")
    TabBtn.Name = name
    TabBtn.Parent = Sidebar
    TabBtn.BackgroundColor3 = Theme.Card
    TabBtn.BackgroundTransparency = 1
    TabBtn.BorderSizePixel = 0
    TabBtn.Position = UDim2.new(0, 8, 0, 8 + (index * 42))
    TabBtn.Size = UDim2.new(1, -16, 0, 36)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.Text = ""
    TabBtn.AutoButtonColor = false
    
    local TabBtnCorner = Instance.new("UICorner")
    TabBtnCorner.CornerRadius = UDim.new(0, 8)
    TabBtnCorner.Parent = TabBtn
    
    -- Иконка таба
    local TabIcon = Instance.new("TextLabel")
    TabIcon.Parent = TabBtn
    TabIcon.BackgroundTransparency = 1
    TabIcon.Position = UDim2.new(0, 8, 0, 0)
    TabIcon.Size = UDim2.new(0, 24, 1, 0)
    TabIcon.Font = Enum.Font.GothamBold
    TabIcon.Text = icon or "•"
    TabIcon.TextColor3 = Theme.TextDim
    TabIcon.TextSize = 16

    -- Текст таба
    local TabText = Instance.new("TextLabel")
    TabText.Parent = TabBtn
    TabText.BackgroundTransparency = 1
    TabText.Position = UDim2.new(0, 34, 0, 0)
    TabText.Size = UDim2.new(1, -40, 1, 0)
    TabText.Font = Enum.Font.GothamSemibold
    TabText.Text = name
    TabText.TextColor3 = Theme.TextDim
    TabText.TextSize = 12
    TabText.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Активный индикатор
    local ActiveBar = Instance.new("Frame")
    ActiveBar.Name = "ActiveBar"
    ActiveBar.Parent = TabBtn
    ActiveBar.BackgroundColor3 = Theme.Primary
    ActiveBar.Position = UDim2.new(0, 0, 0.15, 0)
    ActiveBar.Size = UDim2.new(0, 3, 0.7, 0)
    ActiveBar.Visible = false
    
    local ActiveBarCorner = Instance.new("UICorner")
    ActiveBarCorner.CornerRadius = UDim.new(0, 2)
    ActiveBarCorner.Parent = ActiveBar
    
    -- Контент
    local TabContent = Instance.new("ScrollingFrame")
    TabContent.Name = name
    TabContent.Parent = ContentFrame
    TabContent.BackgroundTransparency = 1
    TabContent.Size = UDim2.new(1, 0, 1, 0)
    TabContent.ScrollBarThickness = 3
    TabContent.ScrollBarImageColor3 = Theme.Primary
    TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabContent.Visible = false
    TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabContent.ScrollingDirection = Enum.ScrollingDirection.Y
    
    local ListLayout = Instance.new("UIListLayout")
    ListLayout.Parent = TabContent
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDim.new(0, 4)
    
    local Padding = Instance.new("UIPadding")
    Padding.Parent = TabContent
    Padding.PaddingTop = UDim.new(0, 4)
    Padding.PaddingLeft = UDim.new(0, 4)
    Padding.PaddingRight = UDim.new(0, 8)
    
    table.insert(TabButtons, {Button = TabBtn, Icon = TabIcon, Text = TabText, Bar = ActiveBar})
    Tabs[name] = TabContent
    
    TabBtn.MouseEnter:Connect(function()
        if CurrentTab ~= name then
            TweenService:Create(TabBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0.5}):Play()
        end
    end)
    
    TabBtn.MouseLeave:Connect(function()
        if CurrentTab ~= name then
            TweenService:Create(TabBtn, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
        end
    end)
    
    TabBtn.MouseButton1Click:Connect(function()
        PlaySound(Sounds.TabSwitch)
        
        for _, v in pairs(Tabs) do v.Visible = false end
        for _, v in pairs(TabButtons) do
            TweenService:Create(v.Button, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
            TweenService:Create(v.Icon, TweenInfo.new(0.2), {TextColor3 = Theme.TextDim}):Play()
            TweenService:Create(v.Text, TweenInfo.new(0.2), {TextColor3 = Theme.TextDim}):Play()
            v.Bar.Visible = false
        end
        
        TabContent.Visible = true
        local tabData = TabButtons[index + 1]
        TweenService:Create(tabData.Button, TweenInfo.new(0.2), {BackgroundTransparency = 0.3}):Play()
        TweenService:Create(tabData.Icon, TweenInfo.new(0.2), {TextColor3 = Theme.PrimaryGlow}):Play()
        TweenService:Create(tabData.Text, TweenInfo.new(0.2), {TextColor3 = Theme.Text}):Play()
        tabData.Bar.Visible = true
        
        CurrentTab = name
    end)
    
    return TabContent
end

