local isAiming = false

local function IsNPC(character)
    -- NPC = у него Humanoid, но нет соответствующего Player
    if not character then return false end
    if Players:GetPlayerFromCharacter(character) then return false end -- это игрок
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head")
    return humanoid ~= nil and root ~= nil and humanoid.Health > 0
end

local function GetAllNPCs()
    local npcs = {}
    
    -- Ищем во всём Workspace
    local function searchIn(parent)
        for _, obj in pairs(parent:GetChildren()) do
            if obj:IsA("Model") and IsNPC(obj) then
                table.insert(npcs, obj)
            end
            -- Рекурсивно в папках
            if obj:IsA("Folder") or obj:IsA("Model") then
                if not Players:GetPlayerFromCharacter(obj) then
                    searchIn(obj)
                end
            end
        end
    end
    
    searchIn(Workspace)
    return npcs
end

local function GetClosestNPCToMouse()
    local closestNPC = nil
    local closestDistance = Settings.Aimbot_FOV
    
    local npcs = GetAllNPCs()
    
    for _, npc in pairs(npcs) do
        local targetPart = npc:FindFirstChild(Settings.Aimbot_TargetPart) or npc:FindFirstChild("Head") or npc:FindFirstChild("HumanoidRootPart")
        if targetPart then
            local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
            if onScreen then
                local mousePos = Vector2.new(Mouse.X, Mouse.Y)
                local screenPoint = Vector2.new(screenPos.X, screenPos.Y)
                local distance = (mousePos - screenPoint).Magnitude
                
                if distance < closestDistance then
                    closestDistance = distance
                    closestNPC = npc
                end
            end
        end
    end
    
    return closestNPC
end

