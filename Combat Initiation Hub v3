local guiOpen = false

local function OpenGUI()
    if guiOpen then return end
    guiOpen = true
    PlaySound(Sounds.OpenGUI)
    
    MainFrame.Visible = true
    MainFrame.BackgroundTransparency = 1
    MainFrame.Size = UDim2.new(0, 520, 0, 440)
    MainFrame.Position = UDim2.new(0.5, -260, 0.5, -220)
    MainStroke.Transparency = 1
    
    -- Затемнение фона
    TweenService:Create(Backdrop, TweenInfo.new(0.4), {BackgroundTransparency = 0.7}):Play()
    
    -- Появление главного фрейма
    TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 560, 0, 480),
        Position = UDim2.new(0.5, -280, 0.5, -240)
    }):Play()
    
    TweenService:Create(MainStroke, TweenInfo.new(0.6), {Transparency = 0.6}):Play()
    
    -- Скрыть иконку
    TweenService:Create(IconButton, TweenInfo.new(0.3), {
        Position = UDim2.new(0, -60, 0.5, -25),
        ImageTransparency = 1
    }):Play()
    
    -- Последовательное появление элементов внутри
    task.wait(0.15)
    for _, child in pairs(TitleBar:GetChildren()) do
        if child:IsA("TextLabel") or child:IsA("ImageLabel") then
            child.TextTransparency = child:IsA("TextLabel") and 1 or 0
            if child:IsA("TextLabel") then
                TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
            end
        end
    end
end

local function CloseGUI()
    if not guiOpen then return end
    guiOpen = false
    PlaySound(Sounds.CloseGUI)
    
    TweenService:Create(Backdrop, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    
    TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 500, 0, 420),
    }):Play()
    
    TweenService:Create(MainStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
    
    -- Показать иконку
    TweenService:Create(IconButton, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        Position = UDim2.new(0, 15, 0.5, -25),
        ImageTransparency = 0
    }):Play()
    
