function Util.AddGradient(parent, color1, color2, rotation)
    return Util.CreateInstance("UIGradient", {
        Color = ColorSequence.new(color1 or Color3.new(1,1,1), color2 or Color3.fromRGB(200,200,200)),
        Rotation = rotation or 90,
        Parent = parent,
    })
end

function Util.Tween(instance, properties, duration, easingStyle, easingDirection)
    if not instance or not instance.Parent then return nil end
    local tweenInfo = TweenInfo.new(
        duration or Config.GUI.AnimationSpeed,
        easingStyle or Enum.EasingStyle.Quart,
        easingDirection or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

function Util.TweenSequence(instance, steps, loopCount)
    loopCount = loopCount or 1
    task.spawn(function()
        for _ = 1, loopCount do
            for _, step in ipairs(steps) do
                local tween = Util.Tween(instance, step.Properties, step.Duration, step.EasingStyle, step.EasingDirection)
                if tween then tween.Completed:Wait() end
            end
        end
    end)
end

function Util.RippleEffect(button, x, y, color)
    local ripple = Util.CreateInstance("Frame", {
        BackgroundColor3 = color or Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.65,
        Position = UDim2.new(0, x - button.AbsolutePosition.X, 0, y - button.AbsolutePosition.Y),
        Size = UDim2.new(0, 0, 0, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = button.ZIndex + 1,
        Parent = button,
    })
    Util.AddCorner(ripple, UDim.new(1, 0))

    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
    local tween = Util.Tween(ripple, {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1,
    }, 0.6, Enum.EasingStyle.Quart)

    if tween then
        tween.Completed:Connect(function()
            ripple:Destroy()
        end)
    end
end

function Util.PulseEffect(instance, scaleAmount, duration)
    scaleAmount = scaleAmount or 0.05
    duration = duration or 0.15
    local origSize = instance.Size
    Util.Tween(instance, {
        Size = origSize + UDim2.new(scaleAmount, 0, scaleAmount, 0)
    }, duration, Enum.EasingStyle.Back)
    task.delay(duration, function()
        Util.Tween(instance, {Size = origSize}, duration * 1.5, Enum.EasingStyle.Quart)
    end)
end

function Util.ShakeEffect(instance, intensity, duration)
    intensity = intensity or 3
    duration = duration or 0.3
    local origPos = instance.Position
    local steps = math.floor(duration / 0.03)
    task.spawn(function()
        for i = 1, steps do
            local offsetX = math.random(-intensity, intensity)
            local offsetY = math.random(-intensity, intensity)
            instance.Position = origPos + UDim2.new(0, offsetX, 0, offsetY)
            task.wait(0.03)
        end
        Util.Tween(instance, {Position = origPos}, 0.1)
    end)
end

function Util.GetPlayerPosition()
    local char = player.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then return root.Position end
    end
    return Vector3.zero
end

function Util.IsPlayerAlive()
    local char = player.Character
    if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

function Util.GetPercentColor(percent)
    if percent >= 80 then return Config.GUI.SuccessColor
    elseif percent >= 50 then return Config.GUI.WarningColor
    elseif percent >= 25 then return Color3.fromRGB(255, 130, 50)
    else return Config.GUI.ErrorColor end
end

function Util.GetComboColor(combo)
    if combo >= 100 then return Config.GUI.MythicColor end
    if combo >= 50 then return Config.GUI.LegendaryColor end
    if combo >= 30 then return Config.GUI.ErrorColor end
    if combo >= 20 then return Color3.fromRGB(255, 150, 0) end
    if combo >= 10 then return Config.GUI.WarningColor end
    if combo >= 5 then return Config.GUI.SuccessColor end
    return Config.GUI.DimTextColor
end

