function GUI._createSlider(parent, label, minVal, maxVal, default, callback)
    local frame = Util.CreateInstance("Frame", {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 38), Parent = parent})
    local valLabel = Util.CreateInstance("TextLabel", {
        BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16),
        Text = label .. ": " .. Util.Round(default, 2),
        TextColor3 = Config.GUI.DimTextColor, TextSize = 11, Font = Config.GUI.FontRegular,
        TextXAlignment = Enum.TextXAlignment.Left, Parent = frame,
    })

    local h = Config.GUI.SliderHeight
    local kSize = Config.GUI.SliderKnobSize
    local bg = Util.CreateInstance("Frame", {
        BackgroundColor3 = Config.GUI.TertiaryColor, Position = UDim2.new(0, 0, 0, 22),
        Size = UDim2.new(1, 0, 0, h), Parent = frame,
    })
    Util.AddCorner(bg, UDim.new(1, 0))

    local norm = (default - minVal) / (maxVal - minVal)
    local fill = Util.CreateInstance("Frame", {
        BackgroundColor3 = Config.GUI.AccentColor, Size = UDim2.new(norm, 0, 1, 0), Parent = bg,
    })
    Util.AddCorner(fill, UDim.new(1, 0))
    Util.AddGradient(fill, Config.GUI.AccentColor, Util.LightenColor(Config.GUI.AccentColor, 0.12), 0)

    local knob = Util.CreateInstance("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        Position = UDim2.new(norm, -kSize/2, 0.5, -kSize/2),
        Size = UDim2.new(0, kSize, 0, kSize), ZIndex = 2, Parent = bg,
    })
    Util.AddCorner(knob, UDim.new(1, 0))
    Util.AddStroke(knob, Config.GUI.AccentColor, 2, 0.3)

    local dragging = false
    local sliderBtn = Util.CreateInstance("TextButton", {
        BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 14),
        Position = UDim2.new(0, 0, 0, -7), Text = "", ZIndex = 3, Parent = bg,
    })

    local function update(input)
        local rel = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = minVal + (maxVal - minVal) * rel
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -kSize/2, 0.5, -kSize/2)
        valLabel.Text = label .. ": " .. Util.Round(val, 2)
        if callback then callback(val) end
    end

    sliderBtn.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    sliderBtn.MouseButton1Click:Connect(function()
        local mp = UserInputService:GetMouseLocation()
        local rel = math.clamp((mp.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = minVal + (maxVal - minVal) * rel
        Util.Tween(fill, {Size = UDim2.new(rel, 0, 1, 0)}, 0.15)
        Util.Tween(knob, {Position = UDim2.new(rel, -kSize/2, 0.5, -kSize/2)}, 0.15)
        valLabel.Text = label .. ": " .. Util.Round(val, 2)
        if callback then callback(val) end
    end)
    return frame
end

