local Util = {}

function Util.Round(number, decimals)
    decimals = decimals or 0
    local mult = 10 ^ decimals
    return math.floor(number * mult + 0.5) / mult
end

function Util.FormatNumber(n)
    if n >= 1000000 then
        return Util.Round(n / 1000000, 2) .. "M"
    elseif n >= 1000 then
        return Util.Round(n / 1000, 1) .. "K"
    end
    return tostring(math.floor(n))
end

function Util.FormatNumberComma(n)
    n = math.floor(n)
    local str = tostring(n)
    local result = ""
    local count = 0
    for i = #str, 1, -1 do
        count = count + 1
        result = str:sub(i, i) .. result
        if count % 3 == 0 and i > 1 then
            result = "," .. result
        end
    end
    return result
end

function Util.FormatTime(seconds)
    seconds = math.max(0, math.floor(seconds))
    local hours = math.floor(seconds / 3600)
    local mins = math.floor((seconds % 3600) / 60)
    local secs = seconds % 60
    if hours > 0 then
        return string.format("%d:%02d:%02d", hours, mins, secs)
    else
        return string.format("%d:%02d", mins, secs)
    end
end

function Util.FormatTimeDetailed(seconds)
    seconds = math.max(0, math.floor(seconds))
    local hours = math.floor(seconds / 3600)
    local mins = math.floor((seconds % 3600) / 60)
    local secs = seconds % 60
    if hours > 0 then
        return string.format("%dч %02dм %02dс", hours, mins, secs)
    elseif mins > 0 then
        return string.format("%dм %02dс", mins, secs)
    else
        return string.format("%dс", secs)
    end
end

function Util.FormatTimestamp()
    local t = os.date("*t")
    return string.format("[%02d:%02d:%02d]", t.hour, t.min, t.sec)
end

function Util.FormatMs(seconds)
    return Util.Round(seconds * 1000, 0) .. "мс"
end

function Util.Lerp(a, b, t)
    return a + (b - a) * math.clamp(t, 0, 1)
end

function Util.LerpColor(c1, c2, t)
    t = math.clamp(t, 0, 1)
    return Color3.new(
        Util.Lerp(c1.R, c2.R, t),
        Util.Lerp(c1.G, c2.G, t),
        Util.Lerp(c1.B, c2.B, t)
    )
end

function Util.DarkenColor(color, amount)
    amount = amount or 0.3
    return Color3.new(
        math.max(0, color.R - amount),
        math.max(0, color.G - amount),
        math.max(0, color.B - amount)
    )
end

function Util.LightenColor(color, amount)
    amount = amount or 0.2
    return Color3.new(
        math.min(1, color.R + amount),
        math.min(1, color.G + amount),
        math.min(1, color.B + amount)
    )
end

function Util.ColorToHex(color)
    return string.format("#%02X%02X%02X",
        math.floor(color.R * 255),
        math.floor(color.G * 255),
        math.floor(color.B * 255)
    )
end

function Util.GetDistance(pos1, pos2)
    if typeof(pos1) == "CFrame" then pos1 = pos1.Position end
    if typeof(pos2) == "CFrame" then pos2 = pos2.Position end
    return (pos1 - pos2).Magnitude
end

function Util.GetItemPosition(item)
    if item:IsA("Model") then
        local primary = item.PrimaryPart
        if primary then return primary.CFrame end
        return item:GetPivot()
    elseif item:IsA("BasePart") then
        return item.CFrame
    end
    return nil
end

function Util.ShuffleTable(t)
    local shuffled = {}
    for i, v in ipairs(t) do shuffled[i] = v end
    for i = #shuffled, 2, -1 do
        local j = math.random(1, i)
        shuffled[i], shuffled[j] = shuffled[j], shuffled[i]
    end
    return shuffled
end

function Util.DeepCopy(orig)
    if type(orig) ~= "table" then return orig end
    local copy = {}
    for k, v in pairs(orig) do
        copy[k] = type(v) == "table" and Util.DeepCopy(v) or v
    end
    return copy
end

function Util.TableContains(t, value)
    for _, v in pairs(t) do
        if v == value then return true end
    end
    return false
end

function Util.CountTable(t)
    local count = 0
    for _ in pairs(t) do count = count + 1 end
    return count
end

function Util.SafeCall(func, ...)
    local success, result = pcall(func, ...)
    if not success then
        warn("[ChomikHub] Error: " .. tostring(result))
        State.Stats.totalErrors = State.Stats.totalErrors + 1
    end
    return success, result
end

function Util.CreateInstance(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        if prop ~= "Parent" then
            instance[prop] = value
        end
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Util.AddCorner(parent, radius)
    if not parent then return nil end
    return Util.CreateInstance("UICorner", {
        CornerRadius = radius or Config.GUI.CornerRadius,
        Parent = parent,
    })
end

function Util.AddStroke(parent, color, thickness, transparency, lineJoin)
    return Util.CreateInstance("UIStroke", {
        Color = color or Config.GUI.AccentColor,
        Thickness = thickness or 1,
        Transparency = transparency or Config.GUI.StrokeTransparency,
        LineJoinMode = lineJoin or Enum.LineJoinMode.Round,
        Parent = parent,
    })
end

function Util.AddPadding(parent, top, bottom, left, right)
