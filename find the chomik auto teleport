local Collector = {}

function Collector.Start()
    if State.isCollecting then Logger.Warning("Сбор уже запущен!"); return end
    State.isCollecting = true
    State.isPaused = false
    Logger.Info("Запуск сбора хомиков...")
    Notify.Success("Сбор запущен", "Режим: " .. Config.CollectMode.ModeIcons[Config.CollectMode.Current] .. " " .. Config.CollectMode.Current)
    task.spawn(function() Collector._collectLoop() end)
end

function Collector.Stop()
    State.isCollecting = false
    State.isPaused = false
    State.currentTarget = nil
    Logger.Info("Сбор остановлен")
    Notify.Warning("Сбор остановлен", "Собрано: " .. State.Stats.sessionCollected .. " | Комбо макс: x" .. State.Combo.MaxCombo)
end

function Collector.Pause()
    State.isPaused = true
    Logger.Info("Сбор приостановлен")
end

function Collector.Resume()
    State.isPaused = false
    Logger.Info("Сбор возобновлён")
end

function Collector.TogglePause()
    if State.isPaused then Collector.Resume() else Collector.Pause() end
end

function Collector._collectLoop()
    while State.isCollecting do
        if not Util.IsPlayerAlive() then
            Logger.Warning("Персонаж мёртв, ожидание...")
            player.CharacterAdded:Wait()
            task.wait(1)
            continue
        end
        if State.isPaused then task.wait(0.1); continue end

        local route = RouteOptimizer.GetOptimizedRoute()
        if #route == 0 then
            Logger.Success("🎉 Все доступные хомики собраны!")
            Notify.Success("🎉 Готово!", "Все хомики собраны!")
            State.isCollecting = false
            break
        end

        for _, itemData in ipairs(route) do
            if not State.isCollecting or not Util.IsPlayerAlive() then break end
            while State.isPaused do task.wait(0.1); if not State.isCollecting then break end end
            if not State.isCollecting then break end

            -- Re-check
            local pDex = player:FindFirstChild(Config.General.DexName)
            if (pDex and pDex:FindFirstChild(itemData.Name)) or State.visitedChomiks[itemData.Name] then
                StatsEngine.RecordSkip()
                continue
            end

            local ok = Collector._teleportToItem(itemData)
            if ok then State.visitedChomiks[itemData.Name] = true end
        end
        task.wait(0.5)
    end
end

function Collector._teleportToItem(itemData)
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end

    local startTime = tick()
    local startPos = root.Position
    State.currentTarget = itemData.Name

    if not itemData.Instance or not itemData.Instance.Parent then
        Logger.Warning("'" .. itemData.Name .. "' не существует")
        return false
    end

    local targetCFrame = Util.GetItemPosition(itemData.Instance)
    if not targetCFrame then
        Logger.Error("Не удалось получить позицию: " .. itemData.Name)
        return false
    end

    ESP.CreateTeleportEffect(root.Position)

    local success = false
    local retryDelay = Config.General.RetryDelay
    for attempt = 1, Config.General.MaxRetries do
        local ok = pcall(function() root.CFrame = targetCFrame end)
        if ok then success = true; break end
        Logger.Warning("Попытка " .. attempt .. " не удалась")
        task.wait(retryDelay)
        retryDelay = retryDelay * Config.General.RetryBackoffMultiplier
    end

    if not success then
        Logger.Error("Не удалось ТП к: " .. itemData.Name)
        StatsEngine.RecordError()
        return false
    end

    ESP.CreateTeleportEffect(targetCFrame.Position)

    local timeTaken = tick() - startTime
    local distance = (targetCFrame.Position - startPos).Magnitude

    StatsEngine.RecordCollection(itemData.Name, distance, timeTaken)
    Logger.Teleport(itemData.Name .. " (" .. Util.Round(distance, 0) .. "m, " .. Util.FormatMs(timeTaken) .. ")")

    if Config.Visuals.ESPEnabled then
        local h = itemData.Instance:FindFirstChild("ChomikESP")
        if h then h.FillColor = Config.Visuals.ESPCollectedColor; h.OutlineColor = Config.Visuals.ESPCollectedColor end
    end

    State.currentTarget = nil
    task.wait(Config.General.Cooldown)
    return true
end

function Collector.TeleportToNearest()
    if not Util.IsPlayerAlive() then Notify.Error("Ошибка", "Персонаж мёртв!"); return end
    local items = RouteOptimizer.GetCollectableItems()
    if #items == 0 then Notify.Info("Информация", "Нет доступных хомиков!"); return end
    items = RouteOptimizer.SortByDistance(items)
    local nearest = items[1]
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = nearest.CFrame
        State.visitedChomiks[nearest.Name] = true
        ESP.CreateTeleportEffect(nearest.CFrame.Position)
        Logger.Teleport("Ближайший: " .. nearest.Name)
        Notify.Success("Телепорт", nearest.Name)
    end
end

