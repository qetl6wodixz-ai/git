            if ind then Util.Tween(ind, {BackgroundTransparency = 1}, 0.2) end
        end
    end

    local page = State.GUIElements.TabPages[tabName]
    local btn = State.GUIElements.TabButtons[tabName]
    if page then page.Visible = true; page.CanvasPosition = Vector2.zero end
    if btn then
        local label = btn:FindFirstChild("Label")
        local ind = btn:FindFirstChild("Indicator")
        Util.Tween(btn, {BackgroundTransparency = 0.05, BackgroundColor3 = Config.GUI.AccentColor}, 0.2)
        if label then Util.Tween(label, {TextColor3 = Config.GUI.TextColor}, 0.2); label.Font = Config.GUI.Font end
        if ind then Util.Tween(ind, {BackgroundTransparency = 0}, 0.2) end
    end
    State.GUIElements.CurrentTab = tabName
