local function updateGUILoop()
    while true do
        task.wait(0.5)
        local s = State.Stats
        local c = State.Combo
        local p = State.Performance
        local rStats = RouteOptimizer.GetStats()

        -- Home status
        if State.GUIElements.HomeStatusLabel then
            if State.isCollecting then
                if State.isPaused then
                    State.GUIElements.HomeStatusLabel.Text = "⏸ Приостановлен"
                    State.GUIElements.HomeStatusLabel.TextColor3 = Config.GUI.WarningColor
                else
                    local target = State.currentTarget and (" → " .. State.currentTarget) or ""
                    State.GUIElements.HomeStatusLabel.Text = "▶ Сбор..." .. target
                    State.GUIElements.HomeStatusLabel.TextColor3 = Config.GUI.SuccessColor
                end
            else
                State.GUIElements.HomeStatusLabel.Text = "⏹ Остановлен"
                State.GUIElements.HomeStatusLabel.TextColor3 = Config.GUI.DimTextColor
            end
        end

        -- Progress
        if State.GUIElements.HomeProgressLabel then
            State.GUIElements.HomeProgressLabel.Text = string.format("Прогресс: %d/%d (%s%%)", rStats.Owned, rStats.TotalInWorld, rStats.CompletionPercent)
        end
        if State.GUIElements.HomeProgressBar then
            local pct = rStats.TotalInWorld > 0 and (rStats.Owned / rStats.TotalInWorld) or 0
            Util.Tween(State.GUIElements.HomeProgressBar, {Size = UDim2.new(pct, 0, 1, 0)}, 0.3)
            if State.GUIElements.HomeProgressText then
                State.GUIElements.HomeProgressText.Text = Util.Round(pct * 100, 1) .. "%"
            end
        end

        -- Quick stats
        if State.GUIElements.QS_Collected then State.GUIElements.QS_Collected.Text = tostring(s.sessionCollected) end
        if State.GUIElements.QS_Time then State.GUIElements.QS_Time.Text = Util.FormatTime(StatsEngine.GetSessionTime()) end
        if State.GUIElements.QS_CPM then State.GUIElements.QS_CPM.Text = tostring(StatsEngine.GetCollectionsPerMinute()) end
        if State.GUIElements.QS_Combo then
            State.GUIElements.QS_Combo.Text = "x" .. c.Count
            State.GUIElements.QS_Combo.TextColor3 = Util.GetComboColor(c.Count)
        end

        -- Title combo
        if State.GUIElements.TitleComboLabel then
            if c.Count > 0 then
                State.GUIElements.TitleComboLabel.Text = "🔥 x" .. c.Count
                State.GUIElements.TitleComboLabel.TextColor3 = Util.GetComboColor(c.Count)
            else
                State.GUIElements.TitleComboLabel.Text = "🔥 —"
                State.GUIElements.TitleComboLabel.TextColor3 = Config.GUI.DimTextColor
            end
        end

        -- Status bar
        if State.GUIElements.SB_Status then
            if State.isCollecting then
                State.GUIElements.SB_Status.Text = State.isPaused and "⏸ Пауза" or "▶ Сбор"
                State.GUIElements.SB_Status.TextColor3 = State.isPaused and Config.GUI.WarningColor or Config.GUI.SuccessColor
            else
                State.GUIElements.SB_Status.Text = "⏹ Стоп"
                State.GUIElements.SB_Status.TextColor3 = Config.GUI.DimTextColor
            end
        end
        if State.GUIElements.SB_Collected then State.GUIElements.SB_Collected.Text = "📦 " .. s.sessionCollected end
        if State.GUIElements.SB_Time then State.GUIElements.SB_Time.Text = "⏱️ " .. Util.FormatTime(StatsEngine.GetSessionTime()) end
        if State.GUIElements.SB_FPS then
            State.GUIElements.SB_FPS.Text = "FPS:" .. p.FPS
            State.GUIElements.SB_FPS.TextColor3 = p.FPS > 45 and Config.GUI.SuccessColor or p.FPS > 25 and Config.GUI.WarningColor or Config.GUI.ErrorColor
        end
        if State.GUIElements.SB_Ping then
            State.GUIElements.SB_Ping.Text = "Ping:" .. p.Ping
            State.GUIElements.SB_Ping.TextColor3 = p.Ping < 100 and Config.GUI.SuccessColor or p.Ping < 200 and Config.GUI.WarningColor or Config.GUI.ErrorColor
        end
        if State.GUIElements.SB_Combo then
            State.GUIElements.SB_Combo.Text = "🔥 x" .. c.Count
            State.GUIElements.SB_Combo.TextColor3 = Util.GetComboColor(c.Count)
        end

        -- Detailed stats
        if State.GUIElements.ST_Collected then State.GUIElements.ST_Collected.Text = tostring(s.sessionCollected) end
        if State.GUIElements.ST_TotalTP then State.GUIElements.ST_TotalTP.Text = tostring(s.totalTeleports) end
        if State.GUIElements.ST_Distance then State.GUIElements.ST_Distance.Text = Util.FormatNumberComma(s.totalDistance) end
        if State.GUIElements.ST_Deaths then State.GUIElements.ST_Deaths.Text = tostring(s.totalDeaths) end
        if State.GUIElements.ST_Skipped then State.GUIElements.ST_Skipped.Text = tostring(s.totalSkipped) end
        if State.GUIElements.ST_Errors then State.GUIElements.ST_Errors.Text = tostring(s.totalErrors) end
        if State.GUIElements.ST_CPM then State.GUIElements.ST_CPM.Text = tostring(StatsEngine.GetCollectionsPerMinute()) end
        if State.GUIElements.ST_Fastest then
            State.GUIElements.ST_Fastest.Text = s.fastestCollection < math.huge and Util.FormatMs(s.fastestCollection) or "—"
        end
        if State.GUIElements.ST_Average then
            State.GUIElements.ST_Average.Text = s.averageCollectionTime > 0 and Util.FormatMs(s.averageCollectionTime) or "—"
        end
        if State.GUIElements.ST_Session then State.GUIElements.ST_Session.Text = Util.FormatTimeDetailed(StatsEngine.GetSessionTime()) end
        if State.GUIElements.ST_MaxCombo then State.GUIElements.ST_MaxCombo.Text = "x" .. c.MaxCombo end
        if State.GUIElements.ST_MaxStreak then State.GUIElements.ST_MaxStreak.Text = tostring(s.maxSuccessStreak) end

        -- Global stats
        if State.GUIElements.GL_Total then State.GUIElements.GL_Total.Text = tostring(rStats.TotalInWorld) end
        if State.GUIElements.GL_Owned then State.GUIElements.GL_Owned.Text = tostring(rStats.Owned) end
        if State.GUIElements.GL_Remaining then State.GUIElements.GL_Remaining.Text = tostring(rStats.Remaining) end
        if State.GUIElements.GL_Percent then State.GUIElements.GL_Percent.Text = rStats.CompletionPercent .. "%" end

        -- Achievement progress
        if State.GUIElements.AchProgressLabel then
            local achS = Achievements.GetStats()
            State.GUIElements.AchProgressLabel.Text = "Разблокировано: " .. achS.Unlocked .. " / " .. achS.Total .. " (" .. achS.Percent .. "%)"
        end
    end
end

