local StatsEngine = {}

function StatsEngine.RecordCollection(itemName, distance, timeTaken)
    local s = State.Stats
    s.totalCollected = s.totalCollected + 1
    s.sessionCollected = s.sessionCollected + 1
    s.totalDistance = s.totalDistance + distance
    s.totalTeleports = s.totalTeleports + 1
    s.successStreak = s.successStreak + 1
    s.errorStreak = 0
    if s.successStreak > s.maxSuccessStreak then s.maxSuccessStreak = s.successStreak end
    if timeTaken < s.fastestCollection then s.fastestCollection = timeTaken end
    if timeTaken > s.slowestCollection then s.slowestCollection = timeTaken end

    table.insert(s.collectionTimes, timeTaken)
    if #s.collectionTimes > 100 then table.remove(s.collectionTimes, 1) end

    local sum = 0
    for _, t in ipairs(s.collectionTimes) do sum = sum + t end
    s.averageCollectionTime = sum / #s.collectionTimes

    table.insert(s.collectHistory, {Name = itemName, Time = tick(), Distance = distance, Duration = timeTaken})
    if #s.collectHistory > 500 then table.remove(s.collectHistory, 1) end

    ComboSystem.Add()
end

function StatsEngine.RecordError()
    State.Stats.totalErrors = State.Stats.totalErrors + 1
    State.Stats.errorStreak = State.Stats.errorStreak + 1
    State.Stats.successStreak = 0
end

function StatsEngine.RecordDeath()
    State.Stats.totalDeaths = State.Stats.totalDeaths + 1
end

function StatsEngine.RecordSkip()
    State.Stats.totalSkipped = State.Stats.totalSkipped + 1
end

function StatsEngine.GetSessionTime()
    return tick() - State.sessionStartTime
end

function StatsEngine.GetCollectionsPerMinute()
    local t = StatsEngine.GetSessionTime()
    if t < 1 then return 0 end
    return Util.Round(State.Stats.sessionCollected / (t / 60), 1)
end

function StatsEngine.ResetSession()
    local s = State.Stats
    s.sessionCollected = 0
    State.sessionStartTime = tick()
    s.collectionTimes = {}
    s.collectHistory = {}
    s.fastestCollection = math.huge
    s.slowestCollection = 0
    s.errorStreak = 0
    s.successStreak = 0
    s.maxSuccessStreak = 0
    State.Combo = {Count = 0, Timer = 0, MaxCombo = 0, Multiplier = 1, History = {}}
    Logger.System("Статистика сессии сброшена")
end

