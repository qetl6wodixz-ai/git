function GUI._makeDraggable(frame)
    local dragging, dragStart, startPos, dragInput = false, nil, nil, nil
    local target = frame:FindFirstChild("TitleBar") or frame

    target.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    target.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Util.Tween(frame, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.12, Enum.EasingStyle.Quad)
        end
    end)
end

function GUI.ToggleVisibility()
    State.isGUIVisible = not State.isGUIVisible
    local mf = State.GUIElements.MainFrame
    if not mf then return end
    if State.isGUIVisible then
        mf.Visible = true
        Util.Tween(mf, {BackgroundTransparency = Config.GUI.Transparency, Size = Config.GUI.WindowSize}, 0.3, Enum.EasingStyle.Back)
    else
        local t = Util.Tween(mf, {BackgroundTransparency = 1, Size = UDim2.new(0, 450, 0, 350)}, 0.2)
        if t then t.Completed:Connect(function() mf.Visible = false end) end
    end
end

function GUI.ToggleMinimize()
    local mf = State.GUIElements.MainFrame
    if not mf then return end
    State.isMinimized = mf.Size.Y.Offset <= 50
    if State.isMinimized then
        Util.Tween(mf, {Size = Config.GUI.WindowSize}, 0.3, Enum.EasingStyle.Back)
    else
        Util.Tween(mf, {Size = UDim2.new(0, Config.GUI.WindowSize.X.Offset, 0, Config.GUI.TitleBarHeight + 2)}, 0.25)
    end
end

