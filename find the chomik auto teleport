    ACHIEVE  = {Color = Color3.fromRGB(255, 215, 0),    Prefix = "🏆", Priority = 3},
}

function Logger.Log(message, logType)
    logType = logType or "INFO"
    local logData = Logger.LogTypes[logType] or Logger.LogTypes.INFO
    local entry = {
        Time = Util.FormatTimestamp(),
        Message = message,
        Type = logType,
        Color = logData.Color,
        Prefix = logData.Prefix,
        Priority = logData.Priority,
        Tick = tick(),
    }
    table.insert(State.Logs, 1, entry)
    while #State.Logs > State.MaxLogs do table.remove(State.Logs) end

    if State.GUIElements.LogScrollFrame then
        Logger.UpdateLogGUI()
    end

    local consoleMsg = string.format("%s %s %s", entry.Time, logData.Prefix, message)
    if logType == "ERROR" then warn(consoleMsg) else print(consoleMsg) end
    return entry
end

function Logger.Info(msg) return Logger.Log(msg, "INFO") end
