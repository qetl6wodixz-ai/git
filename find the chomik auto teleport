}

function Achievements.Define(id, name, description, icon, tier, checkFunc, progressFunc, maxProgress)
    tier = tier or 1
    State.Achievements[id] = {
        Id = id,
        Name = name,
        Description = description,
        Icon = icon,
        Tier = Achievements.Tiers[tier] or Achievements.Tiers[1],
        TierIndex = tier,
        Check = checkFunc,
        GetProgress = progressFunc,
        MaxProgress = maxProgress or 1,
        Unlocked = false,
        UnlockedAt = nil,
        NotifiedAt = nil,
    }
end

function Achievements.Unlock(id)
    local ach = State.Achievements[id]
    if not ach or ach.Unlocked then return end

    ach.Unlocked = true
    ach.UnlockedAt = tick()
    State.AchievementsUnlocked[id] = true

    Logger.Achieve(ach.Tier.Icon .. " " .. ach.Name .. " — " .. ach.Description)

    Notify.Achievement(
        ach.Tier.Icon .. " " .. ach.Name,
        ach.Description .. "\n" .. ach.Tier.Name .. " Achievement",
        6
    )

    if State.GUIElements.AchievementsList then
        Achievements.RefreshGUI()
    end
end

function Achievements.GetProgress(id)
    local ach = State.Achievements[id]
    if not ach then return 0, 1 end
    if ach.Unlocked then return ach.MaxProgress, ach.MaxProgress end
    if ach.GetProgress then
        local ok, current = pcall(ach.GetProgress)
        if ok then return math.min(current, ach.MaxProgress), ach.MaxProgress end
    end
    return 0, ach.MaxProgress
end

function Achievements.GetProgressPercent(id)
    local current, max = Achievements.GetProgress(id)
    return max > 0 and (current / max * 100) or 0
end

function Achievements.CheckAll()
    for id, ach in pairs(State.Achievements) do
        if not ach.Unlocked and ach.Check then
            local ok, result = pcall(ach.Check)
            if ok and result then
                Achievements.Unlock(id)
            end
        end
    end
end

function Achievements.GetStats()
    local total, unlocked, byTier = 0, 0, {}
    for _, tier in ipairs(Achievements.Tiers) do
        byTier[tier.Name] = {Total = 0, Unlocked = 0}
    end
    for _, ach in pairs(State.Achievements) do
        total = total + 1
        byTier[ach.Tier.Name].Total = byTier[ach.Tier.Name].Total + 1
        if ach.Unlocked then
            unlocked = unlocked + 1
            byTier[ach.Tier.Name].Unlocked = byTier[ach.Tier.Name].Unlocked + 1
        end
    end
    return {Total = total, Unlocked = unlocked, Percent = total > 0 and Util.Round(unlocked/total*100, 1) or 0, ByTier = byTier}
end

