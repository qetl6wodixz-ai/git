function Logger.UpdateLogGUI()
    local scrollFrame = State.GUIElements.LogScrollFrame
    if not scrollFrame then return end
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    for i, entry in ipairs(State.Logs) do
        if i > 100 then break end
        local logFrame = Util.CreateInstance("Frame", {
            BackgroundColor3 = i % 2 == 0 and Config.GUI.SecondaryColor or Config.GUI.BackgroundColor,
            BackgroundTransparency = 0.2,
            Size = UDim2.new(1, -6, 0, 24),
            LayoutOrder = i,
            Parent = scrollFrame,
        })
        Util.AddCorner(logFrame, Config.GUI.CornerRadiusSmall)

        -- Colored left accent
        Util.CreateInstance("Frame", {
            BackgroundColor3 = entry.Color,
            Size = UDim2.new(0, 3, 0.7, 0),
            Position = UDim2.new(0, 2, 0.15, 0),
            Parent = logFrame,
        })

        Util.CreateInstance("TextLabel", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 10, 0, 0),
            Size = UDim2.new(0, 60, 1, 0),
