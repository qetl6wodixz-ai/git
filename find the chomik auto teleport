local ComboSystem = {}

function ComboSystem.Add()
    local now = tick()
    local c = State.Combo

    if now - c.Timer <= Config.Combo.Timeout then
        c.Count = c.Count + 1
    else
        c.Count = 1
    end
    c.Timer = now

    if c.Count > c.MaxCombo then c.MaxCombo = c.Count end

    -- Multiplier
    if c.Count >= 100 then c.Multiplier = 5
    elseif c.Count >= 50 then c.Multiplier = 4
    elseif c.Count >= 30 then c.Multiplier = 3
    elseif c.Count >= 20 then c.Multiplier = 2.5
    elseif c.Count >= 10 then c.Multiplier = 2
    elseif c.Count >= 5 then c.Multiplier = 1.5
    else c.Multiplier = 1 end

    -- Milestones
    for _, ms in ipairs(Config.Combo.Milestones) do
        if c.Count == ms then
            Notify.ComboNotify("🔥 COMBO x" .. ms, "Множитель: x" .. c.Multiplier)
            Logger.Combo("Комбо x" .. ms .. "! (x" .. c.Multiplier .. ")")
            break
        end
    end
end

function ComboSystem.Break()
    local c = State.Combo
    if c.Count >= 5 then
        Logger.Info("💔 Комбо сломано на x" .. c.Count)
    end
    c.Count = 0
    c.Multiplier = 1
end

