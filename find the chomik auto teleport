local RouteOptimizer = {}

function RouteOptimizer.GetCollectableItems()
    local worldFolder = workspace:FindFirstChild(Config.General.FolderName)
    if not worldFolder then return {} end
    local playerDex = player:FindFirstChild(Config.General.DexName)
    local items = {}

    for _, item in pairs(worldFolder:GetChildren()) do
        local isOwned = playerDex and playerDex:FindFirstChild(item.Name)
        local isVisited = State.visitedChomiks[item.Name]
        if not isOwned and not isVisited then
            local pos = Util.GetItemPosition(item)
            if pos then
                table.insert(items, {Instance = item, Name = item.Name, Position = pos.Position, CFrame = pos})
            end
        end
    end
    return items
end

function RouteOptimizer.SortByDistance(items, fromPos)
    fromPos = fromPos or Util.GetPlayerPosition()
    table.sort(items, function(a, b)
        return (a.Position - fromPos).Magnitude < (b.Position - fromPos).Magnitude
    end)
    return items
end

function RouteOptimizer.NearestNeighbor(items, startPos)
    startPos = startPos or Util.GetPlayerPosition()
    local route, remaining = {}, {}
    for _, item in ipairs(items) do table.insert(remaining, item) end
    local currentPos = startPos

    while #remaining > 0 do
        local nearestIdx, nearestDist = 1, math.huge
        for i, item in ipairs(remaining) do
            local dist = (item.Position - currentPos).Magnitude
            if dist < nearestDist then nearestDist = dist; nearestIdx = i end
        end
        local nearest = remaining[nearestIdx]
        table.insert(route, nearest)
        currentPos = nearest.Position
        table.remove(remaining, nearestIdx)
    end
    return route
end

function RouteOptimizer.GetOptimizedRoute()
    local items = RouteOptimizer.GetCollectableItems()
    local mode = Config.CollectMode.Current
    if mode == "Nearest" then return RouteOptimizer.NearestNeighbor(items)
    elseif mode == "Random" then return Util.ShuffleTable(items)
    elseif mode == "Reverse" then
        local r = {}
        for i = #items, 1, -1 do table.insert(r, items[i]) end
        return r
    else return items end
end

function RouteOptimizer.GetTotalRouteDistance(route)
    if #route < 1 then return 0 end
    local total, prev = 0, Util.GetPlayerPosition()
    for _, item in ipairs(route) do
        total = total + (item.Position - prev).Magnitude
        prev = item.Position
    end
    return total
end

function RouteOptimizer.GetStats()
    local items = RouteOptimizer.GetCollectableItems()
    local worldFolder = workspace:FindFirstChild(Config.General.FolderName)
    local totalItems = worldFolder and #worldFolder:GetChildren() or 0
    local playerDex = player:FindFirstChild(Config.General.DexName)
    local ownedCount = playerDex and #playerDex:GetChildren() or 0
    return {
        TotalInWorld = totalItems,
        Remaining = #items,
        Owned = ownedCount,
        Visited = Util.CountTable(State.visitedChomiks),
        CompletionPercent = totalItems > 0 and Util.Round((ownedCount / totalItems) * 100, 1) or 0,
    }
end

