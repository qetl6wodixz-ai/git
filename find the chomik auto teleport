local function initialize()
    Logger.System("════════════════════════════════════")
    Logger.System("  🐹 Chomik Collector Hub v4.0 Ultra")
    Logger.System("  Инициализация...")
    Logger.System("════════════════════════════════════")

    Notify.Init()
    Achievements.RegisterAll()
    GUI.Init()
    KeybindManager.Init()

    KeybindManager.Register("ToggleGUI", Config.Keybinds.ToggleGUI, function() GUI.ToggleVisibility() end)
    KeybindManager.Register("StartCollect", Config.Keybinds.StartCollect, function() Collector.Start() end)
    KeybindManager.Register("StopCollect", Config.Keybinds.StopCollect, function() Collector.Stop() end)
    KeybindManager.Register("ToggleESP", Config.Keybinds.ToggleESP, function() ESP.Toggle() end)
    KeybindManager.Register("TeleportNearest", Config.Keybinds.TeleportNearest, function() Collector.TeleportToNearest() end)

    if Config.AntiAFK.Enabled then AntiAFK.Start() end

    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        StatsEngine.RecordDeath()
        Logger.Warning("Персонаж погиб (смерть #" .. State.Stats.totalDeaths .. ")")
        if Config.General.CollectOnSpawn and not State.isCollecting then
            task.wait(1)
            Collector.Start()
        end
    end)

    task.spawn(updateGUILoop)

    Logger.Success("════════════════════════════════════")
    Logger.Success("  ✅ Инициализация завершена!")
    Logger.Success("  📊 " .. Util.CountTable(State.Achievements) .. " достижений")
    Logger.Success("  🎨 " .. Util.CountTable(Themes) .. " тем")
    Logger.Success("  ⌨️ " .. tostring(Config.Keybinds.ToggleGUI):gsub("Enum.KeyCode.", "") .. " — скрыть GUI")
    Logger.Success("════════════════════════════════════")

    Notify.Success("🐹 Chomik Hub v4.0", "Скрипт загружен! " .. Util.CountTable(State.Achievements) .. " достижений ожидают!", 6)

    if Config.General.CollectOnSpawn and player.Character then
        task.wait(1)
        Collector.Start()
    end
end

initialize()
