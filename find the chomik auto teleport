function GUI._refreshCollection(filter, search)
    local ls = State.GUIElements.CollectionListScroll
    if not ls then return end
    for _, c in pairs(ls:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end

    local wf = workspace:FindFirstChild(Config.General.FolderName)
    if not wf then return end
    local pDex = player:FindFirstChild(Config.General.DexName)
    local count, myPos = 0, Util.GetPlayerPosition()

    for i, item in ipairs(wf:GetChildren()) do
        local isOwned = pDex and pDex:FindFirstChild(item.Name)
        local isVisited = State.visitedChomiks[item.Name]

        local show = true
        if filter == "Новые" and (isOwned or isVisited) then show = false end
        if filter == "Собранные" and not isOwned then show = false end
        if filter == "Посещённые" and not isVisited then show = false end
        if search and search ~= "" and not string.find(string.lower(item.Name), string.lower(search)) then show = false end

        if show then
            count = count + 1
            local icon, color
            if isOwned then icon = "✅"; color = Config.GUI.SuccessColor
            elseif isVisited then icon = "👁"; color = Config.GUI.WarningColor
            else icon = "❓"; color = Config.GUI.DimTextColor end

            local itemPos = Util.GetItemPosition(item)
            local dist = itemPos and Util.Round((itemPos.Position - myPos).Magnitude, 0) or "?"

            local row = Util.CreateInstance("Frame", {
                BackgroundColor3 = count % 2 == 0 and Config.GUI.TertiaryColor or Config.GUI.SecondaryColor,
                BackgroundTransparency = 0.25, Size = UDim2.new(1, -4, 0, 28), LayoutOrder = i, Parent = ls,
            })
            Util.AddCorner(row, Config.GUI.CornerRadiusSmall)

            Util.CreateInstance("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0, 5, 0, 0), Size = UDim2.new(0, 18, 1, 0), Text = icon, TextSize = 13, Parent = row})
            Util.CreateInstance("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0, 25, 0, 0), Size = UDim2.new(0.45, -25, 1, 0), Text = item.Name, TextColor3 = color, TextSize = 10, Font = Config.GUI.FontRegular, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, Parent = row})
            Util.CreateInstance("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0.5, 0, 0, 0), Size = UDim2.new(0.18, 0, 1, 0), Text = dist .. "m", TextColor3 = Config.GUI.VeryDimTextColor, TextSize = 9, Font = Config.GUI.FontMono, Parent = row})

            if not isOwned and itemPos then
                local tpBtn = Util.CreateInstance("TextButton", {
                    BackgroundColor3 = Config.GUI.AccentColor, BackgroundTransparency = 0.3,
                    Position = UDim2.new(0.72, 0, 0.1, 0), Size = UDim2.new(0.26, -4, 0.8, 0),
                    Text = "ТП", TextColor3 = Config.GUI.TextColor, TextSize = 10, Font = Config.GUI.Font, Parent = row,
                })
                Util.AddCorner(tpBtn, UDim.new(0, 4))
                tpBtn.MouseButton1Click:Connect(function()
                    local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.CFrame = itemPos; State.visitedChomiks[item.Name] = true
                        ESP.CreateTeleportEffect(itemPos.Position)
                        Logger.Teleport("Ручной ТП: " .. item.Name); Notify.Success("ТП", item.Name)
                    end
                end)
            end
        end
    end
    if State.GUIElements.CollectionCounter then State.GUIElements.CollectionCounter.Text = "Найдено: " .. count end
end

