            VU:ClickButton2(Vector2.new())
            Logger.System("Anti-AFK: предотвращён кик")
        end)
    end)
    if ok then Logger.System("Anti-AFK: активирован")
    else Logger.Warning("Anti-AFK: альтернативный режим") end
end

function AntiAFK.Stop()
    if AntiAFK._connection then AntiAFK._connection:Disconnect(); AntiAFK._connection = nil end
