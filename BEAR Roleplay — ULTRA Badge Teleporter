-- TP ALL (1 секунда между телепортами)
local tpAllActive = false

TPAllBtn.MouseButton1Click:Connect(function()
    if tpAllActive then
        tpAllActive = false
        TPAllBtn.Text = "⚡ TP ВСЕ"
        TweenService:Create(TPAllBtn, TweenInfo.new(0.2), {BackgroundColor3 = C.Red}):Play()
        ProgressFrame.Visible = false
        play("Error")
        notify("⛔ Остановлено", "Авто-телепортация прервана", C.RedGlow, 3)
        setStatus("⛔ Авто-TP остановлен", C.RedGlow)
        return
    end
    
    tpAllActive = true
    TPAllBtn.Text = "⛔ СТОП"
    TweenService:Create(TPAllBtn, TweenInfo.new(0.2), {BackgroundColor3 = C.RedGlow}):Play()
    ProgressFrame.Visible = true
    play("Whoosh")
    
    notify("⚡ Авто-TP", "Телепортация ко всем бейджам (1сек)", C.Yellow, 3)
    
    -- Expand all categories for visibility
    for ci, cf in pairs(catFrames) do
        cf.Open = true
        cf.Holder.Visible = true
        cf.Arrow.Rotation = 90
        cf.Arrow.TextColor3 = Categories[ci].Color
    end
    
    local total = totalBadges
    local current = 0
    
    for _, cat in ipairs(Categories) do
        for _, badge in ipairs(cat.Badges) do
            if not tpAllActive then break end
            current = current + 1
            
            -- Update progress bar
            local pct = current / total
            TweenService:Create(ProgressFill, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Size = UDim2.new(pct, 0, 1, 0)
            }):Play()
            
            -- Update color based on progress
            local progColor = lerpColor(C.Red, C.Green, pct)
            TweenService:Create(ProgressFill, TweenInfo.new(0.3), {BackgroundColor3 = progColor}):Play()
            
            TPAllBtn.Text = string.format("⛔ %d/%d", current, total)
            setStatus(string.format("⚡ [%d/%d] %s %s", current, total, badge.E, badge.N), C.Yellow)
            
            play("Tick")
            teleportTo(badge.P, badge.N)
            
            -- ═══ 1 СЕКУНДА COOLDOWN ═══
            task.wait(1)
        end
        if not tpAllActive then break end
    end
    
    tpAllActive = false
    TPAllBtn.Text = "⚡ TP ВСЕ"
    TweenService:Create(TPAllBtn, TweenInfo.new(0.2), {BackgroundColor3 = C.Red}):Play()
    
    if current >= total then
        play("Complete")
        
        -- Victory progress bar flash
        for i = 1, 3 do
            TweenService:Create(ProgressFill, TweenInfo.new(0.15), {BackgroundColor3 = C.Gold}):Play()
            task.wait(0.2)
            TweenService:Create(ProgressFill, TweenInfo.new(0.15), {BackgroundColor3 = C.Green}):Play()
            task.wait(0.2)
        end
        
        setStatus("🎉 ВСЕ " .. total .. " БЕЙДЖЕЙ ПРОЙДЕНЫ!", C.Green)
        notify("🎉 ЗАВЕРШЕНО!", "Все " .. total .. " точек пройдены за " .. total .. " сек!", C.Gold, 5)
        
        -- Confetti-like screen flash
        local victory = Instance.new("ColorCorrectionEffect")
        victory.Brightness = 0.3
        victory.Contrast = 0.2
        victory.TintColor = Color3.fromRGB(255, 215, 60)
        victory.Parent = Lighting
        
        TweenService:Create(victory, TweenInfo.new(1.5), {
            Brightness = 0, Contrast = 0, TintColor = Color3.new(1,1,1)
        }):Play()
        task.delay(1.6, function() pcall(function() victory:Destroy() end) end)
    end
    
    task.delay(3, function()
        ProgressFrame.Visible = false
    end)
end)

