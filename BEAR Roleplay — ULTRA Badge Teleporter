local teleporting = false

local function teleportTo(pos, name)
    local root = getRoot()
    if not root then
        play("Error")
        setStatus("❌ Персонаж не найден!", C.RedGlow)
        notify("❌ Ошибка", "Персонаж не найден", C.RedGlow, 3)
        return false
    end
    
    if teleporting then return false end
    teleporting = true
    
    play("Teleport")
    setStatus("⚡ " .. (name or "Телепортация..."), C.Yellow)
    
    -- === VISUAL EFFECTS ===
    local char = getChar()
    
    -- 1. Screen flash
    local flash = Instance.new("ColorCorrectionEffect")
    flash.Name = "BearTPColor"
    flash.Brightness = 0
    flash.Contrast = 0
    flash.Saturation = 0
    flash.TintColor = Color3.fromRGB(255, 120, 120)
    flash.Parent = Lighting
    
    TweenService:Create(flash, TweenInfo.new(0.15), {
        Brightness = 0.6, Contrast = 0.4, Saturation = -0.5
    }):Play()
    
    -- 2. Blur effect
    local blur = Instance.new("BlurEffect")
    blur.Name = "BearTPBlur"
    blur.Size = 0
    blur.Parent = Lighting
    
    TweenService:Create(blur, TweenInfo.new(0.15), {Size = 20}):Play()
    
    -- 3. Bloom
    local bloom = Instance.new("BloomEffect")
    bloom.Name = "BearTPBloom"
    bloom.Intensity = 0
    bloom.Size = 24
    bloom.Threshold = 1
    bloom.Parent = Lighting
    
    TweenService:Create(bloom, TweenInfo.new(0.15), {Intensity = 1.5, Threshold = 0.5}):Play()
    
    task.wait(0.15)
    
    -- 4. TELEPORT
    root.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
    task.wait(0.05)
    root.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
    
    task.wait(0.1)
    
    -- 5. Reverse effects
    play("TeleportEnd")
    
    TweenService:Create(flash, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Brightness = 0, Contrast = 0, Saturation = 0
    }):Play()
    
    TweenService:Create(blur, TweenInfo.new(0.4), {Size = 0}):Play()
    TweenService:Create(bloom, TweenInfo.new(0.4), {Intensity = 0, Threshold = 1}):Play()
    
    -- 6. Particle burst at destination
    pcall(function()
        if root then
            for i = 1, 12 do
                local part = Instance.new("Part")
                part.Size = Vector3.new(0.3, 0.3, 0.3)
                part.Shape = Enum.PartType.Ball
                part.Material = Enum.Material.Neon
                part.BrickColor = BrickColor.new("Really red")
                part.Anchored = false
                part.CanCollide = false
                part.CFrame = root.CFrame
                part.Transparency = 0.3
                part.Parent = workspace
                
                local angle = (i / 12) * math.pi * 2
                local vel = Instance.new("BodyVelocity", part)
                vel.Velocity = Vector3.new(math.cos(angle) * 20, math.random(10, 25), math.sin(angle) * 20)
                vel.MaxForce = Vector3.new(999999, 999999, 999999)
                
                game:GetService("Debris"):AddItem(part, 1.5)
                
                task.spawn(function()
                    for t = 0, 1, 0.05 do
                        if part and part.Parent then
                            part.Transparency = 0.3 + t * 0.7
                            part.Size = Vector3.new(0.3 - t * 0.25, 0.3 - t * 0.25, 0.3 - t * 0.25)
                        end
                        task.wait(0.05)
                    end
                end)
            end
        end
    end)
    
    -- 7. Ring effect
    pcall(function()
        if root then
            local ring = Instance.new("Part")
            ring.Size = Vector3.new(1, 0.1, 1)
            ring.Shape = Enum.PartType.Cylinder
            ring.Material = Enum.Material.Neon
            ring.BrickColor = BrickColor.new("Really red")
            ring.Anchored = true
            ring.CanCollide = false
            ring.CFrame = root.CFrame * CFrame.Angles(0, 0, math.rad(90))
            ring.Transparency = 0.5
            ring.Parent = workspace
            
            game:GetService("Debris"):AddItem(ring, 1)
            
            task.spawn(function()
                for t = 0, 1, 0.03 do
                    if ring and ring.Parent then
                        local s = 1 + t * 15
                        ring.Size = Vector3.new(0.1, s, s)
                        ring.Transparency = 0.5 + t * 0.5
                    end
                    task.wait(0.02)
                end
            end)
        end
    end)
    
    -- Cleanup effects
    task.delay(0.7, function()
        pcall(function() flash:Destroy() end)
        pcall(function() blur:Destroy() end)
        pcall(function() bloom:Destroy() end)
    end)
    
    task.wait(0.2)
    play("SuccessHigh")
    setStatus("✅ " .. (name or "Готово!"), C.Green)
    
    task.delay(2.5, function()
        if StatusText then setStatus("✅ Готов к телепортации", C.Green) end
    end)
    
    teleporting = false
    return true
end

