SBox:GetPropertyChangedSignal("Text"):Connect(function()
    local q = SBox.Text:lower()
    local count = 0
    
    if q == "" then
        for _, d in ipairs(allCards) do d.Card.Visible = true end
        BadgeCounter.Text = totalBadges .. " 📌"
        return
    end
    
    play("Tick")
    
    for _, d in ipairs(allCards) do
        local match = d.Name:find(q, 1, true) or d.Desc:find(q, 1, true)
        d.Card.Visible = (match ~= nil)
        if match then
            count = count + 1
            local cf = catFrames[d.CatIdx]
            if not cf.Open then
                cf.Open = true
                cf.Holder.Visible = true
                cf.Arrow.Rotation = 90
                cf.Arrow.TextColor3 = Categories[d.CatIdx].Color
