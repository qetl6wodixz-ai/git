local function getAnimType(name)
    local n = string.lower(name)
    if n:find("dance") or n:find("shuffle") or n:find("floss") or n:find("groove")
       or n:find("boogie") or n:find("robot") or n:find("zombie") or n:find("gangnam")
       or n:find("hype") or n:find("orange justice") or n:find("smooth") then
        return "dance", "💃", Color3.fromRGB(255, 60, 150)
    elseif n:find("emote") or n:find("wave") or n:find("laugh") or n:find("point")
       or n:find("cheer") or n:find("salute") or n:find("shrug") or n:find("clap")
       or n:find("dab") or n:find("hello") or n:find("twirl") or n:find("backflip")
       or n:find("stadium") or n:find("superhero") or n:find("tilt") then
        return "emote", "😊", Color3.fromRGB(255, 180, 40)
    elseif n:find("idle") or n:find("walk") or n:find("run") or n:find("jump")
       or n:find("climb") or n:find("fall") or n:find("swim") or n:find("sit")
       or n:find("fly") or n:find("land") then
        return "movement", "🏃", Color3.fromRGB(60, 200, 120)
    elseif n:find("attack") or n:find("swing") or n:find("slash") or n:find("punch")
       or n:find("kick") or n:find("shoot") or n:find("combat") or n:find("tool") then
        return "combat", "⚔", Color3.fromRGB(255, 90, 70)
    else
        return "other", "🎭", Color3.fromRGB(140, 130, 200)
    end
end

local function getCategory(animId)
    if isRobloxDefault(tostring(animId)) then
        return "roblox"
    else
        return "author"
    end
end

