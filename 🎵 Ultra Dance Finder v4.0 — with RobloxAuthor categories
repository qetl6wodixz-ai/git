-- ПОЛНОЕ СКАНИРОВАНИЕ
-- ═══════════════════════════════════════════════

local function performScan(deepScan)
    if isScanning then showNotification("Сканирование уже идёт!", "warning"); return end

    clearResults()
    seenIds = {}
    scanComplete = false
    isScanning = true
    totalScanned = 0
    scanStartTime = tick()

    playSound(deepScan and "deepScan" or "scanStart")
    ProgressOuter.Visible = true
    ProgressInner.Size = UDim2.new(0, 0, 1, 0)

    StatusIcon.Text = "🔍"
    StatusLabel.Text = "Сканирование..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 40)

    showNotification(
        deepScan and "⚡ Deep Scan: скрипты + GC + nil" or "🔍 Быстрое сканирование...",
        deepScan and "warning" or "info", 2
    )

    task.spawn(function()
        local places = {
            {game:GetService("Workspace"), "Workspace"},
            {ReplicatedStorage, "ReplicatedStorage"},
            {StarterPlayer, "StarterPlayer"},
            {Lighting, "Lighting"},
            {SoundService, "SoundService"},
        }

        local opt = {
            {"ReplicatedFirst", function() return game:GetService("ReplicatedFirst") end},
            {"StarterGui",      function() return game:GetService("StarterGui") end},
            {"StarterPack",     function() return game:GetService("StarterPack") end},
            {"PlayerGui",       function() return LocalPlayer:FindFirstChild("PlayerGui") end},
            {"Backpack",        function() return LocalPlayer:FindFirstChild("Backpack") end},
            {"Character",       function() return LocalPlayer.Character end},
        }

        for _, p in ipairs(opt) do
            pcall(function()
                local inst = p[2]()
                if inst then table.insert(places, {inst, p[1]}) end
            end)
        end

        for _, player in pairs(Players:GetPlayers()) do
            pcall(function()
                if player.Character and player ~= LocalPlayer then
                    table.insert(places, {player.Character, "👤 " .. player.Name})
                end
            end)
        end

        -- Deep Scan extras
        if deepScan then
            pcall(function()
                if getnilinstances then
                    for _, inst in pairs(getnilinstances()) do
                        if inst:IsA("Animation") then
                            local id = extractId(inst.AnimationId)
                            if id and not isDuplicate(id) then
                                table.insert(foundAnimations, {
                                    name = inst.Name .. " [nil]", id = id,
                                    path = "NilInstance › " .. inst.Name,
                                    source = "NilInstance", category = getCategory(id)
                                })
                            end
                        end
                    end
                end
            end)

            pcall(function()
                if getgc then
                    for _, v in pairs(getgc(true)) do
                        if typeof(v) == "Instance" and v:IsA("Animation") then
                            local id = extractId(v.AnimationId)
                            if id and not isDuplicate(id) then
                                table.insert(foundAnimations, {
                                    name = v.Name .. " [gc]", id = id,
                                    path = "GC › " .. v.Name,
                                    source = "GarbageCollector", category = getCategory(id)
                                })
                            end
                        end
                        if typeof(v) == "table" then
                            pcall(function()
                                for key, val in pairs(v) do
                                    if typeof(val) == "string" then
                                        local id = val:match("rbxassetid://(%d+)")
                                        if id and tonumber(id) > 1000 and tostring(key):lower():find("anim") then
                                            if not isDuplicate(id) then
                                                table.insert(foundAnimations, {
                                                    name = tostring(key), id = id,
                                                    path = "GC_Table", source = "GC_Table",
                                                    category = getCategory(id)
                                                })
                                            end
                                        end
                                    end
                                    if typeof(val) == "number" and val > 10000 and tostring(key):lower():find("anim") then
                                        local idStr = tostring(math.floor(val))
                                        if not isDuplicate(idStr) then
                                            table.insert(foundAnimations, {
                                                name = tostring(key), id = idStr,
                                                path = "GC_Table", source = "GC_Table",
                                                category = getCategory(idStr)
                                            })
                                        end
                                    end
                                end
                            end)
                        end
                    end
                end
            end)
        end

        local total = #places
        for idx, place in ipairs(places) do
            if place[1] then
                StatusLabel.Text = place[2] .. "..."
                TweenService:Create(ProgressInner, TweenInfo.new(0.3), {
                    Size = UDim2.new(idx / total, 0, 1, 0)
                }):Play()
                pcall(function() scanInstance(place[1], deepScan) end)
                RobloxCount.Text = " 🏠 " .. robloxCountNum .. " "
                AuthorCount.Text = " 🎨 " .. authorCountNum .. " "
                TotalCount.Text  = " 📊 " .. #foundAnimations .. " "
                TimeLabel.Text   = " ⏱ " .. string.format("%.1f", tick() - scanStartTime) .. "s "
                task.wait()
            end
        end

        TweenService:Create(ProgressInner, TweenInfo.new(0.3), {Size = UDim2.new(1, 0, 1, 0)}):Play()
        StatusLabel.Text = "Создание списка..."

        -- Сортировка: сначала авторские, потом Roblox
        table.sort(foundAnimations, function(a, b)
            if a.category ~= b.category then
                return a.category == "author"
            end
            return a.name < b.name
        end)

        task.wait(0.15)

        for i, data in ipairs(foundAnimations) do
            createAnimCard(data, i)
            if i % 12 == 0 then task.wait() end
        end

        scanComplete = true
        isScanning = false
        local elapsed = string.format("%.1f", tick() - scanStartTime)
        TimeLabel.Text = " ⏱ " .. elapsed .. "s "

        task.wait(0.5)
        ProgressOuter.Visible = false

        if #foundAnimations == 0 then
            playSound("error")
            StatusIcon.Text = "😕"
            StatusLabel.Text = "Не найдено"
            StatusLabel.TextColor3 = Color3.fromRGB(240, 170, 40)
            showNotification("Не найдено анимаций. Потанцуй в игре и нажми Scan!", "warning", 4)

            local hint = Instance.new("Frame")
            hint.Size = UDim2.new(1, -6, 0, 100)
            hint.BackgroundColor3 = Color3.fromRGB(25, 22, 45)
            hint.BorderSizePixel = 0
            hint.ZIndex = 4
            hint.Parent = ResultsFrame
            Instance.new("UICorner", hint).CornerRadius = UDim.new(0, 10)

            local ht = Instance.new("TextLabel")
            ht.Size = UDim2.new(1, -16, 1, 0)
            ht.Position = UDim2.new(0, 8, 0, 0)
            ht.BackgroundTransparency = 1
            ht.Text = "💡 Советы:\n\n🏠 Roblox анимации — встроенные в Roblox (idle, walk, run, стандартные эмоции)\n🎨 Авторские — загруженные автором игры (уникальные танцы, эмоции)\n\n• Потанцуй/используй эмоцию → Scan\n• Попроси других игроков → Scan\n• ⚡ Deep Scan ищет в скриптах и памяти"
            ht.TextColor3 = Color3.fromRGB(160, 150, 210)
            ht.TextSize = 9
            ht.Font = Enum.Font.Gotham
            ht.TextWrapped = true
            ht.TextXAlignment = Enum.TextXAlignment.Left
            ht.TextYAlignment = Enum.TextYAlignment.Center
            ht.ZIndex = 5
            ht.Parent = hint
        else
            playSound("scanComplete")
            StatusIcon.Text = "✅"
            StatusLabel.Text = robloxCountNum .. " Roblox + " .. authorCountNum .. " Авторских"
            StatusLabel.TextColor3 = Color3.fromRGB(50, 210, 90)
            showNotification(
                "Найдено: 🏠 " .. robloxCountNum .. " Roblox + 🎨 " .. authorCountNum .. " Авторских за " .. elapsed .. "s",
                "success", 4
            )
        end
    end)
end

