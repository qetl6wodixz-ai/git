-- ФУНКЦИИ АНИМАЦИИ
-- ═══════════════════════════════════════════════

local function stopAnimation()
    if currentTrack then
        pcall(function() currentTrack:Stop() end)
        pcall(function() currentTrack:Destroy() end)
        currentTrack = nil
    end
    if currentAnim then
        pcall(function() currentAnim:Destroy() end)
        currentAnim = nil
    end
    StatusIcon.Text = "⏹"
    StatusLabel.Text = "Остановлено"
    StatusLabel.TextColor3 = Color3.fromRGB(190, 60, 60)

    -- Убираем подсветку с играющей карточки
    if activePlayingCard then
        pcall(function()
            local glow = activePlayingCard:FindFirstChild("PlayingGlow")
            if glow then glow:Destroy() end
        end)
        activePlayingCard = nil
    end
end

local function playAnimation(animId, cardFrame)
    Character = LocalPlayer.Character
    if not Character then playSound("error"); showNotification("Персонаж не найден!", "error"); return end
    Humanoid = Character:FindFirstChildOfClass("Humanoid")
    if not Humanoid then playSound("error"); showNotification("Humanoid не найден!", "error"); return end

    stopAnimation()

    local id = tostring(animId)
    if not id:find("rbxassetid://") then id = "rbxassetid://" .. id end

    local success, err = pcall(function()
        currentAnim = Instance.new("Animation")
        currentAnim.AnimationId = id
        local animator = Humanoid:FindFirstChildOfClass("Animator")
        if not animator then animator = Instance.new("Animator"); animator.Parent = Humanoid end
        currentTrack = animator:LoadAnimation(currentAnim)
        currentTrack.Priority = Enum.AnimationPriority.Action4
        currentTrack.Looped = true
        currentTrack:Play()
        currentTrack:AdjustSpeed(animSpeed)
    end)

    if success then
        playSound("playAnim")
        StatusIcon.Text = "▶"
        StatusLabel.Text = "Играет: " .. tostring(animId)
        StatusLabel.TextColor3 = Color3.fromRGB(50, 210, 90)
        showNotification("▶ Анимация: " .. tostring(animId), "success", 2)

        -- Подсветка играющей карточки
        if cardFrame then
            activePlayingCard = cardFrame
            local glow = Instance.new("UIStroke")
            glow.Name = "PlayingGlow"
            glow.Color = Color3.fromRGB(50, 255, 100)
            glow.Thickness = 2
            glow.Parent = cardFrame
        end
    else
        playSound("error")
        StatusIcon.Text = "❌"
        StatusLabel.Text = "Ошибка"
        StatusLabel.TextColor3 = Color3.fromRGB(240, 60, 60)
        showNotification("Ошибка: " .. tostring(err), "error")
    end
end

