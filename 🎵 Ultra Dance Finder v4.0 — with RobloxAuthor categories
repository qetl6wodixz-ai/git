-- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ СКАНИРОВАНИЯ
-- ═══════════════════════════════════════════════

local function clearResults()
    for _, c in pairs(ResultsFrame:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    allButtons = {}
    foundAnimations = {}
    robloxCountNum = 0
    authorCountNum = 0
end

local function extractId(s)
    if not s or s == "" then return nil end
    local id = s:match("(%d+)")
    if id and tonumber(id) > 0 then return id end
    return nil
end

local function getShortPath(inst)
    local parts = {}
    local cur = inst
    local d = 0
    while cur and cur ~= game and d < 6 do
        table.insert(parts, 1, cur.Name)
        cur = cur.Parent
        d = d + 1
    end
    return table.concat(parts, " › ")
end

local function isDuplicate(id)
    if seenIds[id] then return true end
    seenIds[id] = true
    return false
end

-- ═══════════════════════════════════════════════
-- СКАНИРОВАНИЕ
-- ═══════════════════════════════════════════════

local function scanInstance(root, deepScan)
    local count = 0

    local function rec(obj, depth)
        if depth > (deepScan and 35 or 20) then return end
        local ok, children = pcall(function() return obj:GetChildren() end)
        if not ok then return end

        for _, child in pairs(children) do
            totalScanned = totalScanned + 1

            if child:IsA("Animation") then
                local id = extractId(child.AnimationId)
                if id and not isDuplicate(id) then
                    count = count + 1
                    playSound("scanPing")
                    local cat = getCategory(id)
                    if cat == "roblox" then playSound("robloxFound") else playSound("authorFound") end
                    table.insert(foundAnimations, {
                        name = child.Name ~= "Animation" and child.Name or (child.Parent and child.Parent.Name .. "_Anim" or "Animation"),
                        id = id, path = getShortPath(child), source = "Animation", category = cat
                    })
                end
            end

            if child:IsA("Animator") then
                pcall(function()
                    for _, track in pairs(child:GetPlayingAnimationTracks()) do
                        if track.Animation then
                            local id = extractId(track.Animation.AnimationId)
                            if id and not isDuplicate(id) then
                                count = count + 1
                                table.insert(foundAnimations, {
                                    name = track.Animation.Name ~= "Animation" and track.Animation.Name or track.Name,
                                    id = id, path = getShortPath(child) .. " › Playing",
                                    source = "ActiveTrack", category = getCategory(id)
                                })
                            end
                        end
                    end
                end)
            end

            if child:IsA("AnimationController") then
                pcall(function()
                    for _, track in pairs(child:GetPlayingAnimationTracks()) do
                        if track.Animation then
                            local id = extractId(track.Animation.AnimationId)
                            if id and not isDuplicate(id) then
                                count = count + 1
                                table.insert(foundAnimations, {
                                    name = track.Animation.Name, id = id,
                                    path = getShortPath(child) .. " › AnimCtrl",
                                    source = "AnimController", category = getCategory(id)
                                })
                            end
                        end
                    end
                end)
            end

            if child:IsA("Humanoid") then
                pcall(function()
                    local animator = child:FindFirstChildOfClass("Animator")
                    if animator then
                        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
                            if track.Animation then
                                local id = extractId(track.Animation.AnimationId)
                                if id and not isDuplicate(id) then
                                    count = count + 1
                                    table.insert(foundAnimations, {
                                        name = track.Animation.Name ~= "Animation" and track.Animation.Name or (child.Parent and child.Parent.Name or "Anim"),
                                        id = id, path = getShortPath(child) .. " › Humanoid",
                                        source = "HumanoidTrack", category = getCategory(id)
                                    })
                                end
                            end
                        end
                    end
                end)
            end

            if child:IsA("StringValue") then
                local id = extractId(child.Value)
                if id and not isDuplicate(id) then
                    local n = child.Name:lower()
                    if n:find("anim") or n:find("dance") or n:find("emote") or n:find("motion") then
                        count = count + 1
                        table.insert(foundAnimations, {
                            name = child.Name, id = id, path = getShortPath(child),
                            source = "StringValue", category = getCategory(id)
                        })
                    end
                end
            end

            if child:IsA("IntValue") or child:IsA("NumberValue") then
                local val = tostring(math.floor(child.Value))
                if tonumber(val) and tonumber(val) > 1000 then
                    local n = child.Name:lower()
                    if n:find("anim") or n:find("dance") or n:find("emote") or n:find("id") then
                        if not isDuplicate(val) then
                            count = count + 1
                            table.insert(foundAnimations, {
                                name = child.Name, id = val, path = getShortPath(child),
                                source = "Value", category = getCategory(val)
                            })
                        end
                    end
                end
            end

            if deepScan and (child:IsA("ModuleScript") or child:IsA("LocalScript")) then
                pcall(function()
                    if decompile then
                        local code = decompile(child)
                        if code then
                            for id in code:gmatch("rbxassetid://(%d+)") do
                                if tonumber(id) > 1000 and not isDuplicate(id) then
                                    count = count + 1
                                    table.insert(foundAnimations, {
                                        name = child.Name .. " [code]", id = id,
                                        path = getShortPath(child),
                                        source = child.ClassName, category = getCategory(id)
                                    })
                                end
                            end
                            for id in code:gmatch("[Aa]nim[ation]*[Ii]?[Dd]?%s*[:=]%s*[\"']?(%d+)") do
                                if tonumber(id) > 1000 and not isDuplicate(id) then
                                    count = count + 1
                                    table.insert(foundAnimations, {
                                        name = child.Name .. " [parsed]", id = id,
                                        path = getShortPath(child),
                                        source = "ScriptParsed", category = getCategory(id)
                                    })
                                end
                            end
                        end
                    end
                end)
            end

            pcall(function() rec(child, depth + 1) end)
            if totalScanned % 100 == 0 then task.wait() end
        end
    end

    rec(root, 0)
    return count
end

