function TargetLockSystem.ToggleLock()
	if TargetLockSystem.LockedTarget then
		-- Unlock
		TargetLockSystem.LockedTarget = nil
		if TargetLockSystem.LockIndicator then
			TargetLockSystem.LockIndicator:Destroy()
			TargetLockSystem.LockIndicator = nil
		end
		NotificationSystem.Show("Target Unlocked", 2)
	else
		-- Lock to nearest player
		local target, dist = Utility.GetNearestPlayer(torso.Position, 100, chara)
		if target then
			TargetLockSystem.LockedTarget = target
			
			-- Create lock indicator
			local billboard = Instance.new("BillboardGui")
			billboard.Name = "LockIndicator"
			billboard.Size = UDim2.new(0, 50, 0, 50)
			billboard.StudsOffset = Vector3.new(0, 3, 0)
			billboard.AlwaysOnTop = true
			
			local icon = Instance.new("TextLabel", billboard)
			icon.Size = UDim2.new(1, 0, 1, 0)
			icon.BackgroundTransparency = 1
			icon.Text = "🎯"
			icon.TextSize = 30
			icon.Font = Enum.Font.Fantasy
			
			billboard.Parent = target:FindFirstChild("Head") or target:FindFirstChild("Torso")
			billboard.Adornee = target:FindFirstChild("Head") or target:FindFirstChild("Torso")
			
			TargetLockSystem.LockIndicator = billboard
			
			-- Get player name
			local targetName = "Unknown"
			for _, plr in pairs(Players:GetPlayers()) do
				if plr.Character == target then
					targetName = plr.Name
					break
				end
			end
			NotificationSystem.Show("Locked onto: " .. targetName, 2, Color3.new(1, 0.5, 0))
		end
	end
end

