local AnimationSystem = {}
AnimationSystem.Animations = {}

function AnimationSystem.Load(name, id)
	local anim = Instance.new("Animation")
	anim.AnimationId = id
	anim.Name = name
	local track = humanoid:LoadAnimation(anim)
	AnimationSystem.Animations[name] = track
	return track
end

function AnimationSystem.Play(name, speed, fadeTime)
	if AnimationSystem.Animations[name] then
		AnimationSystem.Animations[name]:Play(fadeTime or 0.1)
		if speed then
			AnimationSystem.Animations[name]:AdjustSpeed(speed)
		end
	end
end

function AnimationSystem.Stop(name, fadeTime)
	if AnimationSystem.Animations[name] then
		AnimationSystem.Animations[name]:Stop(fadeTime or 0.1)
	end
end

function AnimationSystem.StopAll(fadeTime)
	for _, track in pairs(AnimationSystem.Animations) do
		track:Stop(fadeTime or 0.1)
	end
end

