function ParticleSystem.SpiralEffect(centerPart, duration, color)
	coroutine.wrap(function()
		local elapsed = 0
		local angle = 0
		while elapsed < duration do
			local dt = wait(0.03)
			elapsed = elapsed + dt
			angle = angle + 10
			
			local radius = 3 + math.sin(elapsed * 2) * 2
			local x = math.cos(math.rad(angle)) * radius
			local z = math.sin(math.rad(angle)) * radius
			local y = math.sin(elapsed * 5) * 2
			
			local particle = Instance.new("Part", Workspace)
			particle.Size = Vector3.new(0.3, 0.3, 0.3)
			particle.Shape = Enum.PartType.Ball
			particle.Material = Enum.Material.Neon
			particle.BrickColor = BrickColor.new("Really red")
			particle.Anchored = true
			particle.CanCollide = false
			particle.Position = centerPart.Position + Vector3.new(x, y, z)
			
			coroutine.wrap(function()
				for i = 1, 10 do
					wait(0.05)
					particle.Transparency = particle.Transparency + 0.1
					particle.Size = particle.Size - Vector3.new(0.03, 0.03, 0.03)
				end
				particle:Destroy()
			end)()
		end
	end)()
end

