		comboDisplay.TextTransparency = 0
		
		coroutine.wrap(function()
			for i = 1, 10 do
				wait(0.05)
				comboDisplay.TextSize = 48 + i * 2
			end
			wait(0.5)
			for i = 1, 10 do
				wait(0.05)
				comboDisplay.TextTransparency = comboDisplay.TextTransparency + 0.1
			end
			comboDisplay.Visible = false
		end)()
	end
end

function GUISystem.UpdateCooldowns()
	if not GUISystem.GUI then return end
	local cdFrame = GUISystem.GUI:FindFirstChild("CooldownFrame")
	if not cdFrame then return end
	
	local abilityKeys = {"Teleport", "Grab", "Dash", "AOE", "Beam", "Shield", "Meteor", "Pillar"}
	local abilityNames = {"[Z] Teleport", "[X] Grab", "[C] Dash", "[V] AOE Blast", "[B] Dark Beam", "[N] Shield", "[M] Meteors", "[G] Pillars"}
	
	for idx, key in ipairs(abilityKeys) do
		local label = cdFrame:FindFirstChild("Ability" .. idx)
		if label then
			local remaining = StateManager:GetCooldownRemaining(key)
			if remaining > 0 then
				label.Text = abilityNames[idx] .. " - " .. string.format("%.1f", remaining) .. "s"
				label.TextColor3 = Color3.new(1, 0.2, 0.2)
			else
				label.Text = abilityNames[idx] .. " - Ready"
				label.TextColor3 = Color3.new(0, 1, 0)
			end
		end
	end
end

function GUISystem.AddKillFeedEntry(playerName)
	if not GUISystem.GUI then return end
	local killFeed = GUISystem.GUI:FindFirstChild("KillFeed")
	if not killFeed then return end
	
	-- Shift existing entries down
	local children = killFeed:GetChildren()
	for _, child in pairs(children) do
		if child:IsA("TextLabel") then
			child.Position = child.Position + UDim2.new(0, 0, 0, 25)
			if child.Position.Y.Offset > 125 then
				child:Destroy()
			end
		end
	end
	
	local entry = Instance.new("TextLabel", killFeed)
	entry.Size = UDim2.new(1, 0, 0, 22)
	entry.Position = UDim2.new(0, 0, 0, 0)
	entry.BackgroundColor3 = Color3.new(0.2, 0, 0)
	entry.BackgroundTransparency = 0.5
	entry.Text = "☠ " .. playerName .. " has been consumed"
	entry.TextColor3 = Color3.new(1, 0.3, 0.3)
	entry.Font = Enum.Font.Code
	entry.TextSize = 12
	entry.TextXAlignment = Enum.TextXAlignment.Left
	
	local corner = Instance.new("UICorner", entry)
	corner.CornerRadius = UDim.new(0, 4)
	
	coroutine.wrap(function()
		wait(5)
		if entry and entry.Parent then
			for i = 1, 10 do
				wait(0.05)
				entry.TextTransparency = entry.TextTransparency + 0.1
				entry.BackgroundTransparency = entry.BackgroundTransparency + 0.05
			end
			entry:Destroy()
		end
	end)()
end

