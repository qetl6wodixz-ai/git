			end
		end
		
		-- Debug info
		if CONFIG.DebugMode then
			subtitleLabel.Text = string.format(
				"Phase:%d | Kills:%d | Combo:%d | Abilities:%d",
				StateManager.CurrentPhase,
				StateManager.KillCount,
				StateManager.ComboCount,
				StateManager.AbilitiesUsed
			)
		end
	end
end