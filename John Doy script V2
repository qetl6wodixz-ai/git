function Grab(mouse)
	if StateManager:IsOnCooldown("Grab") or StateManager.IsGrabbing then return end
	StateManager.IsGrabbing = true
	
	local hit = mouse.Target
	if hit ~= nil then
		if hit.Parent:FindFirstChild("Humanoid")~=nil then
			local torsy = nil
			if hit.Parent:FindFirstChild("Torso")~=nil then
				torsy = hit.Parent.Torso
			elseif hit.Parent:FindFirstChild("UpperTorso")~=nil then
				torsy = hit.Parent.UpperTorso
			end
