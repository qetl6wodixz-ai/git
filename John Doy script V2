			local targetPos = torso.Position + Vector3.new(
				math.random(-30, 30),
				0,
				math.random(-30, 30)
			)
			
			local spawnPos = targetPos + Vector3.new(math.random(-10, 10), 80, math.random(-10, 10))
			
			-- Create meteor
			local meteor = Instance.new("Part", Workspace)
			meteor.Shape = Enum.PartType.Ball
			meteor.Size = Vector3.new(4, 4, 4)
			meteor.Material = Enum.Material.Neon
			meteor.BrickColor = BrickColor.new("Really red")
			meteor.Anchored = true
			meteor.CanCollide = false
			meteor.Position = spawnPos
			
			-- Meteor trail
			local meteorTrail, att0, att1 = ParticleSystem.TrailEffect(meteor, CONFIG.PrimaryColor, 1)
			BurningEff(meteor)
			
			-- Meteor glow
			local meteorLight = Instance.new("PointLight", meteor)
			meteorLight.Color = Color3.new(1, 0, 0)
			meteorLight.Range = 20
			meteorLight.Brightness = 5
			
			-- Warning indicator on ground
			local warning = Instance.new("Part", Workspace)
			warning.Shape = Enum.PartType.Cylinder
			warning.Size = Vector3.new(0.2, CONFIG.MeteorRadius * 2, CONFIG.MeteorRadius * 2)
			warning.Material = Enum.Material.Neon
			warning.BrickColor = BrickColor.new("Really red")
			warning.Anchored = true
			warning.CanCollide = false
			warning.CFrame = CFrame.new(targetPos.X, targetPos.Y - 2, targetPos.Z) * CFrame.Angles(0, 0, math.rad(90))
			warning.Transparency = 0.5
			
			-- Animate warning
			coroutine.wrap(function()
				for j = 1, 10 do
					wait(0.1)
					warning.Transparency = 0.3 + math.sin(j) * 0.2
				end
			end)()
			
			-- Animate meteor falling
			local fallDuration = 1
			local startTime = tick()
			
			while tick() - startTime < fallDuration do
				local t = (tick() - startTime) / fallDuration
				local currentPos = spawnPos:Lerp(targetPos, t)
				meteor.Position = currentPos
				wait(0.02)
			end
			
			-- Impact!
			meteor.Position = targetPos
			ParticleSystem.ExplosionEffect(targetPos, CONFIG.PrimaryColor, 12)
			ParticleSystem.GroundCrack(targetPos, CONFIG.MeteorRadius * 0.6, CONFIG.PrimaryColor)
			ParticleSystem.ShockwaveEffect(targetPos, CONFIG.MeteorRadius, CONFIG.PrimaryColor)
			
			SoundSystem.PlayAtPosition(CONFIG.Sounds.Thunder, targetPos, {Volume = 5, PlaybackSpeed = 0.8})
			Utility.Shake(0.8, 0.3)
			
			-- Damage
			local hitPlayers = Utility.GetAllPlayersInRange(targetPos, CONFIG.MeteorRadius, chara)
			for _, data in pairs(hitPlayers) do
				if data.Character:FindFirstChild("Humanoid") and not data.Character:FindFirstChild("HasBeenHit") then
					local targetTorso = data.Character:FindFirstChild("Torso") or data.Character:FindFirstChild("UpperTorso")
					DamageSystem.ApplyDamage(data.Character.Humanoid, CONFIG.MeteorDamage, targetTorso and targetTorso.Position)
					
					-- Knockback
					if targetTorso then
						local dir = (targetTorso.Position - targetPos).Unit
						local bv = Instance.new("BodyVelocity", targetTorso)
						bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
						bv.Velocity = dir * 60 + Vector3.new(0, 30, 0)
						Debris:AddItem(bv, 0.5)
					end
					
					if data.Character.Humanoid.Health <= 0 then
						KillMortal(data.Character)
					end
				end
			end
			
			-- Cleanup
			warning:Destroy()
			meteor:Destroy()
		end)()
	end
	
	StateManager.AbilitiesUsed = StateManager.AbilitiesUsed + 1
end

