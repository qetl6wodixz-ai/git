function SoundSystem.Create(name, parent, id, properties)
	local sound = Instance.new("Sound", parent or torso)
	sound.Name = name
	sound.SoundId = id
	if properties then
		for key, value in pairs(properties) do
			sound[key] = value
		end
	end
	SoundSystem.Sounds[name] = sound
	return sound
end

function SoundSystem.Play(name)
	if SoundSystem.Sounds[name] then
		SoundSystem.Sounds[name]:Play()
	end
end

function SoundSystem.Stop(name)
	if SoundSystem.Sounds[name] then
		SoundSystem.Sounds[name]:Stop()
	end
end

function SoundSystem.PlayAtPosition(id, position, properties)
	local part = Instance.new("Part", Workspace)
	part.Transparency = 1
	part.Anchored = true
	part.CanCollide = false
	part.Position = position
	part.Size = Vector3.new(1, 1, 1)
	
	local sound = Instance.new("Sound", part)
	sound.SoundId = id
	if properties then
		for key, value in pairs(properties) do
			sound[key] = value
		end
	end
	sound:Play()
	
	sound.Ended:Connect(function()
		part:Destroy()
	end)
	
	return sound
end

