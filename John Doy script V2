			p.Shape = Enum.PartType.Ball
			p.Material = Enum.Material.Neon
			p.BrickColor = BrickColor.new("Really red")
			p.Anchored = true
			p.CanCollide = false
			p.Transparency = 0.3
			table.insert(particles, {part = p, angle = (i / 30) * math.pi * 2, height = math.random(-5, 5)})
		end
		
		while elapsed < duration do
			local dt = wait(0.03)
			elapsed = elapsed + dt
			
			for _, data in pairs(particles) do
				data.angle = data.angle + 5 * dt
				local r = radius * (1 - elapsed / duration)
				local x = math.cos(data.angle) * r
				local z = math.sin(data.angle) * r
				data.part.Position = position + Vector3.new(x, data.height + math.sin(elapsed * 3) * 2, z)
				data.part.Transparency = elapsed / duration
			end
		end
		
		for _, data in pairs(particles) do
			data.part:Destroy()
		end
	end)()
end

