			wait(1)
			if chara and humanoid.Health > 0 and StateManager.CurrentPhase >= 2 then
				local nearbyPlayers = Utility.GetAllPlayersInRange(torso.Position, 5, chara)
				for _, data in pairs(nearbyPlayers) do
