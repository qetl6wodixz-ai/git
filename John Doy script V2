	shieldWeld.Part0 = shield
	shieldWeld.Part1 = torso
	
	-- Shield glow
	local shieldLight = Instance.new("PointLight", shield)
	shieldLight.Color = Color3.new(1, 0, 0)
	shieldLight.Range = 20
	shieldLight.Brightness = 3
	
	-- Shield particles
	local shieldParticles = ParticleSystem.DarkAura(shield)
	
	-- Pulsing effect
	coroutine.wrap(function()
