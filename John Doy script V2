		while elapsed < CONFIG.ShieldDuration and shield and shield.Parent do
			wait(0.05)
			elapsed = elapsed + 0.05
			shield.Transparency = 0.5 + math.sin(elapsed * 5) * 0.2
			
			-- Repel nearby players
			local nearbyPlayers = Utility.GetAllPlayersInRange(torso.Position, 8, chara)
			for _, data in pairs(nearbyPlayers) do
				local targetTorso = data.Character:FindFirstChild("Torso") or data.Character:FindFirstChild("UpperTorso")
				if targetTorso then
					local dir = (targetTorso.Position - torso.Position).Unit
					local bv = Instance.new("BodyVelocity", targetTorso)
					bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
					bv.Velocity = dir * 50 + Vector3.new(0, 20, 0)
					Debris:AddItem(bv, 0.2)
					
					DamageSystem.ApplyDamage(data.Character.Humanoid, 5, targetTorso.Position)
				end
			end
		end
		
		-- Shield expire effect
		if shield and shield.Parent then
			ParticleSystem.ExplosionEffect(torso.Position, CONFIG.PrimaryColor, 8)
			shield:Destroy()
		end
		
		StateManager.IsShielded = false
	end)()
	
	StateManager.AbilitiesUsed = StateManager.AbilitiesUsed + 1
