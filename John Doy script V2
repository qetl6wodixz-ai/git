local EnvironmentSystem = {}

function EnvironmentSystem.CorruptTerrain(position, radius)
	-- Create corrupted ground patches
	for i = 1, 8 do
		local angle = (i / 8) * math.pi * 2
		local dist = math.random(3, radius)
		local patchPos = position + Vector3.new(math.cos(angle) * dist, -3, math.sin(angle) * dist)
		
		local patch = Instance.new("Part", Workspace)
		patch.Size = Vector3.new(math.random(3, 8), 0.3, math.random(3, 8))
		patch.Material = Enum.Material.Granite
		patch.BrickColor = BrickColor.new("Really black")
		patch.Anchored = true
		patch.CanCollide = false
		patch.CFrame = CFrame.new(patchPos)
		patch.Name = "CorruptPatch"
		
		BurningEff(patch)
		Debris:AddItem(patch, 5)
	end
end

function EnvironmentSystem.LightningStrike(position)
	-- Create lightning bolt visual
	local boltParts = {}
	local startPos = position + Vector3.new(0, 100, 0)
	local endPos = position
	local segments = 15
	
	local currentPos = startPos
	for i = 1, segments do
		local t = i / segments
		local targetPos = startPos:Lerp(endPos, t)
		
		-- Add randomness to path
		if i < segments then
			targetPos = targetPos + Vector3.new(
				math.random(-5, 5),
				0,
				math.random(-5, 5)
			)
		end
		
		local boltPart = Instance.new("Part", Workspace)
		local direction = (targetPos - currentPos)
		boltPart.Size = Vector3.new(0.5, 0.5, direction.Magnitude)
		boltPart.Material = Enum.Material.Neon
		boltPart.BrickColor = BrickColor.new("Really red")
		boltPart.Anchored = true
		boltPart.CanCollide = false
		boltPart.CFrame = CFrame.new(currentPos, targetPos) * CFrame.new(0, 0, -direction.Magnitude / 2)
		
		table.insert(boltParts, boltPart)
		currentPos = targetPos
	end
	
	-- Flash
	local flash = Instance.new("Part", Workspace)
	flash.Shape = Enum.PartType.Ball
	flash.Size = Vector3.new(10, 10, 10)
	flash.Material = Enum.Material.Neon
	flash.BrickColor = BrickColor.new("Institutional white")
	flash.Anchored = true
	flash.CanCollide = false
	flash.Position = endPos
	flash.Transparency = 0.5
	
	local light = Instance.new("PointLight", flash)
	light.Color = Color3.new(1, 0, 0)
	light.Range = 60
	light.Brightness = 10
	
	ParticleSystem.ExplosionEffect(endPos, CONFIG.PrimaryColor, 8)
	
	-- Fade out
	coroutine.wrap(function()
		wait(0.1)
		for i = 1, 5 do
			wait(0.05)
			for _, part in pairs(boltParts) do
				part.Transparency = part.Transparency + 0.2
			end
			flash.Transparency = flash.Transparency + 0.1
		end
		for _, part in pairs(boltParts) do
			part:Destroy()
		end
		flash:Destroy()
	end)()
end

function EnvironmentSystem.DarkStorm(duration)
	coroutine.wrap(function()
		local elapsed = 0
		while elapsed < duration do
			wait(math.random(1, 3))
			elapsed = elapsed + 2
			
			-- Random lightning strike near the player
			local strikePos = torso.Position + Vector3.new(
				math.random(-50, 50),
				0,
				math.random(-50, 50)
			)
			EnvironmentSystem.LightningStrike(strikePos)
			thundersnd:Play()
			
			-- Damage nearby players at strike location
			local hitPlayers = Utility.GetAllPlayersInRange(strikePos, 8, chara)
			for _, data in pairs(hitPlayers) do
				if data.Character:FindFirstChild("Humanoid") then
					DamageSystem.ApplyDamage(data.Character.Humanoid, 20, strikePos)
				end
			end
		end
	end)()
end

