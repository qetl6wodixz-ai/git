function GUISystem.UpdateStats()
	if not GUISystem.GUI then return end
	local stats = GUISystem.GUI:FindFirstChild("StatsFrame")
	if stats then
		stats.Kills.Text = "Kills: " .. StateManager.KillCount
		stats.Damage.Text = "Damage: " .. Utility.FormatNumber(StateManager.TotalDamageDealt)
		stats.Combo.Text = "Combo: " .. StateManager.ComboCount .. "x"
		stats.Time.Text = "Time: " .. math.floor(StateManager.TimeAlive) .. "s"
		stats.PhaseNum.Text = "Phase: " .. StateManager.CurrentPhase
	end
end

function GUISystem.UpdatePhase(phase)
	if not GUISystem.GUI then return end
	local phaseFrame = GUISystem.GUI:FindFirstChild("PhaseFrame")
	if phaseFrame then
		local phaseNames = {
			[1] = "PHASE 1 - DORMANT",
			[2] = "PHASE 2 - AWAKENED",
			[3] = "PHASE 3 - CORRUPTED"
		}
		phaseFrame.PhaseText.Text = phaseNames[phase] or "UNKNOWN PHASE"
		
		-- Flash effect
		coroutine.wrap(function()
			for i = 1, 5 do
				phaseFrame.PhaseText.TextTransparency = 1
				wait(0.1)
				phaseFrame.PhaseText.TextTransparency = 0
				wait(0.1)
			end
		end)()
	end
end

function GUISystem.ShowCombo(count)
	if not GUISystem.GUI then return end
	local comboDisplay = GUISystem.GUI:FindFirstChild("ComboDisplay")
	if comboDisplay then
		comboDisplay.Text = count .. "x COMBO!"
		comboDisplay.Visible = true
