		chainLink.Size = Vector3.new(0.5, 0.5, 0.5)
		chainLink.Shape = Enum.PartType.Ball
		chainLink.Material = Enum.Material.Neon
		chainLink.BrickColor = BrickColor.new("Really red")
		chainLink.Anchored = true
		chainLink.CanCollide = false
		chainLink.Position = pos
		
		table.insert(chainParts, chainLink)
	end
	
	-- Pull target
	local bodpos = Instance.new("BodyPosition", targetTorso)
	bodpos.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
	bodpos.Position = torso.Position + torso.CFrame.LookVector * 5
	
	-- Animate chain
	coroutine.wrap(function()
		for frame = 1, 30 do
			wait(0.05)
			local currentEndPos = targetTorso.Position
			for i, link in ipairs(chainParts) do
				local t = i / #chainParts
				link.Position = startPos:Lerp(currentEndPos, t)
				link.Transparency = frame / 30
			end
		end
		
		-- Cleanup
		for _, link in pairs(chainParts) do
			link:Destroy()
		end
		bodpos:Destroy()
	end)()
	
	-- Damage on arrival
	wait(1)
	if target:FindFirstChild("Humanoid") and target.Humanoid.Health > 0 then
		DamageSystem.ApplyDamage(target.Humanoid, 30, targetTorso.Position)
		hitsnd:Play()
	end
	
	StateManager.AbilitiesUsed = StateManager.AbilitiesUsed + 1
end

