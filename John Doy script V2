function PassiveSystem.DarkPresence()
	-- Slow down nearby players
	coroutine.wrap(function()
		while true do
			wait(0.5)
			if chara and humanoid.Health > 0 and StateManager.CurrentPhase >= 3 then
				local nearbyPlayers = Utility.GetAllPlayersInRange(torso.Position, 20, chara)
				for _, data in pairs(nearbyPlayers) do
					if data.Character:FindFirstChild("Humanoid") then
						data.Character.Humanoid.WalkSpeed = 8 -- Slow them down
						
						-- Visual effect on affected players
						local targetTorso = data.Character:FindFirstChild("Torso") or data.Character:FindFirstChild("UpperTorso")
						if targetTorso then
							local chains = Instance.new("ParticleEmitter", targetTorso)
							chains.Size = NumberSequence.new(0.5)
							chains.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 1)})
							chains.Lifetime = NumberRange.new(0.5)
							chains.Speed = NumberRange.new(0.5)
							chains.Rate = 20
							chains.VelocitySpread = 360
							chains.Texture = "rbxassetid://347504241"
							chains.Color = ColorSequence.new(Color3.new(0.3, 0, 0))
							Debris:AddItem(chains, 1)
						end
					end
				end
				
				-- Reset speed of players far away
				for _, plr in pairs(Players:GetPlayers()) do
					if plr.Character and plr.Character ~= chara and plr.Character:FindFirstChild("Humanoid") then
						local targetTorso = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
						if targetTorso then
							local dist = (targetTorso.Position - torso.Position).Magnitude
							if dist > 20 then
								plr.Character.Humanoid.WalkSpeed = 16
							end
						end
					end
				end
			end
		end
	end)()
end

