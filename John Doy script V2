function SoulSteal(pos)
	local soulst = coroutine.wrap(function()
		local soul = Instance.new("Part",chara)
		soul.Size = Vector3.new(0,0,0)
		soul.CanCollide = false
		soul.Anchored = false
		soul.Position = pos
		soul.CFrame = CFrame.new(pos.X,pos.Y,pos.Z)
		soul.Transparency = 1
		local ptc = Instance.new("ParticleEmitter",soul)
		ptc.Texture = "http://www.roblox.com/asset/?id=413366101"
		ptc.Size = NumberSequence.new(.5)
		ptc.LockedToPart = true
		ptc.Speed = NumberRange.new(0)
		ptc.Lifetime = NumberRange.new(9999)
		
		-- Additional soul visual
		local soulGlow = Instance.new("PointLight", soul)
		soulGlow.Color = Color3.new(1, 0, 0)
		soulGlow.Range = 5
		soulGlow.Brightness = 2
		
		local bodpos = Instance.new("BodyPosition",soul)
		bodpos.Position = pos
		wait(2)
		soul.Touched:connect(function(hit)
			if hit.Parent == chara then
				-- Soul absorbed effect
				ParticleSystem.ExplosionEffect(soul.Position, Color3.new(1, 0, 0), 3)
				soul:Destroy()
			end
		end)
		while soul and soul.Parent do
			wait(.1)
			bodpos.Position = torso.Position
		end
	end)
	soulst()
end

