local PhaseSystem = {}

function PhaseSystem.TransitionToPhase(phase)
	if StateManager.CurrentPhase >= phase then return end
	StateManager.CurrentPhase = phase
	
	powerupsnd:Play()
	GUISystem.UpdatePhase(phase)
	
	-- Dramatic effect
	Utility.Shake(2, 3)
	ParticleSystem.VortexEffect(torso.Position, 3, 15)
	ParticleSystem.ExplosionEffect(torso.Position, CONFIG.PrimaryColor, 20)
	ParticleSystem.ShockwaveEffect(torso.Position, 50, CONFIG.PrimaryColor)
	
	-- Knockback all nearby players
	local nearbyPlayers = Utility.GetAllPlayersInRange(torso.Position, 40, chara)
	for _, data in pairs(nearbyPlayers) do
		local targetTorso = data.Character:FindFirstChild("Torso") or data.Character:FindFirstChild("UpperTorso")
		if targetTorso then
			local dir = (targetTorso.Position - torso.Position).Unit
			local bv = Instance.new("BodyVelocity", targetTorso)
			bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
			bv.Velocity = dir * 100 + Vector3.new(0, 50, 0)
			Debris:AddItem(bv, 0.5)
		end
	end
	
	if phase == 2 then
		PhaseSystem.Phase2Effects()
	elseif phase == 3 then
		PhaseSystem.Phase3Effects()
	end
end

