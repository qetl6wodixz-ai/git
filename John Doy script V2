--                    DARK BEAM ABILITY                          --
--=============================================================--
function DarkBeam()
	if StateManager:IsOnCooldown("Beam") then return end
	StateManager:SetCooldown("Beam", CONFIG.BeamCooldown)
	
	beamsnd:Play()
	chargesnd:Play()
	
	-- Charge effect
	local chargeEffect = ParticleSystem.ChargeEffect(rightArm)
	wait(0.5)
	
	-- Fire beam
	local beamStart = rightArm.Position
	local beamDirection = rootPart.CFrame.LookVector
	local beamEnd = beamStart + beamDirection * CONFIG.BeamLength
	
	-- Create beam visual
	local beamPart = Instance.new("Part", Workspace)
	beamPart.Size = Vector3.new(CONFIG.BeamWidth, CONFIG.BeamWidth, CONFIG.BeamLength)
	beamPart.Material = Enum.Material.Neon
	beamPart.BrickColor = BrickColor.new("Really red")
	beamPart.Anchored = true
	beamPart.CanCollide = false
	beamPart.CFrame = CFrame.new(beamStart, beamEnd) * CFrame.new(0, 0, -CONFIG.BeamLength / 2)
	beamPart.Transparency = 0.3
	
	-- Beam glow
	local beamLight = Instance.new("PointLight", beamPart)
	beamLight.Color = Color3.new(1, 0, 0)
	beamLight.Range = 30
	beamLight.Brightness = 5
	
	-- Inner beam
	local innerBeam = Instance.new("Part", Workspace)
	innerBeam.Size = Vector3.new(CONFIG.BeamWidth * 0.5, CONFIG.BeamWidth * 0.5, CONFIG.BeamLength)
	innerBeam.Material = Enum.Material.Neon
	innerBeam.BrickColor = BrickColor.new("Institutional white")
	innerBeam.Anchored = true
	innerBeam.CanCollide = false
	innerBeam.CFrame = beamPart.CFrame
	innerBeam.Transparency = 0.1
	
	ParticleSystem.BurningEff(beamPart)
	
	Utility.Shake(0.5, CONFIG.BeamDuration)
	
	-- Damage along beam path
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	raycastParams.FilterDescendantsInstances = {chara}
	
	-- Check for players along beam
	local hitPlayers = {}
	for _, plr in pairs(Players:GetPlayers()) do
		if plr.Character and plr.Character ~= chara and plr.Character:FindFirstChild("Humanoid") then
			local targetTorso = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
			if targetTorso then
				-- Check if player is near the beam line
				local toTarget = targetTorso.Position - beamStart
				local projected = toTarget:Dot(beamDirection)
				if projected > 0 and projected < CONFIG.BeamLength then
					local closestPoint = beamStart + beamDirection * projected
					local distance = (targetTorso.Position - closestPoint).Magnitude
					if distance < CONFIG.BeamWidth * 3 then
						table.insert(hitPlayers, plr.Character)
					end
				end
			end
		end
	end
	
	for _, hitChar in pairs(hitPlayers) do
		if hitChar:FindFirstChild("Humanoid") and not hitChar:FindFirstChild("HasBeenHit") then
			local targetTorso = hitChar:FindFirstChild("Torso") or hitChar:FindFirstChild("UpperTorso")
			DamageSystem.ApplyDamage(hitChar.Humanoid, CONFIG.BeamDamage, targetTorso and targetTorso.Position)
			BurningEff(targetTorso)
			
			if hitChar.Humanoid.Health <= 0 then
				KillMortal(hitChar)
			end
		end
	end
	
	-- Fade beam
	coroutine.wrap(function()
		wait(CONFIG.BeamDuration)
		for i = 1, 10 do
			wait(0.05)
			beamPart.Transparency = beamPart.Transparency + 0.07
			innerBeam.Transparency = innerBeam.Transparency + 0.09
		end
		beamPart:Destroy()
		innerBeam:Destroy()
	end)()
	
	-- Clean up charge effect
	if chargeEffect then
		chargeEffect:Destroy()
	end
	
	StateManager.AbilitiesUsed = StateManager.AbilitiesUsed + 1
end

