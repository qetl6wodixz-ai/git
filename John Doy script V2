local StateManager = {
	CurrentPhase = 1,
	IsAttacking = false,
	IsDashing = false,
	IsShielded = false,
	IsGrabbing = false,
	IsCharging = false,
	ComboCount = 0,
	LastAttackTime = 0,
	LastDashTime = 0,
	LastTeleportTime = 0,
	LastAOETime = 0,
	LastBeamTime = 0,
	LastShieldTime = 0,
	LastMeteorTime = 0,
	LastPillarTime = 0,
	KillCount = 0,
	TotalDamageDealt = 0,
	AbilitiesUsed = 0,
	TimeAlive = 0,
	Cooldowns = {},
}

function StateManager:SetCooldown(ability, duration)
	self.Cooldowns[ability] = tick() + duration
end

function StateManager:IsOnCooldown(ability)
	if self.Cooldowns[ability] then
		return tick() < self.Cooldowns[ability]
	end
	return false
end

function StateManager:GetCooldownRemaining(ability)
	if self.Cooldowns[ability] then
		local remaining = self.Cooldowns[ability] - tick()
		return remaining > 0 and remaining or 0
	end
	return 0
end

function StateManager:CanAttack()
	return not self.IsAttacking and not self.IsDashing and not self.IsGrabbing and not self.IsCharging
end

function StateManager:IncrementCombo()
	if tick() - self.LastAttackTime <= CONFIG.ComboWindow then
		self.ComboCount = math.min(self.ComboCount + 1, CONFIG.MaxCombo)
	else
		self.ComboCount = 1
	end
	self.LastAttackTime = tick()
end

function StateManager:ResetCombo()
	self.ComboCount = 0
end

function StateManager:GetComboDamageMultiplier()
	return 1 + (self.ComboCount * 0.15)
end

function StateManager:GetPhaseDamageMultiplier()
	if self.CurrentPhase == 1 then return 1
	elseif self.CurrentPhase == 2 then return 1.5
	elseif self.CurrentPhase == 3 then return 2.0
	end
	return 1
end

