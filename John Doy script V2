local DamageSystem = {}

function DamageSystem.CalculateDamage(baseDamage, isCritical)
	local damage = baseDamage or CONFIG.BaseDamage
	
	-- Apply combo multiplier
	damage = damage * StateManager:GetComboDamageMultiplier()
	
	-- Apply phase multiplier
	damage = damage * StateManager:GetPhaseDamageMultiplier()
	
	-- Apply critical
	if isCritical then
		damage = damage * CONFIG.CriticalMultiplier
	end
	
	return damage
end

function DamageSystem.RollCritical()
	return math.random(1, 100) <= CONFIG.CriticalChance
end

function DamageSystem.ApplyDamage(humanoid, damage, position)
	if humanoid and humanoid.Health > 0 then
		local isCritical = DamageSystem.RollCritical()
		local finalDamage = DamageSystem.CalculateDamage(damage, isCritical)
		
		humanoid:TakeDamage(finalDamage)
		StateManager.TotalDamageDealt = StateManager.TotalDamageDealt + finalDamage
		
		if position then
			GUISystem.ShowDamageNumber(position, finalDamage, isCritical)
		end
		
		return finalDamage, isCritical
	end
	return 0, false
end

function DamageSystem.ApplyDOT(humanoid, damagePerTick, ticks, interval, effectFunc)
	coroutine.wrap(function()
		for i = 1, ticks do
			if humanoid and humanoid.Health > 0 then
				local torso = humanoid.Parent:FindFirstChild("Torso") or humanoid.Parent:FindFirstChild("UpperTorso")
				DamageSystem.ApplyDamage(humanoid, damagePerTick, torso and torso.Position)
				if effectFunc and torso then
					effectFunc(torso)
				end
				wait(interval or 0.5)
			else
				break
			end
		end
	end)()
end

