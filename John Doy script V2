local Utility = {}

function Utility.CreateInstance(className, parent, name, properties)
	local instance = Instance.new(className)
	if properties then
		for key, value in pairs(properties) do
			instance[key] = value
		end
	end
	if name then
		instance.Name = name
	end
	instance.Parent = parent
	return instance
end

function Utility.Lerp(a, b, t)
	return a + (b - a) * t
end

function Utility.LerpColor(c1, c2, t)
	return Color3.new(
		Utility.Lerp(c1.R, c2.R, t),
		Utility.Lerp(c1.G, c2.G, t),
		Utility.Lerp(c1.B, c2.B, t)
	)
end

function Utility.RandomVector3(min, max)
	return Vector3.new(
		math.random(min, max),
		math.random(min, max),
		math.random(min, max)
	)
end

function Utility.GetDistance(pos1, pos2)
	return (pos1 - pos2).Magnitude
end

function Utility.GetNearestPlayer(position, range, ignoreChar)
	local nearest = nil
	local nearestDist = range or math.huge
	for _, plr in pairs(Players:GetPlayers()) do
		if plr.Character and plr.Character ~= ignoreChar and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
			local torso = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
			if torso then
				local dist = Utility.GetDistance(position, torso.Position)
				if dist < nearestDist then
					nearest = plr.Character
					nearestDist = dist
				end
			end
		end
	end
	return nearest, nearestDist
end

function Utility.GetAllPlayersInRange(position, range, ignoreChar)
	local players = {}
	for _, plr in pairs(Players:GetPlayers()) do
		if plr.Character and plr.Character ~= ignoreChar and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
			local torso = plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
			if torso then
				local dist = Utility.GetDistance(position, torso.Position)
				if dist <= range then
					table.insert(players, {Character = plr.Character, Distance = dist})
				end
			end
		end
	end
	return players
end

function Utility.Shake(intensity, duration)
	local shakeCoroutine = coroutine.wrap(function()
		local cam = game.Workspace.CurrentCamera
		local elapsed = 0
		while elapsed < duration do
			local dt = RunService.RenderStepped:Wait()
			elapsed = elapsed + dt
			local shakeOffset = CFrame.new(
				math.random(-intensity * 100, intensity * 100) / 100,
				math.random(-intensity * 100, intensity * 100) / 100,
				math.random(-intensity * 100, intensity * 100) / 100
			)
			cam.CFrame = cam.CFrame * shakeOffset
		end
	end)
	shakeCoroutine()
end

function Utility.CreateTween(instance, properties, duration, easingStyle, easingDirection)
	local tweenInfo = TweenInfo.new(
		duration or 1,
		easingStyle or Enum.EasingStyle.Quad,
		easingDirection or Enum.EasingDirection.Out
	)
	local tween = TweenService:Create(instance, tweenInfo, properties)
	return tween
end

function Utility.SafeDestroy(instance, delay)
	if instance then
		if delay and delay > 0 then
			Debris:AddItem(instance, delay)
		else
			instance:Destroy()
		end
	end
end

function Utility.CloneSound(soundTemplate, parent)
	local clone = soundTemplate:Clone()
	clone.Parent = parent or soundTemplate.Parent
	return clone
end

function Utility.FormatNumber(num)
	if num >= 1000000 then
		return string.format("%.1fM", num / 1000000)
	elseif num >= 1000 then
		return string.format("%.1fK", num / 1000)
	else
		return tostring(math.floor(num))
	end
end

function Utility.AngleBetween(cf1, cf2)
	local dot = cf1.LookVector:Dot((cf2.Position - cf1.Position).Unit)
	return math.acos(math.clamp(dot, -1, 1))
end

function Utility.BezierPoint(t, p0, p1, p2)
	local u = 1 - t
	return u * u * p0 + 2 * u * t * p1 + t * t * p2
end

function Utility.CreateBezierCurve(startPos, endPos, height, segments)
	local midPoint = (startPos + endPos) / 2 + Vector3.new(0, height, 0)
	local points = {}
	for i = 0, segments do
		local t = i / segments
		local point = Utility.BezierPoint(t, startPos, midPoint, endPos)
		table.insert(points, point)
	end
	return points
end

