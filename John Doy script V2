			bodpos.Position = torsy.Position
			wait(1)
			burnsnd:Play()
			hit.Parent.Humanoid.MaxHealth = 100
			bodpos.Position = bodpos.Position + Vector3.new(0,4,0)
			for i = 1, CONFIG.GrabTicks do
