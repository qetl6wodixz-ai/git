function CreateDarkClone()
	if StateManager:IsOnCooldown("Clone") then return end
	StateManager:SetCooldown("Clone", 12)
	
	-- Create a fake clone
	local clone = Instance.new("Model", Workspace)
	clone.Name = "DarkClone"
	
	-- Clone body parts
	local cloneTorso = Instance.new("Part", clone)
	cloneTorso.Name = "Torso"
	cloneTorso.Size = Vector3.new(2, 2, 1)
	cloneTorso.Material = Enum.Material.Granite
	cloneTorso.BrickColor = BrickColor.new("Really black")
	cloneTorso.Anchored = false
	cloneTorso.CanCollide = true
	cloneTorso.CFrame = torso.CFrame * CFrame.new(math.random(-5, 5), 0, math.random(-5, 5))
	
	local cloneHead = Instance.new("Part", clone)
	cloneHead.Name = "Head"
	cloneHead.Size = Vector3.new(2, 1, 1)
	cloneHead.Material = Enum.Material.Granite
	cloneHead.BrickColor = BrickColor.new("Really black")
	cloneHead.Anchored = false
	cloneHead.CanCollide = false
	cloneHead.CFrame = cloneTorso.CFrame * CFrame.new(0, 1.5, 0)
	
	local headMesh = Instance.new("SpecialMesh", cloneHead)
	headMesh.Scale = Vector3.new(1.25, 1.25, 1.25)
	
	local headWeld = Instance.new("Weld", cloneHead)
	headWeld.Part0 = cloneHead
	headWeld.Part1 = cloneTorso
	headWeld.C0 = CFrame.new(0, -1.5, 0)
	
	-- Clone limbs
	local limbNames = {"Left Arm", "Right Arm", "Left Leg", "Right Leg"}
	local limbOffsets = {
		CFrame.new(-1.5, 0, 0),
		CFrame.new(1.5, 0, 0),
		CFrame.new(-0.5, -2, 0),
		CFrame.new(0.5, -2, 0)
	}
	
	for idx, name in ipairs(limbNames) do
		local limb = Instance.new("Part", clone)
		limb.Name = name
		limb.Size = Vector3.new(1, 2, 1)
		limb.Material = Enum.Material.Granite
		limb.BrickColor = BrickColor.new("Really black")
		limb.Anchored = false
		limb.CanCollide = false
		
		local limbWeld = Instance.new("Weld", limb)
		limbWeld.Part0 = limb
		limbWeld.Part1 = cloneTorso
		limbWeld.C0 = limbOffsets[idx]:Inverse()
	end
	
	-- Clone humanoid
	local cloneHumanoid = Instance.new("Humanoid", clone)
	cloneHumanoid.MaxHealth = 1
	cloneHumanoid.Health = 1
	
	-- Effects
	ScatterEff(cloneTorso)
	ParticleSystem.DarkAura(cloneTorso)
	
	-- Eye effect
	local cloneEye = Instance.new("Part", clone)
	cloneEye.Size = Vector3.new(0.3, 0.3, 0.1)
	cloneEye.Material = Enum.Material.Neon
	cloneEye.BrickColor = BrickColor.new("Really red")
	cloneEye.Anchored = false
	cloneEye.CanCollide = false
	local eyeWeld = Instance.new("Weld", cloneEye)
	eyeWeld.Part0 = cloneEye
	eyeWeld.Part1 = cloneHead
	eyeWeld.C0 = CFrame.new(-0.3, 0.1, -0.5)
	
	-- Clone AI (simple chase and explode)
	coroutine.wrap(function()
		local cloneLife = 0
		local maxLife = 8
		
		while cloneLife < maxLife and cloneTorso and cloneTorso.Parent do
			wait(0.1)
			cloneLife = cloneLife + 0.1
			
			-- Find nearest player to chase (not the owner)
			local target, dist = Utility.GetNearestPlayer(cloneTorso.Position, 50, chara)
			if target then
				local targetTorso = target:FindFirstChild("Torso") or target:FindFirstChild("UpperTorso")
				if targetTorso then
					local dir = (targetTorso.Position - cloneTorso.Position).Unit
					cloneTorso.CFrame = cloneTorso.CFrame + dir * 0.5
					
					-- Explode on contact
					if (targetTorso.Position - cloneTorso.Position).Magnitude < 5 then
						ParticleSystem.ExplosionEffect(cloneTorso.Position, CONFIG.PrimaryColor, 10)
						
						local hitPlayers = Utility.GetAllPlayersInRange(cloneTorso.Position, 10, chara)
						for _, data in pairs(hitPlayers) do
							if data.Character:FindFirstChild("Humanoid") then
								DamageSystem.ApplyDamage(data.Character.Humanoid, 30, cloneTorso.Position)
							end
						end
						
						clone:Destroy()
						return
					end
				end
			end
		end
		
		-- Time's up, explode anyway
		if cloneTorso and cloneTorso.Parent then
			ParticleSystem.ExplosionEffect(cloneTorso.Position, CONFIG.PrimaryColor, 8)
			clone:Destroy()
		end
	end)()
	
	StateManager.AbilitiesUsed = StateManager.AbilitiesUsed + 1
end

