local Statistics = {}

function Statistics:Start()
    Config.Statistics.StartTime = tick()
end

function Statistics:Update()
    if Config.Statistics.StartTime > 0 then
        Config.Statistics.RunTime = tick() - Config.Statistics.StartTime
    end
end

function Statistics:GetRunTime()
    local runtime = Config.Statistics.RunTime
    local hours = math.floor(runtime / 3600)
    local minutes = math.floor((runtime % 3600) / 60)
    local seconds = math.floor(runtime % 60)
    return string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

function Statistics:GetSuccessRate()
    if Config.Statistics.TotalAttempts == 0 then return 0 end
    return (Config.Statistics.SuccessfulAttempts / Config.Statistics.TotalAttempts) * 100
end

function Statistics:GetAttemptsPerSecond()
    if Config.Statistics.RunTime == 0 then return 0 end
    return Config.Statistics.TotalAttempts / Config.Statistics.RunTime
end

function Statistics:Reset()
    SoundSystem:Play("Warning")
