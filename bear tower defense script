local Commands = {}

function Commands:Register()
    LocalPlayer.Chatted:Connect(function(message)
        local args = string.split(message, " ")
        local cmd = args[1]:lower()
        
        if cmd == "/start" then
            Config.AutoSolveEnabled = true
            NotificationSystem:CreateNotification("Command", "Auto-Solver started!", 2, "SUCCESS")
            SoundSystem:Play("Success")
            
        elseif cmd == "/stop" then
            Config.AutoSolveEnabled = false
            NotificationSystem:CreateNotification("Command", "Auto-Solver stopped!", 2, "WARNING")
            SoundSystem:Play("Warning")
            
        elseif cmd == "/speed" and args[2] then
            local speed = tonumber(args[2])
            if speed then
                Config.WaitTime = math.clamp(speed, 0.001, 5)
                NotificationSystem:CreateNotification("Command", "Speed set to " .. Config.WaitTime, 2, "INFO")
                SoundSystem:Play("Click")
            end
            
        elseif cmd == "/reset" then
            Statistics:Reset()
            NotificationSystem:CreateNotification("Command", "Statistics reset!", 2, "INFO")
            SoundSystem:Play("Warning")
            
        elseif cmd == "/theme" and args[2] then
            local themeName = args[2]:sub(1, 1):upper() .. args[2]:sub(2):lower()
            if ColorPalettes[themeName] then
                Config.CurrentTheme = themeName
                Config.Theme = ColorPalettes[themeName]
                NotificationSystem:CreateNotification("Command", "Theme changed to " .. themeName, 2, "SUCCESS")
                SoundSystem:Play("Success")
                task.wait(0.3)
                CreateGUI()
            end
            
        elseif cmd == "/info" then
            print("=== PUZZLE SOLVER INFO ===")
            print("Version: 3.0 Ultimate")
            print("Status:", Config.AutoSolveEnabled and "Running" or "Stopped")
            print("Speed:", Config.WaitTime .. "s")
            print("Theme:", Config.Theme.Name)
            print("Total Attempts:", Config.Statistics.TotalAttempts)
            print("Success Rate:", string.format("%.2f%%", Statistics:GetSuccessRate()))
        end
    end)
end

