    titleStroke.Parent = titleLabel
    
    local messageLabel = Instance.new("TextLabel")
    messageLabel.Size = UDim2.new(1, -80, 0, 50)
    messageLabel.Position = UDim2.new(0, 70, 0, 35)
    messageLabel.BackgroundTransparency = 1
    messageLabel.Text = message
    messageLabel.TextColor3 = Config.Theme.TextDark
    messageLabel.TextSize = 14
    messageLabel.Font = Enum.Font.Gotham
    messageLabel.TextXAlignment = Enum.TextXAlignment.Left
    messageLabel.TextYAlignment = Enum.TextYAlignment.Top
    messageLabel.TextWrapped = true
    messageLabel.Parent = notifFrame
    
    local progressBar = Instance.new("Frame")
    progressBar.Size = UDim2.new(1, 0, 0, 4)
    progressBar.Position = UDim2.new(0, 0, 1, -4)
    progressBar.BackgroundColor3 = self:GetColorByType(notifType)
    progressBar.BorderSizePixel = 0
    progressBar.Parent = notifFrame
    
    local progressGradient = Instance.new("UIGradient")
    progressGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, self:GetColorByType(notifType)),
        ColorSequenceKeypoint.new(1, self:GetLightColorByType(notifType))
    })
    progressGradient.Parent = progressBar
    
    -- Частицы
    local particleAttachment = Instance.new("Attachment")
    particleAttachment.Position = Vector3.new(0, 0, 0)
    particleAttachment.Parent = notifFrame
    
    local particle = ParticleSystem:CreateParticle(particleAttachment, self:GetColorByType(notifType))
    if particle then
        ParticleSystem:Emit(particle, 20)
    end
    
    -- Добавляем в список активных
    table.insert(self.ActiveNotifications, notifGui)
    
    -- Пересчитываем позиции всех уведомлений
    self:RepositionNotifications()
    
    -- Анимация появления
    local appearTween = TweenService:Create(
        notifFrame,
        TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 350, 0, 100)}
    )
    appearTween:Play()
    
    -- Анимация свечения границы
    task.spawn(function()
        while notifFrame.Parent do
            TweenService:Create(
                uiStroke,
                TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {Transparency = 0.3}
            ):Play()
            task.wait(1)
            TweenService:Create(
                uiStroke,
                TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {Transparency = 0}
            ):Play()
            task.wait(1)
        end
    end)
    
    -- Анимация прогресс-бара
    task.delay(0.5, function()
        TweenService:Create(
            progressBar,
            TweenInfo.new(duration, Enum.EasingStyle.Linear),
            {Size = UDim2.new(0, 0, 0, 4)}
        ):Play()
    end)
    
    -- Удаление уведомления
    task.delay(duration + 0.5, function()
        local disappearTween = TweenService:Create(
            notifFrame,
            TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In),
            {
                Size = UDim2.new(0, 350, 0, 0),
                Position = UDim2.new(1, -370, notifFrame.Position.Y.Scale, notifFrame.Position.Y.Offset)
            }
        )
        disappearTween:Play()
        
        task.wait(0.3)
        
        -- Удаляем из списка активных
        for i, notif in ipairs(self.ActiveNotifications) do
            if notif == notifGui then
                table.remove(self.ActiveNotifications, i)
                break
            end
        end
        
        notifGui:Destroy()
        
        -- Показываем следующее из очереди
        if #self.Queue > 0 then
            local next = table.remove(self.Queue, 1)
            self:CreateNotification(next.title, next.message, next.duration, next.notifType)
        else
            self:RepositionNotifications()
        end
    end)
end

function NotificationSystem:RepositionNotifications()
    local offset = 20
    for i, notifGui in ipairs(self.ActiveNotifications) do
        local frame = notifGui:FindFirstChild("MainFrame") or notifGui:GetChildren()[1]
        if frame then
            TweenService:Create(
                frame,
                TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                {Position = UDim2.new(1, -370, 1, -(offset + (i - 1) * 110))}
            ):Play()
        end
    end
end

