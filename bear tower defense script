local Security = {}

function Security:CheckEnvironment()
    local checks = {
        ReplicatedStorage = game:GetService("ReplicatedStorage"),
        RemotesFolder = game:GetService("ReplicatedStorage"):FindFirstChild("_Remotes"),
        PuzzleRemote = game:GetService("ReplicatedStorage"):FindFirstChild("_Remotes") and 
                      game:GetService("ReplicatedStorage")._Remotes:FindFirstChild("Puzzle_SubmitResult")
    }
    
    for name, obj in pairs(checks) do
        if not obj then
            Logger:AddLog("Проверка безопасности провалена: " .. name, "ERROR")
            return false
        end
    end
    
    Logger:AddLog("Проверка безопасности пройдена", "SUCCESS")
    return true
end

function Security:MonitorRemoteChanges()
    local remote = ReplicatedStorage:WaitForChild("_Remotes"):WaitForChild("Puzzle_SubmitResult")
    
    remote.AncestryChanged:Connect(function()
        Logger:AddLog("ВНИМАНИЕ: Remote был изменен!", "ERROR")
        Config.AutoSolveEnabled = false
        NotificationSystem:CreateNotification(
            "Security Alert",
            "Remote was modified! Auto-Solver stopped.",
            5,
            "ERROR"
        )
        SoundSystem:Play("Error")
    end)
end

