        buttonGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, toggleButton.BackgroundColor3),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(
                math.min(toggleButton.BackgroundColor3.R * 255 * 1.2, 255),
                math.min(toggleButton.BackgroundColor3.G * 255 * 1.2, 255),
                math.min(toggleButton.BackgroundColor3.B * 255 * 1.2, 255)
            ))
        })
        buttonGradient.Rotation = 45
        buttonGradient.Parent = toggleButton
        
        UICreator:AddHoverEffect(toggleButton)
        
        local isEnabled = defaultValue
        
        toggleButton.MouseButton1Click:Connect(function()
            isEnabled = not isEnabled
            SoundSystem:Play("Toggle")
            
            toggleButton.Text = isEnabled and "ON" or "OFF"
            local targetColor = isEnabled and Config.Theme.Success or Config.Theme.Tertiary
            
            TweenService:Create(
                toggleButton,
                TweenInfo.new(0.3, Enum.EasingStyle.Quad),
                {BackgroundColor3 = targetColor}
            ):Play()
            
            TweenService:Create(
                buttonStroke,
                TweenInfo.new(0.3, Enum.EasingStyle.Quad),
                {Color = isEnabled and Config.Theme.SuccessLight or Config.Theme.TextMuted}
            ):Play()
            
            buttonGradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, targetColor),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(
                    math.min(targetColor.R * 255 * 1.2, 255),
                    math.min(targetColor.G * 255 * 1.2, 255),
                    math.min(targetColor.B * 255 * 1.2, 255)
                ))
            })
            
            if callback then
                callback(isEnabled)
            end
        end)
        
        return toggleFrame
    end
    
