-- ====================================

local function StartAutoSolver()
    task.spawn(function()
        while true do
            task.wait(Config.WaitTime)
            
            if Config.AutoSolveEnabled then
                local startTime = tick()
                local success, error = pcall(function()
                    local args = {1}
                    local result = ReplicatedStorage:WaitForChild("_Remotes"):WaitForChild("Puzzle_SubmitResult"):InvokeServer(unpack(args))
                    
                    local endTime = tick()
                    local attemptTime = endTime - startTime
                    
                    Config.Statistics.TotalAttempts = Config.Statistics.TotalAttempts + 1
                    
                    if result then
                        Config.Statistics.SuccessfulAttempts = Config.Statistics.SuccessfulAttempts + 1
                        
                        if attemptTime < Config.Statistics.BestTime or Config.Statistics.BestTime == 0 then
                            Config.Statistics.BestTime = attemptTime
                        end
                        
                        if attemptTime > Config.Statistics.WorstTime and Config.Statistics.WorstTime < 999999 then
                            Config.Statistics.WorstTime = attemptTime
                        end
                    else
                        Config.Statistics.FailedAttempts = Config.Statistics.FailedAttempts + 1
                    end
                    
                    -- Обновляем среднее время
                    Config.Statistics.AverageTime = (Config.Statistics.AverageTime * (Config.Statistics.TotalAttempts - 1) + attemptTime) / Config.Statistics.TotalAttempts
                end)
                
                if not success then
                    Config.Statistics.FailedAttempts = Config.Statistics.FailedAttempts + 1
                    Logger:AddLog("Ошибка при отправке: " .. tostring(error), "ERROR")
                    
                    if Config.Advanced.SafeMode then
                        task.wait(1)
                    end
                end
                
                -- Достижения
                if Config.Statistics.TotalAttempts % 100 == 0 then
                    SoundSystem:Play("Achievement")
                    NotificationSystem:CreateNotification(
                        "Achievement!",
                        string.format("Reached %d total attempts!", Config.Statistics.TotalAttempts),
                        4,
                        "SUCCESS"
                    )
                end
            end
        end
    end)
end

