local Logger = {}
Logger.Logs = {}
Logger.MaxLogs = 1000

function Logger:AddLog(message, logType)
    local timestamp = os.date("%H:%M:%S")
    local logEntry = {
        Time = timestamp,
        Message = message,
        Type = logType or "INFO",
        Id = HttpService:GenerateGUID(false)
    }
    
    table.insert(self.Logs, 1, logEntry)
    
    if #self.Logs > self.MaxLogs then
        table.remove(self.Logs, #self.Logs)
    end
    
    if Config.Advanced.LoggingEnabled then
        local prefix = string.format("[%s] [%s]", timestamp, logEntry.Type)
        if logType == "ERROR" then
            warn(prefix, message)
        else
            print(prefix, message)
        end
    end
    
    return logEntry
end

function Logger:GetLogs(count)
    count = count or 10
    local logs = {}
    for i = 1, math.min(count, #self.Logs) do
        table.insert(logs, self.Logs[i])
    end
    return logs
end

function Logger:Clear()
    self.Logs = {}
    SoundSystem:Play("Success")
end

function Logger:ExportLogs()
    local export = "=== PUZZLE SOLVER LOGS ===\n"
    export = export .. "Exported: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n\n"
    
    for i, log in ipairs(self.Logs) do
        export = export .. string.format("[%s] [%s] %s\n", log.Time, log.Type, log.Message)
    end
    
    return export
end

