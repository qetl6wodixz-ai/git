local function Initialize()
    Logger:AddLog("🚀 Начало инициализации Puzzle Solver Pro v3.0 Ultimate...", "INFO")
    
    -- Проверка безопасности
    if not Security:CheckEnvironment() then
        warn("⚠️ Проверка безопасности провалена!")
        return
    end
    
    -- Создание GUI
    CreateGUI()
    
    -- Запуск автоматического решения
    StartAutoSolver()
    
    -- Регистрация команд
    Commands:Register()
    
    -- Мониторинг безопасности
    Security:MonitorRemoteChanges()
    
    -- Включение Anti-AFK если активно
    if Config.Advanced.AntiAFK then
        AntiAFK:Enable()
    end
    
    -- Включение Auto-Rejoin если активно
    if Config.Advanced.AutoRejoin then
        AutoRejoin:Enable()
    end
    
    Logger:AddLog("✨ Инициализация завершена успешно!", "SUCCESS")
    Logger:AddLog("===========================================", "INFO")
    Logger:AddLog("PUZZLE SOLVER PRO V3.0 ULTIMATE - READY!", "SUCCESS")
    Logger:AddLog("===========================================", "INFO")
    
    SoundSystem:Play("Achievement")
end

