function WeatherSystem:setWeather(weatherType, transitionTime)
    if not self.weatherTypes[weatherType] then return end
    
    self.targetWeather = weatherType
    self.transitionTime = transitionTime or 5
    self.transitionStartTime = tick()
    self.previousWeather = self.currentWeather
end

function WeatherSystem:update(deltaTime)
    -- Handle weather transition
    if self.targetWeather and self.targetWeather ~= self.currentWeather then
        local elapsed = tick() - self.transitionStartTime
        local progress = math.min(elapsed / self.transitionTime, 1)
        
        if progress >= 1 then
            self.currentWeather = self.targetWeather
            self.targetWeather = nil
        else
            self.weatherIntensity = progress
        end
    end
    
    -- Update wind
    self.windDirection = (self.windDirection + Vector3.new(
        (math.random() - 0.5) * 0.1,
        0,
        (math.random() - 0.5) * 0.1
    )).Unit
    
    -- Check for lightning
    local currentData = self.weatherTypes[self.currentWeather]
    if currentData.LightningChance then
        if math.random() < currentData.LightningChance * deltaTime then
            self:triggerLightning()
        end
    end
end

function WeatherSystem:triggerLightning()
    local lightningData = {
        Position = Vector3.new(
            math.random(-500, 500),
            200,
            math.random(-500, 500)
        ),
        Brightness = 10,
        Duration = 0.1,
        ThunderDelay = math.random(1, 5),
        ThunderVolume = math.random() * 0.5 + 0.5
    }
    
    return lightningData
end

function WeatherSystem:getPhysicsModifiers()
    local currentData = self.weatherTypes[self.currentWeather]
    
    return {
        FrictionMultiplier = 1 - (currentData.SurfaceSlipperiness or 0),
        WindForce = self.windDirection * self.windSpeed,
        VisibilityRange = 1000 * (1 - (currentData.VisibilityReduction or 0)),
        AmbientDamageRate = currentData.VehicleDamageRate or 0
    }
end

