        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = circle,
    })
    Util.AddCorner(ring, size / 2)
    local ringStroke = Util.AddStroke(ring, color, 1, 0.6)
    
    -- Анимация орбиты
    spawn(function()
        local angle = startAngle or 0
        while circle.Parent do
