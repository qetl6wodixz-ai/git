    })
    Util.AddCorner(particle, 999)
    
    if isGlowing then
        local glow = Util.Create("ImageLabel", {
            Size = UDim2.new(3, 0, 3, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundTransparency = 1,
            Image = "rbxassetid://5028857084",
            ImageColor3 = Config.Colors.Primary,
            ImageTransparency = 0.8,
            ZIndex = 6,
            Parent = particle,
        })
    end
    
    -- Анимация движения
    local function animateParticle()
        while particle.Parent do
            local targetX = math.random() * 1
            local targetY = math.random() * 1
            local duration = math.random(40, 100) / 10
            
            local moveTween = TweenService:Create(particle, 
                TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                {
                    Position = UDim2.new(targetX, 0, targetY, 0),
                    BackgroundTransparency = math.random(40, 90) / 100,
                }
            )
            moveTween:Play()
            moveTween.Completed:Wait()
        end
    end
    
    spawn(animateParticle)
    
    return particle
end

