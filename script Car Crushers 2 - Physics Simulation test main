function UltraSoundSystem:playSound(soundType, params)
    local position = params.Position or Vector3.new(0, 0, 0)
    local volume = (params.Volume or 1) * self.masterVolume
    local pitch = params.Pitch or 1
    local looped = params.Looped or false
    
    -- Doppler effect calculation
    if self.spatialEnabled and UltraConfig.Audio.DopplerEffect then
        local velocity = params.Velocity or Vector3.new(0, 0, 0)
        local listenerPosition = workspace.CurrentCamera.CFrame.Position
        local direction = (position - listenerPosition).Unit
        local relativeVelocity = velocity:Dot(direction)
        
        -- Adjust pitch based on relative velocity
        local speedOfSound = 343 -- m/s
        pitch = pitch * (speedOfSound / (speedOfSound - relativeVelocity * 0.1))
    end
    
    local sound = {
        Type = soundType,
        Position = position,
        Volume = volume,
        Pitch = math.clamp(pitch, 0.5, 2.0),
        Looped = looped,
        StartTime = tick(),
        Duration = params.Duration or 1
    }
    
    table.insert(self.activeSounds, sound)
    
    return sound
end

function UltraSoundSystem:playImpactSound(impactForce, position, materialType)
    local intensity = "Light"
    if impactForce > 50 then intensity = "Medium" end
    if impactForce > 100 then intensity = "Heavy" end
    
    local soundCategory = materialType .. "Impact"
    if self.soundBank[soundCategory] then
        local sounds = self.soundBank[soundCategory][intensity] or self.soundBank[soundCategory]
        local selectedSound = sounds[math.random(1, #sounds)]
        
        self:playSound(selectedSound, {
            Position = position,
            Volume = math.min(impactForce / 100, 1),
            Pitch = 1 + (math.random() - 0.5) * 0.2
        })
        
        -- Add bass boost for heavy impacts
        if impactForce > 80 then
            self:playSound("SubBass", {
                Position = position,
                Volume = impactForce / 150 * UltraConfig.Audio.ExplosionBassBoost,
                Pitch = 0.5
            })
        end
    end
end

