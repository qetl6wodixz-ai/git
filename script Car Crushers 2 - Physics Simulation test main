-- Эффект печатной машинки
function Util.TypewriterEffect(label, text, speed, callback)
    speed = speed or Config.Animation.TypewriterSpeed
    spawn(function()
        label.Text = ""
        for i = 1, #text do
            label.Text = text:sub(1, i)
            if i % 2 == 0 then
                Util.PlaySound(Config.Sounds.Typing, 0.1, math.random(80, 120) / 100)
            end
            task.wait(speed)
        end
        if callback then callback() end
    end)
end

-- Эффект глитча для текста
function Util.GlitchText(label, originalText, duration, intensity)
    duration = duration or 0.5
    intensity = intensity or 3
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{}|;':\",./<>?"
    
    spawn(function()
        local startTime = tick()
        while tick() - startTime < duration do
            local glitchedText = ""
            for i = 1, #originalText do
                if math.random(1, 10) <= intensity then
                    local randIndex = math.random(1, #chars)
                    glitchedText = glitchedText .. chars:sub(randIndex, randIndex)
                else
                    glitchedText = glitchedText .. originalText:sub(i, i)
                end
            end
            label.Text = glitchedText
            task.wait(0.03)
        end
        label.Text = originalText
    end)
end

-- Shake эффект
function Util.ShakeElement(element, intensity, duration)
    intensity = intensity or 5
    duration = duration or 0.3
    local originalPos = element.Position
    
    spawn(function()
        local startTime = tick()
        while tick() - startTime < duration do
            local offsetX = math.random(-intensity, intensity)
            local offsetY = math.random(-intensity, intensity)
            element.Position = UDim2.new(
                originalPos.X.Scale, originalPos.X.Offset + offsetX,
                originalPos.Y.Scale, originalPos.Y.Offset + offsetY
            )
            task.wait(0.02)
        end
        element.Position = originalPos
    end)
end

-- Bounce анимация
function Util.BounceIn(element)
    element.Size = UDim2.new(0, 0, 0, 0)
    local targetSize = element.Size
    
    Util.Tween(element, 0.4, {
        Size = UDim2.new(
            targetSize.X.Scale * 1.1, targetSize.X.Offset * 1.1,
            targetSize.Y.Scale * 1.1, targetSize.Y.Offset * 1.1
        )
    }, Enum.EasingStyle.Back)
    
    task.wait(0.4)
    
    Util.Tween(element, 0.2, {Size = targetSize}, Enum.EasingStyle.Quad)
end

