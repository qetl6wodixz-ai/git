            BackgroundColor3 = Util.RandomColor(color, 40),
            BackgroundTransparency = 0,
            BorderSizePixel = 0,
            ZIndex = 55,
            Parent = ScreenGui,
        })
        Util.AddCorner(particle, 999)
        
        local targetX = position.X.Offset + math.cos(angle) * speed
        local targetY = position.Y.Offset + math.sin(angle) * speed
        
        Util.Tween(particle, math.random(5, 15) / 10, {
            Position = UDim2.new(position.X.Scale, targetX, position.Y.Scale, targetY),
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 1, 0, 1),
        })
        
        game:GetService("Debris"):AddItem(particle, 2)
    end
end

