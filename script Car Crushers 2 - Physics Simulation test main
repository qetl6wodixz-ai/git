                    if achievement.Progress >= achievement.Target then
                        achievement.Unlocked = true
                        print("🏆 Achievement Unlocked: " .. achievement.Name)
                    end
                else
                    achievement.Unlocked = true
                    print("🏆 Achievement Unlocked: " .. achievement.Name)
                end
            end
        end
