local crusherPart = script.Parent 
local originalCFrame = crusherPart.CFrame -- Запоминаем стартовую позицию
local downCFrame = originalCFrame * CFrame.new(0, -30, 0) -- На сколько ехать вниз (30 стадов)

-- Звук (опционально, создай Sound внутри детали и назови "CrushSound")
local sound = crusherPart:FindFirstChild("CrushSound")

-- [[ ФУНКЦИИ ]] --

-- Функция для поиска и уничтожения машин
local function crushCars()
	-- Параметры поиска: ищем только незакрепленные детали, пропуская сам пресс
	local overlapParams = OverlapParams.new()
	overlapParams.FilterDescendantsInstances = {crusherPart}
	overlapParams.FilterType = Enum.RaycastFilterType.Exclude
	
	-- Получаем размер пресса
	local size = crusherPart.Size
	local currentCFrame = crusherPart.CFrame
	
	-- Самый быстрый способ найти всё под прессом
	local partsInZone = workspace:GetPartBoundsInBox(currentCFrame, size, overlapParams)
	local crushedModels = {} -- Чтобы не давить одну машину 100 раз

	for _, part in pairs(partsInZone) do
		-- Проверяем, что это часть модели (машины) и она не закреплена
		if part.Parent and not part.Anchored and part:IsA("BasePart") then
			local model = part.Parent
			
			-- Если мы еще не давили эту модель
			if not crushedModels[model] then
				crushedModels[model] = true
				
				-- Применяем силу ко всем частям машины
				for _, p in pairs(model:GetDescendants()) do
					if p:IsA("BasePart") and not p.Anchored then
						-- Ломаем сварки (WeldConstraints), чтобы машина развалилась
						for _, w in pairs(p:GetJoints()) do
							w:Destroy()
						end
						
						-- Придаем импульс вниз + немного в стороны (рандом)
						local randomX = math.random(-5000, 5000)
						local randomZ = math.random(-5000, 5000)
						p:ApplyImpulse(Vector3.new(randomX, -CONFIG.CrushForce, randomZ) * p.AssemblyMass)
					end
				end
			end
		end
	end
end

-- Главная функция давки
local function StartCrush()
	-- 1. Инфо для анимации
	local tweenInfoDown = TweenInfo.new(CONFIG.CrushSpeed, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	local tweenInfoUp = TweenInfo.new(CONFIG.ReturnSpeed, Enum.EasingStyle.Bounce, Enum.EasingDirection.Out)
	
	-- 2. Твин вниз
	local tweenDown = TweenService:Create(crusherPart, tweenInfoDown, {CFrame = downCFrame})
	tweenDown:Play()
	
	if sound then sound:Play() end
	
	-- 3. Пока едет вниз, давим машины
	local connection
	connection = game:GetService("RunService").Heartbeat:Connect(function()
		if tweenDown.PlaybackState == Enum.PlaybackState.Completed then
			connection:Disconnect() -- Останавливаем проверку
		end
		crushCars()
	end)
	
	tweenDown.Completed:Wait() -- Ждем пока доедет до низа
	task.wait(0.5) -- Небольшая пауза внизу
	
	-- 4. Твин вверх
	local tweenUp = TweenService:Create(crusherPart, tweenInfoUp, {CFrame = originalCFrame})
	tweenUp:Play()
	tweenUp.Completed:Wait()
	
	if sound then sound:Stop() end
end

-- [[ ЗАПУСК ]] --
if CONFIG.AutoLoop then
	while true do
		StartCrush()
		task.wait(CONFIG.LoopWait)
	end
else
	-- Если хочешь запускать по кнопке или другому скрипту, раскомментируй:
	-- StartCrush()
end

