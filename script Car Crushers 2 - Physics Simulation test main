-- 💥 Process Impact Damage
function UltraVehicleDamage:processImpact(impactData)
    local position = impactData.Position
    local force = impactData.Force
    local direction = impactData.Direction
    local impactType = impactData.Type or "Collision"
    
    -- Calculate affected area
    local affectedRadius = math.min(force / 100, 5)
    local affectedComponents = self:getComponentsInRadius(position, affectedRadius)
    
    local damageResults = {
        ComponentsDamaged = {},
        ParticlesGenerated = {},
        SoundsTriggered = {},
        VisualEffects = {}
    }
    
    for _, componentName in ipairs(affectedComponents) do
        local component = self.components[componentName]
        if component then
            local distance = (position - self:getComponentPosition(componentName)).Magnitude
            local damageFalloff = 1 - (distance / affectedRadius)
            local actualDamage = force * damageFalloff * self:getMaterialResistance(componentName)
            
            -- Apply damage
            local damageResult = self:applyComponentDamage(componentName, actualDamage, direction)
            table.insert(damageResults.ComponentsDamaged, damageResult)
            
            -- Generate effects based on damage
            local effects = self:generateDamageEffects(componentName, actualDamage, position, direction)
            for _, effect in ipairs(effects.Particles) do
                table.insert(damageResults.ParticlesGenerated, effect)
            end
            for _, sound in ipairs(effects.Sounds) do
                table.insert(damageResults.SoundsTriggered, sound)
            end
            for _, visual in ipairs(effects.Visuals) do
                table.insert(damageResults.VisualEffects, visual)
            end
        end
    end
    
    -- Update structural integrity
    self:recalculateStructuralIntegrity()
    
    -- Check for cascading failures
    self:checkCascadingFailures()
    
    return damageResults
end

function UltraVehicleDamage:applyComponentDamage(componentName, damage, direction)
    local component = self.components[componentName]
    local result = {
        Component = componentName,
        DamageApplied = damage,
        NewIntegrity = 0,
        Events = {}
    }
    
    -- Reduce integrity
    component.Integrity = math.max(0, component.Integrity - damage)
    result.NewIntegrity = component.Integrity
    
    -- Apply deformation if applicable
    if component.Deformation ~= nil then
        local deformationAmount = damage * 0.01
        component.Deformation = math.min(1, component.Deformation + deformationAmount)
        
        if component.Deformation > 0.3 then
            table.insert(result.Events, "SEVERE_DEFORMATION")
        end
    end
    
    -- Check for detachment
    if component.Detached ~= nil and component.Integrity < 20 then
        if math.random() < (1 - component.Integrity / 20) * 0.5 then
            component.Detached = true
            table.insert(result.Events, "COMPONENT_DETACHED")
        end
    end
    
    -- Check hinges
    if component.Hinges then
        for hingeName, working in pairs(component.Hinges) do
            if working and damage > 30 and math.random() < 0.3 then
                component.Hinges[hingeName] = false
                table.insert(result.Events, "HINGE_BROKEN:" .. hingeName)
            end
        end
    end
    
    -- Window damage
    if component.Window then
        if damage > 15 then
            component.Window = math.max(0, component.Window - damage * 2)
            if component.Window == 0 then
                table.insert(result.Events, "WINDOW_SHATTERED")
            end
        end
    end
    
    -- Glass crack patterns
    if component.CrackPattern then
        if damage > 10 then
            local crackCount = math.floor(damage / 5)
            for i = 1, crackCount do
                table.insert(component.CrackPattern, {
                    Start = Vector2.new(math.random(), math.random()),
                    End = Vector2.new(math.random(), math.random()),
                    Width = math.random() * 2 + 0.5
                })
            end
        end
        
        if component.Integrity < 30 and not component.Shattered then
            component.Shattered = true
            table.insert(result.Events, "GLASS_SHATTERED")
        end
    end
    
    -- Tire damage
    if component.TirePressure then
        if damage > 25 then
            local pressureLoss = damage * 0.5
            component.TirePressure = math.max(0, component.TirePressure - pressureLoss)
            
            if component.TirePressure < 10 then
                table.insert(result.Events, "TIRE_FLAT")
            end
        end
        
        -- Alignment damage
        if damage > 40 then
            component.Alignment = component.Alignment + (direction.X * damage * 0.1)
            component.Alignment = math.clamp(component.Alignment, -45, 45)
        end
        
        -- Rim damage
        if component.Rim and damage > 50 then
            component.Rim.Integrity = math.max(0, component.Rim.Integrity - damage * 0.5)
            if not component.Rim.Bent and damage > 70 then
                component.Rim.Bent = true
                table.insert(result.Events, "RIM_BENT")
            end
        end
    end
    
    -- Mechanical component specific damage
    if componentName == "Engine" then
        if damage > 40 then
            component.OilPressure = math.max(0, component.OilPressure - damage * 0.3)
            if component.OilPressure < 15 then
                self.fluids.Oil.Leaking = true
                self.fluids.Oil.LeakRate = (15 - component.OilPressure) * 0.5
                table.insert(result.Events, "OIL_LEAK")
            end
        end
        
        if component.Integrity < 50 then
            component.Running = false
            table.insert(result.Events, "ENGINE_FAILURE")
        end
    end
    
    if componentName == "Radiator" then
        if damage > 30 and not component.Punctured then
            component.Punctured = true
            self.fluids.Coolant.Leaking = true
            self.fluids.Coolant.LeakRate = damage * 0.2
            table.insert(result.Events, "COOLANT_LEAK")
        end
    end
    
    if componentName == "FuelTank" then
        if damage > 50 and not component.Punctured then
            component.Punctured = true
            self.fluids.Fuel.Leaking = true
            self.fluids.Fuel.LeakRate = damage * 0.3
            table.insert(result.Events, "FUEL_LEAK")
        end
    end
    
    return result
end

function UltraVehicleDamage:generateDamageEffects(componentName, damage, position, direction)
    local effects = {
        Particles = {},
        Sounds = {},
        Visuals = {}
    }
    
    -- Determine material type
    local materialType = self:getComponentMaterial(componentName)
    
    -- Metal impact effects
