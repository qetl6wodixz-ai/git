	CrushSpeed = 0.5,       -- Скорость опускания (в секундах)
	ReturnSpeed = 1,        -- Скорость поднятия обратно
	CrushForce = 15000,     -- Сила, с которой давит (чем больше, тем сильнее ломает)
	CheckDelay = 0.1,       -- Как часто проверять машины во время давки
	AutoLoop = true,        -- Включить бесконечный цикл?
	LoopWait = 5            -- Пауза между давками (если AutoLoop = true)
}

-- [[ СЕРВИСЫ ]] --
