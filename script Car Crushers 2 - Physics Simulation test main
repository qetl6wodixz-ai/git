        elseif particle.Type == "Sparks" then
            self.visualEffects:createSparks(particle.Position, collisionData.Direction * -1, particle.Count)
        end
    end
    
    -- Play sounds
    for _, sound in ipairs(results.SoundsTriggered) do
        self.soundSystem:playSound(sound.Type, sound)
    end
    
    -- Apply visual effects
    for _, visual in ipairs(results.VisualEffects) do
        if visual.Type == "ScreenShake" then
            self.visualEffects:createScreenShake(visual.Intensity, visual.Duration)
        elseif visual.Type == "SlowMotion" then
            self.visualEffects:createSlowMotion(visual.TimeScale, visual.Duration)
        end
    end
    
    -- Update statistics
    self.stats.TotalCollisions = self.stats.TotalCollisions + 1
    self.stats.ParticlesGenerated = self.stats.ParticlesGenerated + #results.ParticlesGenerated
    
    return results
end

function UltraSimulationEnhancement:update(deltaTime)
    -- Update all systems
    self.weatherSystem:update(deltaTime)
    self.visualEffects:update(deltaTime)
    
    -- Update fluid leaks
    for vehicle, damageSystem in pairs(self.vehicleDamage) do
        for fluidName, fluidData in pairs(damageSystem.fluids) do
            if fluidData.Leaking and fluidData.Level > 0 then
                fluidData.Level = fluidData.Level - (fluidData.LeakRate * deltaTime)
                
                -- Create leak visual
                if math.random() < fluidData.LeakRate * deltaTime then
                    self.visualEffects:createFluidLeak(
                        damageSystem:getComponentPosition("FuelTank"),
                        fluidName,
                        fluidData.LeakRate
                    )
                end
            end
        end
        
        -- Update temperature
        if damageSystem.fluids.Coolant.Level < 50 then
            damageSystem.temperature.Engine = damageSystem.temperature.Engine + deltaTime * (50 - damageSystem.fluids.Coolant.Level) * 0.01
        end
    end
    
    self.stats.EffectsActive = #self.visualEffects.activeEffects
end

function UltraSimulationEnhancement:createMassiveExplosion(position)
    -- Epic explosion sequence
    print("💥 MASSIVE EXPLOSION TRIGGERED!")
    
    -- Main explosion
    self.visualEffects:createExplosion(position, 20, "Nuclear")
    
    -- Screen shake
    self.visualEffects:createScreenShake(5, 2)
    
    -- Slow motion
    self.visualEffects:createSlowMotion(0.2, 1)
    
    -- Multiple fire points
    for i = 1, 10 do
        local offset = Vector3.new(
            math.random(-10, 10),
            math.random(0, 5),
            math.random(-10, 10)
        )
        self.visualEffects:createFire(position + offset, math.random() * 2 + 1, 30)
    end
    
    -- Debris shower
    for i = 1, 50 do
        local offset = Vector3.new(
            math.random(-5, 5),
            math.random(0, 3),
            math.random(-5, 5)
        )
        self.visualEffects:createSparks(position + offset, Vector3.new(0, 1, 0), 20)
    end
    
    -- Massive smoke cloud
    self.visualEffects:createSmoke(position, Color3.fromRGB(20, 20, 20), 5, 60)
    
    -- Sound
    self.soundSystem:playSound("Explosion_Large", {
        Position = position,
        Volume = 1,
        Pitch = 0.8
    })
    
    return true
end

function UltraSimulationEnhancement:getStats()
    return self.stats
end

function UltraSimulationEnhancement:setWeather(weatherType)
    self.weatherSystem:setWeather(weatherType, 5)
    print("🌦️ Weather changing to: " .. weatherType)
end

