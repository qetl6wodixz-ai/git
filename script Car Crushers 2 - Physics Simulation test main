-- Replay System
local ReplaySystem = {
    recording = false,
    frames = {},
    maxFrames = 3000, -- 50 seconds at 60fps
    
    startRecording = function(self)
        self.recording = true
        self.frames = {}
        print("📹 Replay recording started")
    end,
    
    stopRecording = function(self)
        self.recording = false
        print("📹 Replay recording stopped: " .. #self.frames .. " frames")
    end,
    
    recordFrame = function(self, frameData)
        if self.recording then
            table.insert(self.frames, frameData)
            if #self.frames > self.maxFrames then
                table.remove(self.frames, 1)
            end
        end
    end,
    
    playback = function(self, speed)
        print("▶️ Playing replay at " .. (speed or 1) .. "x speed")
        return self.frames
    end
}

