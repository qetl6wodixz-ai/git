function VisualEffectsManager:update(deltaTime)
    local currentTime = tick()
    
    -- Update and remove expired effects
    for i = #self.activeEffects, 1, -1 do
        local effect = self.activeEffects[i]
        local elapsed = currentTime - effect.StartTime
        
        if elapsed > effect.Duration then
            table.remove(self.activeEffects, i)
        else
            -- Update effect based on type
            if effect.Type == "ScreenShake" then
                effect.CurrentIntensity = effect.Intensity * (1 - elapsed / effect.Duration) * effect.Decay
            elseif effect.Type == "SlowMotion" then
                local progress = elapsed / effect.Duration
                if progress < effect.EaseIn then
                    effect.CurrentTimeScale = 1 - (1 - effect.TimeScale) * (progress / effect.EaseIn)
                elseif progress > (1 - effect.EaseOut) then
                    local easeProgress = (progress - (1 - effect.EaseOut)) / effect.EaseOut
                    effect.CurrentTimeScale = effect.TimeScale + (1 - effect.TimeScale) * easeProgress
                else
                    effect.CurrentTimeScale = effect.TimeScale
                end
            end
        end
    end
end

