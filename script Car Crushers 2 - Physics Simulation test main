function UltraVehicleDamage:getComponentMaterial(componentName)
    local glassParts = {"Windshield", "RearWindow", "HeadlightLeft", "HeadlightRight", "TaillightLeft", "TaillightRight"}
    local plasticParts = {"FrontBumper", "RearBumper", "LeftMirror", "RightMirror", "FogLightLeft", "FogLightRight"}
    
    for _, part in ipairs(glassParts) do
        if componentName == part then return "Glass" end
    end
    
    for _, part in ipairs(plasticParts) do
        if componentName == part then return "Plastic" end
    end
    
    return "Metal"
end

function UltraVehicleDamage:getMaterialResistance(componentName)
    local resistances = {
        Metal = 0.8,
        Glass = 1.5,
        Plastic = 1.2
    }
    return resistances[self:getComponentMaterial(componentName)] or 1
end

function UltraVehicleDamage:getComponentsInRadius(position, radius)
    -- Simplified - return all components (in real implementation, would check positions)
    local allComponents = {}
    for name, _ in pairs(self.components) do
        table.insert(allComponents, name)
    end
    return allComponents
end

function UltraVehicleDamage:getComponentPosition(componentName)
    -- Return estimated position based on component name
    local positions = {
        Hood = Vector3.new(0, 1, 3),
        Trunk = Vector3.new(0, 1, -3),
        -- ... more positions
    }
    return positions[componentName] or Vector3.new(0, 0, 0)
end

function UltraVehicleDamage:recalculateStructuralIntegrity()
    local totalIntegrity = 0
    local componentCount = 0
    local criticalComponents = {"Chassis", "Subframe", "Engine", "FrontLeftSuspension", "FrontRightSuspension", "RearLeftSuspension", "RearRightSuspension"}
    
    for name, component in pairs(self.components) do
        if component.Integrity then
            local weight = 1
            for _, critical in ipairs(criticalComponents) do
                if name == critical then
                    weight = 3
                    break
                end
            end
            totalIntegrity = totalIntegrity + (component.Integrity * weight)
            componentCount = componentCount + weight
        end
    end
    
    self.structuralIntegrity = totalIntegrity / componentCount
end

function UltraVehicleDamage:checkCascadingFailures()
    -- Engine overheating from coolant loss
    if self.fluids.Coolant.Level < 30 then
        self.temperature.Engine = self.temperature.Engine + (30 - self.fluids.Coolant.Level) * 0.1
        
        if self.temperature.Engine > 120 then
            self.components.Engine.Integrity = math.max(0, self.components.Engine.Integrity - 1)
        end
    end
    
    -- Electrical failure from battery damage
    if self.components.Battery.Integrity < 50 then
        self.electrical.BatteryCharge = self.electrical.BatteryCharge * (self.components.Battery.Integrity / 50)
        
        if self.electrical.BatteryCharge < 20 then
            self.electrical.LightsWorking = false
            self.electrical.EngineStartable = false
        end
    end
    
    -- Brake failure from fluid loss
    if self.fluids.BrakeFluid.Level < 40 then
        -- Brakes compromised
    end
end

