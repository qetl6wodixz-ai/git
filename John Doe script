New = function(Object,Parent,Name,Data)
	local Object = Instance.new(Object) for Index,Value in pairs(Data or {}) do Object[Index]=Value end Object.Parent=Parent Object.Name=Name return Object
end
local function GetDistanceBetween(p1,p2) return (p1.Position-p2.Position).Magnitude end
local function IsValidTarget(t) if t and t:FindFirstChild("Humanoid") and t.Humanoid.Health>0 and t~=chara and not t:FindFirstChild("HasBeenHit") then return true end return false end
local function GetAllTargetsInRange(pos,range)
	local r={} for _,plr in pairs(Players:GetPlayers()) do if plr~=player and plr.Character then
		local t=plr.Character:FindFirstChild("Torso") or plr.Character:FindFirstChild("UpperTorso")
		if t and (t.Position-pos).Magnitude<=range and IsValidTarget(plr.Character) then table.insert(r,plr.Character) end
	end end return r
end
function CanUseAbility(n) local r=AbilityPhaseReq[n] return r and CurrentPhase>=r end
function CanUseCooldown(n,cd) if AbilityCooldowns[n] and AbilityCooldowns[n]>tick() then return false end AbilityCooldowns[n]=tick()+cd return true end
local function lerpColor(c1,c2,t) return Color3.new(c1.R+(c2.R-c1.R)*t,c1.G+(c2.G-c1.G)*t,c1.B+(c2.B-c1.B)*t) end

