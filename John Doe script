function SetPhase(newPhase) if newPhase==CurrentPhase or IsTransitioning then return end
	CurrentPhase=newPhase local info=PhaseInfo[newPhase] DamageMultiplier=info.DamageMult SpeedMultiplier=info.SpeedMult
	if PhaseTransFuncs[newPhase] then spawn(PhaseTransFuncs[newPhase]) end
	spawn(function() local md=0.5 if newPhase>=7 then md=2 elseif newPhase>=4 then md=1 end wait(md) PMusic:SwitchToPhase(newPhase) end)
	spawn(function() wait(1) if tecks then tecks.Text=info.Name tecks.TextColor3=info.Color end end)
	spawn(function() wait(2) local bb=Instance.new("BillboardGui",chara.Head) bb.Size=UDim2.new(0,400,0,80) bb.StudsOffset=Vector3.new(0,5,0) bb.Adornee=chara.Head
		local lb=Instance.new("TextLabel",bb) lb.Size=UDim2.new(1,0,1,0) lb.BackgroundTransparency=1 lb.Text="PHASE "..newPhase..": "..info.Name
		lb.TextColor3=RC lb.TextStrokeTransparency=0 lb.TextStrokeColor3=BK lb.Font=Enum.Font.GothamBold lb.TextScaled=true
		wait(3) for i=1,20 do lb.TextTransparency=lb.TextTransparency+0.05 lb.TextStrokeTransparency=lb.TextStrokeTransparency+0.05 wait(0.03) end bb:Destroy() end)
	spawn(function() wait(1.5) GenerateMegaSpikesForPhase(newPhase) GenerateTendrilsForPhase(newPhase) GenerateOrbsForPhase(newPhase)
		GenerateTrailsForPhase(newPhase) GenerateAuraForPhase(newPhase) GenerateEyeEffectsForPhase(newPhase) CreateDarkWings(newPhase) UpdateBodyDarkness(newPhase) end)
	spawn(function() while IsTransitioning do wait(0.1) end if IsSprinting then Humanoid.WalkSpeed=info.RunSpeed else Humanoid.WalkSpeed=info.WalkSpeed end end)
	if newPhase>=5 then spawn(function() wait(2) for _,t in pairs(GetAllTargetsInRange(chara.Torso.Position,15+newPhase*3)) do
		local h=t:FindFirstChild("Humanoid") if h then h.Health=h.Health-newPhase*10 if h.Health<=0 then KillMortal(t) end end end end) end end

