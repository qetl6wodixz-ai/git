function SoulSteal(pos) coroutine.wrap(function() local soul=Instance.new("Part",chara) soul.Size=Vector3.new(0,0,0) soul.CanCollide=false soul.Anchored=false soul.Position=pos soul.Transparency=1
	local ptc=Instance.new("ParticleEmitter",soul) ptc.Texture="http://www.roblox.com/asset/?id=413366101" ptc.Size=NumberSequence.new(.5) ptc.LockedToPart=true ptc.Speed=NumberRange.new(0) ptc.Lifetime=NumberRange.new(9999)
	local bp=Instance.new("BodyPosition",soul) bp.Position=pos wait(2) soul.Touched:connect(function(hit) if hit.Parent==chara then PlayerStats.SoulsCollected=PlayerStats.SoulsCollected+1 soul:Destroy() end end)
	while soul and soul.Parent do wait(.1) bp.Position=chara.Torso.Position end end)() end

function KillMortal(hitdude) if not hitdude or hitdude:FindFirstChild("HasBeenHit") then return end
	local torsy=hitdude:FindFirstChild("Torso") or hitdude:FindFirstChild("UpperTorso") if not torsy then return end
	Instance.new("ObjectValue",hitdude).Name="HasBeenHit" hitdude:BreakJoints()
	local hum=hitdude:FindFirstChild("Humanoid") if hum then hum:Destroy() end
	SoulSteal(torsy.Position) KillCount=KillCount+1 PlayerStats.Kills=PlayerStats.Kills+1 CheckPhaseUp()
	local chi=hitdude:GetChildren() for i=1,#chi do if chi[i].ClassName=="Part" or chi[i].ClassName=="MeshPart" then
		Instance.new("BodyPosition",chi[i]).Position=chi[i].Position+Vector3.new(math.random(-5,5),math.random(-5,5),math.random(-5,5))
		ScatterEff(chi[i]) chi[i].BrickColor=BrickColor.new("Really black") end end
	for i=1,4 do for j=1,#chi do if chi[j].ClassName=="Part" or chi[j].ClassName=="MeshPart" then chi[j].Transparency=chi[j].Transparency+.25 wait(.01) end end end
	for i=1,#chi do if chi[i].ClassName=="Part" or chi[i].ClassName=="MeshPart" then chi[i]:Destroy() end end end

