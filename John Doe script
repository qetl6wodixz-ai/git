		local ox,oy,oz=(math.random()-0.5)*2*mo.X,(math.random()-0.5)*2*mo.Y,(math.random()-0.5)*2*mo.Z
		local od=Vector3.new(ox,oy,oz).Unit local rx=math.atan2(od.Z,od.Y)+(math.random()-0.5)*0.8 local ry=math.random()*math.pi*2 local rz=math.atan2(od.X,od.Y)+(math.random()-0.5)*0.8
