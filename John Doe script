function Teleport(pos) PlaySound("Tele") for _,c in pairs(chara:GetChildren()) do if c.ClassName=="Part" and c.Name~="HumanoidRootPart" then
	local tr=Instance.new("Part",workspace) tr.Size=c.Size tr.Material="Neon" tr.BrickColor=BrickColor.new("Really black") tr.Transparency=.3 tr.CanCollide=false tr.Anchored=true tr.CFrame=c.CFrame
	coroutine.wrap(function() wait(1) for j=1,7 do wait(.1) tr.Transparency=tr.Transparency+.1 end tr:Destroy() end)() end end
	chara.Torso.CFrame=CFrame.new(pos.X,pos.Y,pos.Z) end

function Grab(mouse) local hit=mouse.Target if not hit then return end if hit.Parent:FindFirstChild("Humanoid") then
	local torsy=hit.Parent:FindFirstChild("Torso") or hit.Parent:FindFirstChild("UpperTorso")
	local bp=Instance.new("BodyPosition",torsy) bp.Position=torsy.Position wait(1) PlaySound("Burn") hit.Parent.Humanoid.MaxHealth=100 bp.Position=bp.Position+Vector3.new(0,4,0)
	for i=1,10 do wait(.1) BurningEff(torsy) hit.Parent.Humanoid.Health=hit.Parent.Humanoid.Health-10 end KillMortal(hit.Parent) end end

