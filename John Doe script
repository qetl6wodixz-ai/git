-- ИСПРАВЛЕННЫЙ FadeOut
function PMusic:FadeOutSound(snd, dur)
	if not snd or not snd.Parent then return end
	local startVol = snd.Volume
	if startVol <= 0 then snd:Stop() return end
	spawn(function()
		local steps = math.max(1, math.floor((dur or 2) / 0.05))
		for i = 1, steps do
			if not snd or not snd.Parent then return end
			snd.Volume = startVol * (1 - i/steps)
			wait(0.05)
		end
		if snd and snd.Parent then
			snd.Volume = 0
			snd:Stop()
		end
	end)
end

-- ИСПРАВЛЕННЫЙ FadeIn
function PMusic:FadeInSound(snd, targetVol, dur)
	if not snd or not snd.Parent then return end
	spawn(function()
		snd.Volume = 0
		snd:Play()
		local steps = math.max(1, math.floor((dur or 2) / 0.05))
		for i = 1, steps do
			if not snd or not snd.Parent then return end
			snd.Volume = targetVol * (i / steps)
			wait(0.05)
		end
		if snd and snd.Parent then
			snd.Volume = targetVol
		end
	end)
end

-- ИСПРАВЛЕННОЕ ПЕРЕКЛЮЧЕНИЕ МУЗЫКИ
function PMusic:SwitchToPhase(newPhase)
	if self.Fading then return end
	self.Fading = true

	local trackData = self.Tracks[newPhase]
	if not trackData then self.Fading = false return end

	local newData = trackData.Data
	local newSound = trackData.Sound

	-- Стопим базовые Music1/Music2 только один раз
	if Sounds["Music1"] and Sounds["Music1"].Playing then
		self:FadeOutSound(Sounds["Music1"], 2)
	end
	if Sounds["Music2"] and Sounds["Music2"].Playing then
		self:FadeOutSound(Sounds["Music2"], 2)
	end

	-- Фейд-аут ВСЕХ других фазовых треков (не только текущего)
	for ph, td in pairs(self.Tracks) do
		if ph ~= newPhase and td.Sound and td.Sound.Parent then
			if td.Sound.Playing and td.Sound.Volume > 0 then
				self:FadeOutSound(td.Sound, 2)
			end
		end
	end

	-- Фейд-ин нового трека с задержкой
	spawn(function()
		wait(1.5) -- ждём пока старые треки начнут затихать
		if newSound and newSound.Parent then
			self:FadeInSound(newSound, newData.Vol, 2.5)
		end
	end)

	-- Обновляем амбиент слои
	spawn(function()
		local dl = PhaseInfo[newPhase].DarkLevel
		local targetAmbVol = dl * 2.5
		local targetAmbPitch = math.max(0.08, 0.2 - dl * 0.12)
		local targetHBVol = 0
		local targetHBPitch = 0.5
		if newPhase >= 3 then
			targetHBVol = 0.8 + (newPhase - 3) * 0.4
			targetHBPitch = 0.5 + (newPhase - 3) * 0.08
		end
		for i = 1, 40 do
			AmbientLayer.Volume = AmbientLayer.Volume + (targetAmbVol - AmbientLayer.Volume) * 0.05
			AmbientLayer.PlaybackSpeed = AmbientLayer.PlaybackSpeed + (targetAmbPitch - AmbientLayer.PlaybackSpeed) * 0.05
			HeartbeatLayer.Volume = HeartbeatLayer.Volume + (targetHBVol - HeartbeatLayer.Volume) * 0.05
			HeartbeatLayer.PlaybackSpeed = HeartbeatLayer.PlaybackSpeed + (targetHBPitch - HeartbeatLayer.PlaybackSpeed) * 0.05
