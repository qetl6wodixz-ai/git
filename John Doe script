	if name=="Roar" then if ExtraAnims["Roar"] then ExtraAnims["Roar"]:Play() end PlaySound("PhaseRoar")
		spawn(function() for i=1,3 do local rw=Instance.new("Part",workspace) rw.Shape="Ball" rw.Size=Vector3.new(1,1,1) rw.Position=chara.Head.Position rw.Material=Enum.Material.Neon rw.Color=Color3.new(1,0,0) rw.Anchored=true rw.CanCollide=false rw.Transparency=0.5
			spawn(function() for j=1,20 do local s=j*3 rw.Size=Vector3.new(s,s,s) rw.Transparency=0.5+(j/20)*0.5 wait(0.02) end rw:Destroy() end)
			for _,t in pairs(GetAllTargetsInRange(chara.Torso.Position,30)) do local ts=t:FindFirstChild("Torso") or t:FindFirstChild("UpperTorso")
				if ts then local pf=Instance.new("BodyVelocity",ts) pf.Velocity=(ts.Position-chara.Torso.Position).Unit*(30+CurrentPhase*5)+Vector3.new(0,10,0) pf.MaxForce=Vector3.new(50000,50000,50000) Debris:AddItem(pf,0.5) end
				local h=t:FindFirstChild("Humanoid") if h then h.Health=h.Health-CurrentPhase*5 if h.Health<=0 then KillMortal(t) end end end wait(0.5) end end)
		wait(2) if ExtraAnims["Roar"] then ExtraAnims["Roar"]:Stop() end
	elseif name=="Taunt" then if ExtraAnims["Taunt"] then ExtraAnims["Taunt"]:Play() end PlaySound("EvilLaugh2") wait(3) if ExtraAnims["Taunt"] then ExtraAnims["Taunt"]:Stop() end
	elseif name=="Stomp" then if ExtraAnims["Stomp"] then ExtraAnims["Stomp"]:Play() end PlaySound("PhaseImpact") wait(0.5)
		ShakeCamera(1+CurrentPhase*0.2,1,50) CreateGroundSpikes(chara.Torso.Position,10+CurrentPhase*2,3+CurrentPhase,Color3.new(0.3,0,0))
		local sr=Instance.new("Part",workspace) sr.Shape="Cylinder" sr.Size=Vector3.new(0.5,1,1) sr.CFrame=CFrame.new(chara.Torso.Position-Vector3.new(0,3,0))*CFrame.Angles(0,0,math.rad(90)) sr.Material=Enum.Material.Neon sr.Color=Color3.new(1,0,0) sr.Anchored=true sr.CanCollide=false sr.Transparency=0.3
		spawn(function() for i=1,30 do local s=i*(2+CurrentPhase*0.5) sr.Size=Vector3.new(0.5,s,s) sr.Transparency=0.3+(i/30)*0.7
			for _,t in pairs(GetAllTargetsInRange(chara.Torso.Position,s/2)) do local h=t:FindFirstChild("Humanoid") if h and h.Health>0 then h.Health=h.Health-CurrentPhase*4 if h.Health<=0 then KillMortal(t) end end end wait(0.02) end sr:Destroy() end)
		wait(1.5) if ExtraAnims["Stomp"] then ExtraAnims["Stomp"]:Stop() end
	elseif name=="PowerUp" then if ExtraAnims["PowerUpAnim"] then ExtraAnims["PowerUpAnim"]:Play() end PlaySound("PhaseAscend") Humanoid.WalkSpeed=0 LevitatePlayer(5,3) ShakeCamera(0.8,2.5,40)
		spawn(function() for i=1,30 do CreateBodyLightning(chara.Torso,3,Color3.new(1,0,0)) wait(0.08) end end)
		CreateDarkPulse(chara.Torso.Position,20+CurrentPhase*3,Color3.new(1,0,0),3) wait(2.5)
		local info=PhaseInfo[CurrentPhase] if IsSprinting then Humanoid.WalkSpeed=info.RunSpeed else Humanoid.WalkSpeed=info.WalkSpeed end
		if ExtraAnims["PowerUpAnim"] then ExtraAnims["PowerUpAnim"]:Stop() end
	elseif name=="Point" then if ExtraAnims["Point"] then ExtraAnims["Point"]:Play() end
		if CurrentPhase>=4 then spawn(function() local ray=Instance.new("Part",workspace) ray.Size=Vector3.new(0.2,0.2,200) ray.Material=Enum.Material.Neon ray.Color=Color3.new(1,0,0)
			ray.Anchored=true ray.CanCollide=false ray.Transparency=0.3 ray.CFrame=chara["Right Arm"].CFrame*CFrame.new(0,-2,0)*CFrame.new(0,0,-100) ElectricEff(ray,Color3.new(1,0,0))
			for _,t in pairs(GetAllTargetsInRange(ray.Position,5)) do local h=t:FindFirstChild("Humanoid") if h and h.Health>0 then h.Health=h.Health-CurrentPhase*10 if h.Health<=0 then KillMortal(t) end end end
			wait(1) for i=1,10 do ray.Transparency=0.3+(i/10)*0.7 wait(0.03) end ray:Destroy() end) end
		wait(2) if ExtraAnims["Point"] then ExtraAnims["Point"]:Stop() end end EmoteActive=false end

