	local bodyParts={{Part=chara.Torso,Weight=3,MaxOffset=Vector3.new(1.2,1.2,0.6)},{Part=chara["Left Arm"],Weight=2,MaxOffset=Vector3.new(0.6,1.2,0.6)},
		{Part=chara["Right Arm"],Weight=2,MaxOffset=Vector3.new(0.6,1.2,0.6)},{Part=chara["Left Leg"],Weight=2,MaxOffset=Vector3.new(0.6,1.2,0.6)},
