function ClearMegaSpikes() for _,sd in pairs(MegaSpikes) do if sd.Connection then sd.Connection:Disconnect() end
	if sd.Part and sd.Part.Parent then spawn(function() local sp=sd.Part for i=1,10 do if not sp or not sp.Parent then break end sp.Transparency=i/10 sp.Size=sp.Size*0.9 wait(0.02) end if sp and sp.Parent then sp:Destroy() end end) end
end MegaSpikes={} LastDamageTick={} end

function CreateMegaSpike(parentPart,spikeSize,offsetCF,sData,index)
	local spike=Instance.new("WedgePart") spike.Name="MegaSpike_"..index spike.Size=Vector3.new(0.01,0.01,0.01)
	spike.Material=sData.Material spike.Color=sData.Color spike.CanCollide=false spike.Anchored=false spike.Parent=chara
	local weld=Instance.new("Weld",spike) weld.Part0=parentPart weld.Part1=spike weld.C0=offsetCF
	local targetSize=spikeSize

	if sData.GlowEnabled then
		local l=Instance.new("PointLight",spike) l.Name="SpikeGlow" l.Color=Color3.new(1,0,0) l.Brightness=0.5+CurrentPhase*0.15 l.Range=2+CurrentPhase*0.5
	end

	-- КРАСНЫЕ частицы на шипах
	if sData.ParticlesEnabled then
		local tp=Instance.new("ParticleEmitter",spike) tp.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.03+CurrentPhase*0.01),NumberSequenceKeypoint.new(1,0)})
		tp.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.2),NumberSequenceKeypoint.new(1,1)}) tp.LightEmission=1 tp.Lifetime=NumberRange.new(0.2+CurrentPhase*0.05,0.5+CurrentPhase*0.08)
		tp.Speed=NumberRange.new(0.5,2+CurrentPhase*0.3) tp.Rate=10+CurrentPhase*5 tp.VelocitySpread=60 tp.Texture="rbxassetid://347504241"
		tp.Color=ColorSequence.new(Color3.new(1,0,0),Color3.new(0.3,0,0)) tp.EmissionDirection="Top"
		local sm=Instance.new("ParticleEmitter",spike) sm.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.05),NumberSequenceKeypoint.new(0.5,0.15),NumberSequenceKeypoint.new(1,0.05)})
		sm.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(1,1)}) sm.LightEmission=0.2 sm.Lifetime=NumberRange.new(0.5,1)
		sm.Speed=NumberRange.new(0.3,1) sm.Rate=5+CurrentPhase*2 sm.VelocitySpread=180 sm.Texture="rbxasset://textures/particles/smoke_main.dds"
		sm.Color=ColorSequence.new(Color3.new(0.15,0,0)) sm.Acceleration=Vector3.new(0,1,0)
	end

	-- УРОН ПРИ КАСАНИИ
	local dmgConn=spike.Touched:Connect(function(hit)
		if not hit or not hit.Parent or hit.Parent==chara or hit:IsDescendantOf(chara) then return end
		local hum=hit.Parent:FindFirstChild("Humanoid") if not hum or hum.Health<=0 or hit.Parent:FindFirstChild("HasBeenHit") then return end
		local key=hit.Parent:GetFullName() if LastDamageTick[key] and tick()-LastDamageTick[key]<DamageTickRate then return end LastDamageTick[key]=tick()
		local dmg=sData.Damage*DamageMultiplier hum.Health=hum.Health-dmg PlaySound("SpikeDamage")
		spawn(function() local dg=Instance.new("BillboardGui",hit) dg.Size=UDim2.new(0,80,0,30) dg.StudsOffset=Vector3.new(math.random(-2,2),math.random(1,3),0) dg.Adornee=hit
			local dl=Instance.new("TextLabel",dg) dl.Size=UDim2.new(1,0,1,0) dl.BackgroundTransparency=1 dl.Text="-"..math.floor(dmg) dl.TextColor3=Color3.new(1,0,0) dl.TextStrokeTransparency=0 dl.TextStrokeColor3=Color3.new(0,0,0) dl.Font=Enum.Font.GothamBold dl.TextScaled=true
			for i=1,30 do dg.StudsOffset=dg.StudsOffset+Vector3.new(0,0.08,0) dl.TextTransparency=i/30 dl.TextStrokeTransparency=i/30 wait(0.03) end dg:Destroy() end)
		if hum.Health<=0 then KillMortal(hit.Parent) end
		local torso=hit.Parent:FindFirstChild("Torso") or hit.Parent:FindFirstChild("UpperTorso")
		if torso then local pf=Instance.new("BodyVelocity",torso) pf.Velocity=(torso.Position-chara.Torso.Position).Unit*(20+CurrentPhase*5)+Vector3.new(0,15,0) pf.MaxForce=Vector3.new(50000,50000,50000) Debris:AddItem(pf,0.3) end
	end)

	spawn(function() for i=1,20 do if not spike or not spike.Parent then break end local p=i/20 local bn=1+math.sin(p*math.pi*2)*(1-p)*0.3
		spike.Size=Vector3.new(targetSize.X*p*bn,targetSize.Y*p*bn,targetSize.Z*p*bn) wait(0.02) end if spike and spike.Parent then spike.Size=targetSize end end)

	if sData.PulseEnabled then spawn(function() local ps=sData.AnimationSpeed
		while spike and spike.Parent do local pu=math.sin(tick()*ps+index)*0.1 spike.Size=Vector3.new(targetSize.X*(1+pu),targetSize.Y*(1+pu*0.5),targetSize.Z*(1+pu))
			local t=(math.sin(tick()*ps*0.5+index)+1)/2 spike.Color=lerpColor(sData.Color,Color3.new(1,0,0),t)
			local gl=spike:FindFirstChild("SpikeGlow") if gl then gl.Brightness=(0.5+CurrentPhase*0.15)*(1+pu*3) end wait(0.03) end end) end

	table.insert(MegaSpikes,{Part=spike,Weld=weld,TargetSize=targetSize,Connection=dmgConn}) return spike
end

