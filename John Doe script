-- Фаза 2: Волны урона при ходьбе
local Phase2AbilityCD = 0
local function Phase2WaveAttack()
	if tick() - Phase2AbilityCD < 2 then return end
	Phase2AbilityCD = tick()
	local wave = Instance.new("Part", workspace)
	wave.Shape = "Ball"
	wave.Size = Vector3.new(2, 2, 2)
	wave.Position = chara.Torso.Position
	wave.Material = Enum.Material.Neon
	wave.Color = Color3.new(1, 0, 0)
	wave.Anchored = true
	wave.CanCollide = false
	wave.Transparency = 0.5
	
	spawn(function()
		for i = 1, 30 do
			wave.Size = Vector3.new(4*i, 4*i, 4*i)
			wave.Transparency = 0.5 + (i/30)*0.5
			for _, target in pairs(GetAllTargetsInRange(wave.Position, 8*i/30)) do
				local h = target:FindFirstChild("Humanoid")
				if h and h.Health > 0 then
					h.Health = h.Health - 5
					if h.Health <= 0 then KillMortal(target) end
				end
			end
			wait(0.03)
		end
		wave:Destroy()
	end)
end

-- Фаза 3: Спонтанные взрывы
local Phase3ExplosionCD = 0
local function Phase3SpontaneousExplosion()
	if tick() - Phase3ExplosionCD < 3 then return end
	Phase3ExplosionCD = tick()
	local explosions = math.floor(CurrentPhase/2)
	for i = 1, explosions do
		spawn(function()
			local exp = Instance.new("Part", workspace)
			exp.Shape = "Ball"
			exp.Size = Vector3.new(5, 5, 5)
			exp.Position = chara.Torso.Position + Vector3.new(math.random(-15, 15), math.random(-5, 15), math.random(-15, 15))
			exp.Material = Enum.Material.Neon
			exp.Color = Color3.new(1, 0.2, 0)
			exp.Anchored = true
			exp.CanCollide = false
			exp.Transparency = 0.3
			
			for j = 1, 15 do
				exp.Size = exp.Size + Vector3.new(2, 2, 2)
				exp.Transparency = 0.3 + (j/15)*0.7
				for _, target in pairs(GetAllTargetsInRange(exp.Position, 10)) do
					local h = target:FindFirstChild("Humanoid")
					if h and h.Health > 0 then h.Health = h.Health - 3 end
				end
				wait(0.03)
			end
			exp:Destroy()
		end)
	end
end

-- Фаза 4: Шокирующие волны при атаке
local Phase4ShockCD = 0
local function Phase4ShockWave()
	if tick() - Phase4ShockCD < 1.5 then return end
	Phase4ShockCD = tick()
	for i = 1, 3 do
		spawn(function()
			local shock = Instance.new("Part", workspace)
			shock.Shape = "Cylinder"
			shock.Size = Vector3.new(1, 20, 20)
			shock.CFrame = chara.Torso.CFrame * CFrame.Angles(0, 0, math.rad(90))
			shock.Material = Enum.Material.Neon
			shock.Color = Color3.new(1, 0, 0)
			shock.Anchored = true
			shock.CanCollide = false
			shock.Transparency = 0.5
			
			for j = 1, 20 do
				shock.Size = Vector3.new(1, 20 + j*2, 20 + j*2)
				shock.CFrame = chara.Torso.CFrame * CFrame.Angles(0, 0, math.rad(90))
				shock.Transparency = 0.5 + (j/20)*0.5
				wait(0.03)
			end
			shock:Destroy()
		end)
	end
end

-- Фаза 5-10: Прогрессивные эффекты
local function PhaseProgressiveEffect()
	if CurrentPhase >= 5 then
		-- Тёмные шары кружат вокруг
		spawn(function()
			for i = 1, 3 do
				local orb = Instance.new("Part", chara)
				orb.Shape = "Ball"
				orb.Size = Vector3.new(0.5, 0.5, 0.5)
				orb.Material = Enum.Material.Neon
				orb.Color = Color3.new(1, 0, 0)
				orb.CanCollide = false
				orb.Anchored = true
				
				spawn(function()
					while orb and orb.Parent do
						local angle = (i/3)*math.pi*2 + tick()
						orb.Position = chara.Torso.Position + Vector3.new(math.cos(angle)*5, math.sin(tick())*2, math.sin(angle)*5)
						wait(0.02)
					end
				end)
			end
		end)
	end
	
	if CurrentPhase >= 7 then
		-- Огненные вспышки на прыжке
		if Humanoid.Jumping then
			for i = 1, 5 do
				local flame = Instance.new("Part", workspace)
				flame.Shape = "Ball"
				flame.Size = Vector3.new(2, 2, 2)
				flame.Position = chara.Torso.Position + Vector3.new(math.random(-8, 8), 0, math.random(-8, 8))
				flame.Material = Enum.Material.Neon
				flame.Color = Color3.new(1, 0.3, 0)
				flame.Anchored = true
				flame.CanCollide = false
				
				spawn(function()
					for j = 1, 10 do
						flame.Transparency = j/10
						wait(0.1)
					end
					flame:Destroy()
				end)
			end
		end
	end
end

