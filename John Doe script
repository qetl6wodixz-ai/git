function ClearTendrils() for _,t in pairs(DarkTendrils) do if t.Folder and t.Folder.Parent then t.Folder:Destroy() end t.Active=false end DarkTendrils={} end
function ClearOrbs() for _,o in pairs(FloatingOrbs) do if o.Part and o.Part.Parent then o.Part:Destroy() end if o.Connection then o.Connection:Disconnect() end end FloatingOrbs={} end
function ClearWings() for _,w in pairs(PhaseWings) do if w and w.Parent then w:Destroy() end end PhaseWings={} end
function ClearBodyTrails() for _,t in pairs(BodyTrails) do if t and t.Parent then t:Destroy() end end BodyTrails={} end
function ClearAuras() for _,a in pairs(AuraObjects) do if a and a.Parent then a:Destroy() end end AuraObjects={} end
function ClearEyeEffects() for _,e in pairs(EyeEffects) do if e and e.Parent then e:Destroy() end end EyeEffects={} end

function GenerateTendrilsForPhase(phase) ClearTendrils() if phase<3 then return end
	local tc=math.floor((phase-2)*1.5) local tl=2+phase*0.5 local segs=4+math.floor(phase/2) local dmg=10+phase*5
	local bps={chara.Torso,chara["Left Arm"],chara["Right Arm"]} if phase>=6 then table.insert(bps,chara["Left Leg"]) table.insert(bps,chara["Right Leg"]) end
	for i=1,tc do local bp=bps[((i-1)%#bps)+1] local folder=Instance.new("Folder",chara) folder.Name="Tendril"
		local parts={} local prev=bp local ba=math.random()*math.pi*2
		for s=1,segs do local sz=Vector3.new(0.15+(1-s/segs)*0.2,tl/segs,0.15+(1-s/segs)*0.2)
			local seg=Instance.new("Part",folder) seg.Size=sz seg.Material=Enum.Material.Neon seg.Color=Color3.new(0.2,0,0) seg.CanCollide=false seg.Anchored=false seg.Transparency=0.2+(s/segs)*0.3
			local w=Instance.new("Weld",seg) w.Part0=prev w.Part1=seg
			if s==1 then w.C0=CFrame.new(math.cos(ba)*0.5,0,math.sin(ba)*0.5)*CFrame.Angles(math.random()*0.5,ba,0)
			else w.C0=CFrame.new(0,-sz.Y,0)*CFrame.Angles(math.sin(tick()+s)*0.2,0,math.cos(tick()+s)*0.2) end
			seg.Touched:Connect(function(hit) if not hit or not hit.Parent or hit.Parent==chara or hit:IsDescendantOf(chara) then return end
				local hum=hit.Parent:FindFirstChild("Humanoid") if not hum or hum.Health<=0 or hit.Parent:FindFirstChild("HasBeenHit") then return end
				local key=hit.Parent:GetFullName().."_t" if LastDamageTick[key] and tick()-LastDamageTick[key]<0.8 then return end LastDamageTick[key]=tick()
				hum.Health=hum.Health-dmg PlaySound("TendrilWhip") if hum.Health<=0 then KillMortal(hit.Parent) end end)
			table.insert(parts,seg) prev=seg end
		local td={Parts=parts,Folder=folder,Active=true}
		spawn(function() while td.Active and folder and folder.Parent do for si,seg in ipairs(parts) do if seg and seg.Parent then local w=seg:FindFirstChildOfClass("Weld")
			if w and si>1 then local t=tick()*(1.5+CurrentPhase*0.1)+si*0.5 w.C0=CFrame.new(0,-seg.Size.Y,0)*CFrame.Angles(math.sin(t)*(0.15+CurrentPhase*0.02),math.cos(t*0.7)*0.1,math.sin(t*1.3)*(0.15+CurrentPhase*0.02)) end end end wait(0.03) end end)
		table.insert(DarkTendrils,td) wait(0.1) end end

function GenerateOrbsForPhase(phase) ClearOrbs() if phase<2 then return end local dmg=10+phase*8
	for i=1,phase do local orb=Instance.new("Part",chara) orb.Shape="Ball" orb.Size=Vector3.new(0.01,0.01,0.01) orb.Material=Enum.Material.Neon orb.Color=Color3.new(1,0,0) orb.CanCollide=false orb.Anchored=true orb.Transparency=0.2
		Instance.new("PointLight",orb).Color=Color3.new(1,0,0)
		local op=Instance.new("ParticleEmitter",orb) op.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.15),NumberSequenceKeypoint.new(1,0)})
		op.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)}) op.LightEmission=1 op.Lifetime=NumberRange.new(0.5,1) op.Speed=NumberRange.new(0.5,2)
		op.Rate=40 op.VelocitySpread=360 op.Texture="rbxassetid://347504259" op.Color=ColorSequence.new(Color3.new(1,0,0))
		spawn(function() local ts=0.6+CurrentPhase*0.1 for j=1,15 do if not orb or not orb.Parent then break end local s=ts*(j/15) orb.Size=Vector3.new(s,s,s) wait(0.03) end end)
		local dc=orb.Touched:Connect(function(hit) if not hit or not hit.Parent or hit.Parent==chara or hit:IsDescendantOf(chara) then return end
			local hum=hit.Parent:FindFirstChild("Humanoid") if not hum or hum.Health<=0 or hit.Parent:FindFirstChild("HasBeenHit") then return end
			local key=hit.Parent:GetFullName().."_o" if LastDamageTick[key] and tick()-LastDamageTick[key]<1 then return end LastDamageTick[key]=tick()
			hum.Health=hum.Health-dmg if hum.Health<=0 then KillMortal(hit.Parent) end end)
		table.insert(FloatingOrbs,{Part=orb,Index=i,Total=phase,Connection=dc})
		spawn(function() while orb and orb.Parent do if chara:FindFirstChild("Torso") then local t=tick()*(0.8+CurrentPhase*0.05) local a=(i/phase)*math.pi*2+t local r=3+CurrentPhase*0.3+math.sin(t*0.5)*0.5
			orb.Position=chara.Torso.Position+Vector3.new(math.cos(a)*r,math.sin(t*1.5+i)*1.5+1,math.sin(a)*r) end wait(0.02) end end) wait(0.15) end end

function CreateDarkWings(phase) ClearWings() if phase<5 then return end
	local wf=Instance.new("Folder",chara) wf.Name="DarkWings" table.insert(PhaseWings,wf) local ws=1+(phase-5)*0.8 local fc=3+(phase-5)*2
	for side=-1,1,2 do local wb=Instance.new("Part",wf) wb.Size=Vector3.new(0.3,0.5,0.3) wb.Material=Enum.Material.Neon wb.Color=Color3.new(0.3,0,0) wb.CanCollide=false wb.Anchored=false wb.Transparency=0.3
		local ww=Instance.new("Weld",wb) ww.Part0=chara.Torso ww.Part1=wb ww.C0=CFrame.new(side*0.8,0.5,0.5)
		for f=1,fc do local fl=ws*(1-(f/fc)*0.3) local ft=Instance.new("WedgePart",wf) ft.Size=Vector3.new(0.1,fl,0.4+(1-f/fc)*0.6) ft.Material=Enum.Material.Neon ft.Color=Color3.new(0.15,0,0) ft.CanCollide=false ft.Anchored=false ft.Transparency=0.1+(f/fc)*0.4
			local fw=Instance.new("Weld",ft) fw.Part0=wb fw.Part1=ft fw.C0=CFrame.new(side*fl*0.5,(f/fc)*0.3,0)*CFrame.Angles(0,0,side*(f/fc)*math.rad(60))
			ft.Touched:Connect(function(hit) if not hit or not hit.Parent or hit.Parent==chara or hit:IsDescendantOf(chara) then return end
				local hum=hit.Parent:FindFirstChild("Humanoid") if not hum or hum.Health<=0 or hit.Parent:FindFirstChild("HasBeenHit") then return end
				local key=hit.Parent:GetFullName().."_w" if LastDamageTick[key] and tick()-LastDamageTick[key]<0.6 then return end LastDamageTick[key]=tick()
				hum.Health=hum.Health-(20+phase*5) if hum.Health<=0 then KillMortal(hit.Parent) end end) end
		spawn(function() while wf and wf.Parent do local t=tick() ww.C0=CFrame.new(side*0.8,0.5,0.5)*CFrame.Angles(math.sin(t*0.5)*math.rad(5),0,side*(math.rad(30)+math.sin(t*2)*math.rad(15+(phase-5)*3))) wait(0.03) end end) end end

function GenerateTrailsForPhase(phase) ClearBodyTrails() if phase<1 then return end local lt=0.3+phase*0.08 local w=0.5+phase*0.15
	local parts={chara.Torso} if phase>=2 then table.insert(parts,chara["Left Arm"]) table.insert(parts,chara["Right Arm"]) end
	if phase>=4 then table.insert(parts,chara["Left Leg"]) table.insert(parts,chara["Right Leg"]) end
	for _,p in pairs(parts) do local a0=Instance.new("Attachment",p) a0.Position=Vector3.new(0,p.Size.Y/2,0)
		local a1=Instance.new("Attachment",p) a1.Position=Vector3.new(0,-p.Size.Y/2,0)
		local tr=Instance.new("Trail",p) tr.Attachment0=a0 tr.Attachment1=a1 tr.Color=ColorSequence.new(Color3.new(1,0,0),Color3.new(0,0,0))
		tr.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.3),NumberSequenceKeypoint.new(0.5,0.5),NumberSequenceKeypoint.new(1,1)}) tr.Lifetime=lt tr.MinLength=0.05 tr.MaxWidth=w tr.LightEmission=0.5 tr.FaceCamera=true
		table.insert(BodyTrails,a0) table.insert(BodyTrails,a1) table.insert(BodyTrails,tr) end end

function GenerateAuraForPhase(phase) ClearAuras() if phase<1 then return end local dl=PhaseInfo[phase].DarkLevel
	local ma=Instance.new("ParticleEmitter",chara.Torso) ma.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.5+dl*2),NumberSequenceKeypoint.new(0.5,1.5+dl*4),NumberSequenceKeypoint.new(1,0.5+dl*2)})
	ma.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.7-dl*0.3),NumberSequenceKeypoint.new(0.5,0.4-dl*0.2),NumberSequenceKeypoint.new(1,1)})
	ma.LightEmission=0.2+dl*0.5 ma.Lifetime=NumberRange.new(1+dl*3) ma.Speed=NumberRange.new(1+dl*4) ma.Rate=math.floor(30+dl*150) ma.VelocitySpread=360
	ma.Texture="rbxasset://textures/particles/smoke_main.dds" ma.Color=ColorSequence.new(Color3.new(0.5,0,0),Color3.new(0,0,0)) ma.Acceleration=Vector3.new(0,2+dl*8,0) table.insert(AuraObjects,ma)
	if phase>=2 then local sa=Instance.new("ParticleEmitter",chara.Torso) sa.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.05+dl*0.1),NumberSequenceKeypoint.new(0.3,0.15+dl*0.2),NumberSequenceKeypoint.new(1,0.02)})
		sa.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(0.5,0.3),NumberSequenceKeypoint.new(1,1)}) sa.LightEmission=1.5 sa.Lifetime=NumberRange.new(0.3,0.8)
		sa.Speed=NumberRange.new(3+dl*8) sa.Rate=math.floor(20+dl*80) sa.VelocitySpread=360 sa.Texture="rbxassetid://347504241" sa.Color=ColorSequence.new(Color3.new(1,0,0)) table.insert(AuraObjects,sa) end
	if phase>=3 then for _,p in pairs({chara["Left Arm"],chara["Right Arm"],chara["Left Leg"],chara["Right Leg"]}) do
		local ls=Instance.new("ParticleEmitter",p) ls.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.2+dl*0.3),NumberSequenceKeypoint.new(1,0.5+dl*0.8)})
		ls.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(1,1)}) ls.Lifetime=NumberRange.new(0.5,1.5) ls.Speed=NumberRange.new(0.5,2) ls.Rate=math.floor(10+dl*30) ls.VelocitySpread=180
		ls.Texture="rbxasset://textures/particles/smoke_main.dds" ls.Color=ColorSequence.new(Color3.new(0.15,0,0)) ls.Acceleration=Vector3.new(0,1,0) table.insert(AuraObjects,ls) end end
	if phase>=5 then local ea=Instance.new("ParticleEmitter",chara.Torso) ea.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.05),NumberSequenceKeypoint.new(0.2,0.3+dl*0.3),NumberSequenceKeypoint.new(1,0.05)})
		ea.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(0.3,0.2),NumberSequenceKeypoint.new(1,1)}) ea.LightEmission=2 ea.Lifetime=NumberRange.new(0.1,0.4)
		ea.Speed=NumberRange.new(5,12) ea.Rate=math.floor(50+dl*150) ea.VelocitySpread=360 ea.Texture="rbxassetid://347504241" ea.Color=ColorSequence.new(Color3.new(1,0,0),Color3.new(0.5,0,0)) table.insert(AuraObjects,ea) end
	if phase>=7 then local fa=Instance.new("ParticleEmitter",chara.Torso) fa.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(0.3,1+dl),NumberSequenceKeypoint.new(1,0.3)})
		fa.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.3),NumberSequenceKeypoint.new(0.5,0.5),NumberSequenceKeypoint.new(1,1)}) fa.LightEmission=1 fa.Lifetime=NumberRange.new(0.5,1.5)
		fa.Speed=NumberRange.new(2,6) fa.Rate=math.floor(60+dl*100) fa.VelocitySpread=30 fa.Texture="rbxasset://textures/particles/fire_main.dds" fa.Color=ColorSequence.new(Color3.new(1,0,0),Color3.new(0.3,0,0))
		fa.Acceleration=Vector3.new(0,15,0) fa.EmissionDirection="Top" table.insert(AuraObjects,fa) end end

function GenerateEyeEffectsForPhase(phase) ClearEyeEffects() if phase<1 then return end
	if EyeFire then for _,c in pairs(EyeFire:GetChildren()) do if c:IsA("ParticleEmitter") then c.Rate=100+phase*30 c.Speed=NumberRange.new(1+phase*0.3) c.Color=ColorSequence.new(Color3.new(1,0,0)) end end end
	if phase>=3 then local e2=Instance.new("Part",chara) e2.Size=Vector3.new(0.4,0.2,0.2) e2.Material=Enum.Material.Neon e2.Color=Color3.new(1,0,0) e2.CanCollide=false e2.Anchored=false
		local w2=Instance.new("Weld",e2) w2.Part0=FakeHead.MainPart w2.Part1=e2 w2.C0=CFrame.new(-0.3,0.1,-0.6)
		local ef2=Instance.new("ParticleEmitter",e2) ef2.Size=NumberSequence.new(0.1+phase*0.02) ef2.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(0.2,0),NumberSequenceKeypoint.new(1,1)})
		ef2.LightEmission=1 ef2.Lifetime=NumberRange.new(0.3+phase*0.05) ef2.Speed=NumberRange.new(1+phase*0.3) ef2.EmissionDirection="Front" ef2.Rate=100+phase*30
		ef2.Texture="rbxassetid://347504241" ef2.Acceleration=Vector3.new(0,10,0) ef2.Color=ColorSequence.new(Color3.new(1,0,0)) table.insert(EyeEffects,e2) end
	if phase>=6 then local e3=Instance.new("Part",chara) e3.Shape="Ball" e3.Size=Vector3.new(0.3,0.3,0.15) e3.Material=Enum.Material.Neon e3.Color=Color3.new(1,0,0) e3.CanCollide=false e3.Anchored=false
		local w3=Instance.new("Weld",e3) w3.Part0=FakeHead.MainPart w3.Part1=e3 w3.C0=CFrame.new(0,0.35,-0.5)
		local el3=Instance.new("PointLight",e3) el3.Color=Color3.new(1,0,0) el3.Brightness=5 el3.Range=10
		spawn(function() while e3 and e3.Parent do local p=math.sin(tick()*3)*0.1 e3.Size=Vector3.new(0.3+p,0.3+p,0.15) el3.Brightness=5+math.sin(tick()*2)*2 wait(0.03) end end)
		table.insert(EyeEffects,e3) end end

